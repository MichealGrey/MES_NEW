<Window x:Class="MES.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        Title="半导体MES制造执行系统" Height="1080" Width="1920"
        WindowState="Maximized" Background="{DynamicResource MesBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>
        <ContentControl prism:RegionManager.RegionName="MenuRegion" Grid.Row="0"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="320"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ContentControl prism:RegionManager.RegionName="NavigationRegion" Grid.Column="0"/>
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="{StaticResource MesBorderBrush}" ShowsPreview="True"/>
            <ContentControl prism:RegionManager.RegionName="MainContentRegion" Grid.Column="2"/>
        </Grid>
        <ContentControl prism:RegionManager.RegionName="StatusRegion" Grid.Row="2"/>
    </Grid>
</Window>
