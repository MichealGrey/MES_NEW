<Window x:Class="MES.Shell.Views.AccountSwitchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="切换账号" Height="320" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="24">
        <TextBlock Text="切换账号" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" HorizontalAlignment="Center"/>

        <TextBlock Text="工号" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="txtEmployeeId" Height="32" Margin="0,0,0,12"/>

        <TextBlock Text="密码" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="txtPassword" Height="32" Margin="0,0,0,12"/>

        <TextBlock x:Name="txtError" Text="" Foreground="Red" FontSize="12" Margin="0,0,0,8" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button Content="切换" Width="100" Height="34" Click="btnSwitch_Click" IsDefault="True"/>
            <Button Content="锁定屏幕" Width="100" Height="34" Margin="12,0,0,0" Click="btnLock_Click"/>
            <Button Content="取消" Width="80" Height="34" Margin="12,0,0,0" Click="btnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
