<Window x:Class="MES.Shell.Views.LockScreenView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="屏幕已锁定" Height="400" Width="480"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Topmost="true"
        ResizeMode="NoResize"
        WindowStyle="None">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="1" HorizontalAlignment="Center">
            <TextBlock Text="🔒" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="屏幕已锁定" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="请输入密码解锁" FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>

            <StackPanel Margin="0,24,0,0" Width="280">
                <TextBlock Text="密码" FontSize="12" Margin="0,0,0,4"/>
                <TextBox x:Name="txtPassword" Height="36" Margin="0,0,0,8" KeyDown="txtPassword_KeyDown"/>

                <TextBlock x:Name="txtError" Text="" Foreground="Red" FontSize="12" Margin="0,0,0,8" Visibility="Collapsed"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Button Content="解锁" Width="120" Height="36" Click="btnUnlock_Click" IsDefault="True"/>
                    <Button Content="切换账号" Width="120" Height="36" Margin="16,0,0,0" Click="btnSwitch_Click"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
