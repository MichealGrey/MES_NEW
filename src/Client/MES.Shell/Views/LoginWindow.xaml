<Window x:Class="MES.Shell.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
        Title="半导体MES - 用户登录"
        Height="420" Width="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowState="Normal"
        Topmost="True">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="LoginInputStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#1E1E35"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A45"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#00D2FF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <!-- 主背景 + 圆角 + 阴影 -->
    <Border CornerRadius="8" Background="#121220">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.6" ShadowDepth="0" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题区 -->
            <Border Grid.Row="0"
                    Background="#0F3460"
                    CornerRadius="8,8,0,0"
                    Padding="24,24">
                <StackPanel>
                    <TextBlock Text="半导体封测制造执行系统"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="SEMI-MES (Semiconductor MES)"
                               FontSize="11"
                               Foreground="#88FFFFFF"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- 登录表单 -->
            <Grid Grid.Row="1" Margin="48,12,48,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 工号 -->
                <TextBlock Grid.Row="0"
                           Text="工号 / 厂牌号"
                           FontSize="13"
                           Foreground="#B0B0C0"
                           Margin="0,16,0,8"/>
                <TextBox Grid.Row="1"
                         x:Name="EmployeeIdBox"
                         Text="{Binding EmployeeId, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource LoginInputStyle}"
                         MaxLength="20"
                         ToolTip="输入工号或扫描厂牌条形码，按 Enter 登录">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding LoginCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- 密码 -->
                <TextBlock Grid.Row="2"
                           Text="密码"
                           FontSize="13"
                           Foreground="#B0B0C0"
                           Margin="0,16,0,8"/>
                <PasswordBox Grid.Row="3"
                             x:Name="PasswordBox"
                             Height="44"
                             FontSize="18"
                             Padding="12,0"
                             Background="#1E1E35"
                             Foreground="White"
                             BorderBrush="#2A2A45"
                             BorderThickness="1"
                             PasswordChar="●"
                             ToolTip="输入密码，厂牌扫描可留空"
                             PasswordChanged="PasswordBox_PasswordChanged">
                    <PasswordBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding LoginCommand}"/>
                    </PasswordBox.InputBindings>
                </PasswordBox>

                <!-- 错误提示 -->
                <Border Grid.Row="4"
                        Background="#3A1010"
                        CornerRadius="4"
                        Padding="12,8"
                        Margin="0,12,0,0"
                        BorderBrush="#E74C3C"
                        BorderThickness="1"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#E74C3C"
                               FontSize="13"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- 加载指示 -->
                <StackPanel Grid.Row="5" Margin="0,8,0,0"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <ProgressBar IsIndeterminate="True"
                                 Height="3"
                                 Foreground="#00D2FF"
                                 Background="#2A2A45"/>
                    <TextBlock Text="正在验证身份..."
                               FontSize="12"
                               Foreground="#808098"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 登录按钮 -->
                <Button Grid.Row="6"
                        Content="登 录"
                        Command="{Binding LoginCommand}"
                        Height="44"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="White"
                        Background="#00D2FF"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,12,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#00D2FF"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#33DDFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#0099CC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- 底部提示 -->
                <TextBlock Grid.Row="7"
                           Text="厂牌扫描后可直接按 Enter 登录"
                           FontSize="11"
                           Foreground="#505068"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
                <Button Grid.Row="6"
                    Content="取 消"
                    Height="44"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="White"
                    Background="Red"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,50,0,-28" Click="Button_Click" Grid.RowSpan="2">
                    <Button.Style>
                        <Style TargetType="{x:Type Button}">
                            <Setter Property="Background" Value="#00D2FF"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#33DDFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#0099CC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
