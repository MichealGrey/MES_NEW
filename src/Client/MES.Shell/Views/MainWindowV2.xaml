<Window x:Class="MES.Shell.MainWindowV2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:vm="clr-namespace:MES.Shell.ViewModels"
        Title="OSAT MES - 半导体制造执行系统"
        Height="1080"
        Width="1920"
        MinHeight="720"
        MinWidth="1280"
        WindowState="Maximized"
        Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <Window.DataContext>
        <vm:HeaderViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- 标题栏按钮样式 -->
        <Style x:Key="MesHeaderButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="{DynamicResource MesRadiusSm}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource MesBackgroundElevatedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- 顶部标题栏：64px -->
            <RowDefinition Height="64"/>
            <!-- 主内容区域 -->
            <RowDefinition Height="*"/>
            <!-- 底部状态栏：32px -->
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- ==========================================
             第一部分：顶部标题栏
        ========================================== -->
        <Border Grid.Row="0"
                Background="{StaticResource MesBackgroundSurfaceBrush}"
                BorderBrush="{StaticResource MesBorderDefaultBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <!-- Logo 区域 -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- 面包屑/模块导航 -->
                    <ColumnDefinition Width="*"/>
                    <!-- 全局搜索 -->
                    <ColumnDefinition Width="320"/>
                    <!-- 用户信息 -->
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo 和系统名称 -->
                <StackPanel Grid.Column="0"
                           Orientation="Horizontal"
                           VerticalAlignment="Center"
                           Margin="0,0,24,0">
                    <Border Width="40"
                           Height="40"
                           Background="{StaticResource MesInfoBrush}"
                           CornerRadius="8"
                           Margin="0,0,12,0">
                        <TextBlock Text="MES"
                                  FontFamily="{StaticResource MesFontDisplay}"
                                  FontSize="14"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="OSAT MES"
                              FontFamily="{StaticResource MesFontDisplay}"
                              FontSize="20"
                              FontWeight="SemiBold"
                              Foreground="{StaticResource MesTextPrimaryBrush}"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 模块导航标签 -->
                <ItemsControl Grid.Column="1"
                             ItemsSource="{Binding Modules}"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Left">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                   Style="{StaticResource MesGhostButton}"
                                   Command="{Binding DataContext.SwitchModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                   CommandParameter="{Binding Name}"
                                   Margin="0,0,4,0"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 全局搜索框 -->
                <Border Grid.Column="2"
                       Background="{StaticResource MesBackgroundElevatedBrush}"
                       CornerRadius="{StaticResource MesRadiusSm}"
                       Margin="16,0"
                       MaxWidth="320">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                  Text="🔍"
                                  FontSize="14"
                                  Foreground="{StaticResource MesTextTertiaryBrush}"
                                  VerticalAlignment="Center"
                                  Margin="12,0,8,0"/>
                        <TextBox Grid.Column="1"
                                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource MesTextBox}"
                                BorderThickness="0"
                                Background="Transparent"
                                VerticalAlignment="Center"
                                FontSize="13"
                                Foreground="{StaticResource MesTextPrimaryBrush}"/>
                    </Grid>
                </Border>

                <!-- 用户信息区域 -->
                <StackPanel Grid.Column="3"
                           Orientation="Horizontal"
                           VerticalAlignment="Center">
                    <!-- 通知按钮 -->
                    <Button Style="{StaticResource MesHeaderButton}"
                           Content="🔔"
                           ToolTip="通知"/>

                    <!-- 设置按钮 -->
                    <Button Style="{StaticResource MesHeaderButton}"
                           Content="⚙"
                           ToolTip="设置"/>

                    <!-- 用户头像和名称 -->
                    <Border Background="{StaticResource MesBackgroundElevatedBrush}"
                           CornerRadius="{StaticResource MesRadiusSm}"
                           Padding="12,6"
                           Margin="8,0,0,0"
                           Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28"
                                   Height="28"
                                   Background="{StaticResource MesInfoBrush}"
                                   CornerRadius="{StaticResource MesRadiusFull}"
                                   Margin="0,0,8,0">
                                <TextBlock Text="👤"
                                          FontSize="14"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding UserName}"
                                         FontSize="13"
                                         FontWeight="Medium"
                                         Foreground="{StaticResource MesTextPrimaryBrush}"/>
                                <TextBlock Text="{Binding UserRole}"
                                         FontSize="11"
                                         Foreground="{StaticResource MesTextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==========================================
             第二部分：主内容区域（侧边栏 + 内容）
        ========================================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 侧边导航栏：240px（可折叠） -->
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="Auto"/>
                <!-- 主内容区域 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 侧边导航栏 -->
            <ContentControl prism:RegionManager.RegionName="NavigationRegionV2"
                           Grid.Column="0"
                           Background="{StaticResource MesBackgroundSurfaceBrush}"
                           BorderBrush="{StaticResource MesBorderDefaultBrush}"
                           BorderThickness="0,0,1,0"/>

            <!-- 可拖拽的分隔条 -->
            <GridSplitter Grid.Column="1"
                         Width="4"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Stretch"
                         Background="{StaticResource MesBorderDefaultBrush}"
                         ShowsPreview="True"
                         Cursor="SizeWE"/>

            <!-- 主内容区域 -->
            <ContentControl prism:RegionManager.RegionName="MainContentRegionV2"
                           Grid.Column="2"
                           Background="{StaticResource MesBackgroundPrimaryBrush}"/>
        </Grid>

        <!-- ==========================================
             第三部分：底部状态栏V2
        ========================================== -->
        <ContentControl prism:RegionManager.RegionName="StatusBarRegionV2"
                       Grid.Row="2"/>
    </Grid>
</Window>
