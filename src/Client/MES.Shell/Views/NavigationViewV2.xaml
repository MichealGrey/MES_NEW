<UserControl x:Class="MES.Shell.Views.NavigationViewV2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundSurfaceBrush}">

    <UserControl.Resources>
        <!-- 导航分组标题样式 -->
        <Style x:Key="NavGroupTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MesTextTertiaryBrush}"/>
            <Setter Property="Margin" Value="16,16,16,8"/>
        </Style>

        <!-- 导航菜单项按钮样式 -->
        <Style x:Key="NavMenuItem" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource MesTextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 左侧高亮条 -->
                                <Border x:Name="highlight"
                                       Grid.Column="0"
                                       Background="{DynamicResource MesInfoBrush}"
                                       Width="4"
                                       Margin="-16,0,12,0"
                                       Visibility="Collapsed"/>

                                <!-- 菜单文本 -->
                                <TextBlock Grid.Column="1"
                                          Text="{TemplateBinding Content}"
                                          VerticalAlignment="Center"/>

                                <!-- 右侧箭头 -->
                                <TextBlock Grid.Column="2"
                                          Text="▸"
                                          FontSize="10"
                                          Opacity="0.5"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource MesBackgroundElevatedBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource MesTextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="highlight" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="{DynamicResource MesTextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 子菜单项样式 -->
        <Style x:Key="NavSubMenuItem" TargetType="Button" BasedOn="{StaticResource NavMenuItem}">
            <Setter Property="Padding" Value="36,8,16,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

            <!-- 批次管理模块 -->
            <StackPanel Margin="0,16,0,0">
                <!-- 模块标题 -->
                <TextBlock Text="📦 批次管理"
                          Style="{StaticResource NavGroupTitle}"
                          Margin="16,0,16,8"/>

                <!-- 批次操作分组 -->
                <TextBlock Text="🔧 批次操作"
                          FontSize="12"
                          Foreground="{DynamicResource MesTextTertiaryBrush}"
                          Margin="28,12,16,4"/>

                <Button Content="批次详情"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="LotDetailViewV2"/>
                <Button Content="拆批/合批"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="LotSplitMergeView"/>
                <Button Content="Hold/Release"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="LotHoldView"/>
                <Button Content="批次异常"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="LotExceptionView"/>

                <!-- 批次归档 -->
                <TextBlock Text="📦 批次归档"
                          FontSize="12"
                          Foreground="{DynamicResource MesTextTertiaryBrush}"
                          Margin="28,12,16,4"/>

                <Button Content="批次归档"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="LotArchiveView"/>
            </StackPanel>

            <!-- 生产执行模块 -->
            <StackPanel Margin="0,16,0,0">
                <TextBlock Text="🏭 生产执行"
                          Style="{StaticResource NavGroupTitle}"/>

                <!-- 日常操作 -->
                <TextBlock Text="📌 日常操作"
                          FontSize="12"
                          Foreground="{DynamicResource MesTextTertiaryBrush}"
                          Margin="28,8,16,4"/>

                <Button Content="快速进站"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="TrackInView"/>
                <Button Content="进站/出站"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="TrackInView"/>
                <Button Content="生产报工"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="ProductionReportView"/>
                <Button Content="物料确认"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="MaterialManagementView"/>

                <!-- 计划管理 -->
                <TextBlock Text="📋 计划管理"
                          FontSize="12"
                          Foreground="{DynamicResource MesTextTertiaryBrush}"
                          Margin="28,12,16,4"/>

                <Button Content="派工管理"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="DispatchView"/>
                <Button Content="等级分选"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="GradeSortView"/>

                <!-- 特殊操作 -->
                <TextBlock Text="🔧 特殊操作"
                          FontSize="12"
                          Foreground="{DynamicResource MesTextTertiaryBrush}"
                          Margin="28,12,16,4"/>

                <Button Content="拆批/合批"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="LotSplitMergeView"/>
                <Button Content="产线监控"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="ProductionReportView"/>
            </StackPanel>

            <!-- 工单管理模块 -->
            <StackPanel Margin="0,16,0,0">
                <TextBlock Text="📋 工单管理"
                          Style="{StaticResource NavGroupTitle}"/>

                <Button Content="工单列表"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="WorkOrderListView"/>
                <Button Content="创建工单"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="AddWorkOrderWin"/>
                <Button Content="工单排程"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="WorkOrderScheduleView"/>
                <Button Content="客户交付跟踪"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="CustomerProgressView"/>
                <Button Content="工单关闭"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="WorkOrderCloseView"/>
            </StackPanel>

            <!-- 质量管理模块 -->
            <StackPanel Margin="0,16,0,0">
                <TextBlock Text="🔬 质量管理"
                          Style="{StaticResource NavGroupTitle}"/>

                <!-- 监控分析 -->
                <TextBlock Text="📊 监控分析"
                          FontSize="12"
                          Foreground="{DynamicResource MesTextTertiaryBrush}"
                          Margin="28,8,16,4"/>

                <Button Content="质量看板"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="QualityTargetView"/>
                <Button Content="SPC控制图"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="SpcChartView"/>
                <Button Content="FDC监控"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="FdcMonitorView"/>

                <!-- 检验执行 -->
                <TextBlock Text="🔍 检验执行"
                          FontSize="12"
                          Foreground="{DynamicResource MesTextTertiaryBrush}"
                          Margin="28,12,16,4"/>

                <Button Content="检验管理"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="InspectionView"/>
                <Button Content="首件检验"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="FirstArticleInspectionView"/>
                <Button Content="巡检管理"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="PatrolInspectionView"/>

                <!-- 异常处理 -->
                <TextBlock Text="⚠️ 异常处理"
                          FontSize="12"
                          Foreground="{DynamicResource MesTextTertiaryBrush}"
                          Margin="28,12,16,4"/>

                <Button Content="OOC事件"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="OocEventView"/>
                <Button Content="不合格品管理"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="NonconformingView"/>

                <!-- 配置管理 -->
                <TextBlock Text="⚙️ 配置管理"
                          FontSize="12"
                          Foreground="{DynamicResource MesTextTertiaryBrush}"
                          Margin="28,12,16,4"/>

                <Button Content="SPC规则"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="SpcRuleConfigView"/>
                <Button Content="FMEA"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="FmeaView"/>
                <Button Content="质量目标"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="QualityTargetView"/>
            </StackPanel>

            <!-- 设备管控模块 -->
            <StackPanel Margin="0,16,0,0">
                <TextBlock Text="⚙ 设备管控"
                          Style="{StaticResource NavGroupTitle}"/>

                <Button Content="设备总览"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="EquipmentOverviewView"/>
                <Button Content="设备详情"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="EquipmentDetailView"/>
                <Button Content="设备控制(EAP)"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="EapControlView"/>
                <Button Content="保养计划"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="PmScheduleView"/>
                <Button Content="故障管理"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="EquipmentAlarmView"/>
                <Button Content="备件管理"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="SparePartView"/>
                <Button Content="设备绩效"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="EquipmentPerformanceView"/>
                <Button Content="设备履历"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="EquipmentHistoryView"/>
                <Button Content="工装夹具"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="FixtureView"/>
            </StackPanel>

            <!-- 客诉8D模块（新增） -->
            <StackPanel Margin="0,16,0,0">
                <TextBlock Text="📢 客诉8D"
                          Style="{StaticResource NavGroupTitle}"/>

                <Button Content="客诉登记"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="ComplaintListView"/>
                <Button Content="8D全流程管理"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="ComplaintActionView"/>
                <Button Content="客户质量报告"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="ComplaintReportView"/>
                <Button Content="客户审核管理"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="ComplaintListView"/>
                <Button Content="RMA退货管理"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="ComplaintListView"/>
            </StackPanel>

            <!-- 工程变更模块（新增） -->
            <StackPanel Margin="0,16,0,0">
                <TextBlock Text="🔄 工程变更"
                          Style="{StaticResource NavGroupTitle}"/>

                <Button Content="ECR申请"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="ECNListView"/>
                <Button Content="ECO管理"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="ECNApprovalView"/>
                <Button Content="变更验证"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="ECNImpactView"/>
                <Button Content="变更履历"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="ECNHistoryView"/>
            </StackPanel>

            <!-- 其他模块占位 -->
            <StackPanel Margin="0,16,0,16">
                <TextBlock Text="🗃 更多模块"
                          Style="{StaticResource NavGroupTitle}"/>

                <Button Content="仓储物流"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="FoupManagementView"/>
                <Button Content="排程调度"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="DispatchBoardView"/>
                <Button Content="追溯管理"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="LotTraceView"/>
                <Button Content="良率分析"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="YieldDashboardView"/>
                <Button Content="配方管理"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="RecipeListView"/>
                <Button Content="报警中心"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="AlarmDashboardView"/>
                <Button Content="EHS管理"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="EnvironmentMonitorView"/>
                <Button Content="主数据"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="ProductManagementView"/>
                <Button Content="报表中心"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="ProductionReportView"/>
                <Button Content="系统设置"
                       Style="{StaticResource NavSubMenuItem}"
                       Command="{Binding NavigateCommand}" CommandParameter="SystemMonitorView"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
