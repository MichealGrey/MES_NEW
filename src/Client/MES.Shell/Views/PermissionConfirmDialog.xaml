<Window x:Class="MES.Shell.Views.PermissionConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="操作权限确认" Height="300" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="true">
    <StackPanel Margin="24">
        <TextBlock Text="⚠️  操作权限确认" FontSize="16" FontWeight="Bold" Foreground="DarkOrange" Margin="0,0,0,16" HorizontalAlignment="Center"/>

        <Border Background="LightGray" Padding="12" Margin="0,0,0,16" CornerRadius="4">
            <StackPanel>
                <TextBlock x:Name="txtOperation" Text="当前操作: TrackOut" FontSize="13"/>
                <TextBlock x:Name="txtLot" Text="批次: LOT20260001" FontSize="13"/>
                <TextBlock x:Name="txtRequiredLevel" Text="所需权限: 操作员确认 (L1)" FontSize="12" Foreground="Gray"/>
            </StackPanel>
        </Border>

        <TextBlock Text="请输入您的账号以确认操作:" FontSize="12" Margin="0,0,0,8"/>

        <TextBlock Text="工号" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="txtEmployeeId" Height="32" Margin="0,0,0,8"/>

        <TextBlock Text="密码" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="txtPassword" Height="32" Margin="0,0,0,8" KeyDown="txtPassword_KeyDown"/>

        <TextBlock x:Name="txtError" Text="" Foreground="Red" FontSize="12" Margin="0,0,0,8" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button Content="确认操作" Width="110" Height="34" Click="btnConfirm_Click" IsDefault="True"/>
            <Button Content="取消" Width="90" Height="34" Margin="16,0,0,0" Click="btnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
