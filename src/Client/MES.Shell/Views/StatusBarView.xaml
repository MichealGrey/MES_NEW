<UserControl x:Class="MES.Shell.Views.StatusBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:prism="http://prismlibrary.com/"
             Background="{StaticResource MesStatusBarBrush}">

    <!--
        【WPF知识点 - 中级】StatusBar 状态栏
        - 使用 Grid 均匀分布4个状态区域
        - DispatcherTimer 定时刷新系统时间
        - IEventAggregator 订阅告警事件，实时更新告警数
        - 使用 Ellipse + DataTrigger 实现连接状态指示灯

        业务说明:
        状态栏是车间操作员的全局信息中心——
        1. 当前登录用户（半导体MES需要操作员身份可追溯）
        2. 系统连接状态（与设备/Redis的连接）
        3. 实时告警数（Critical/Major告警必须立即看到）
        4. 系统时间（工厂时间同步，Track In/Out必须记录精确时间）
    -->

    <Grid Margin="12,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- 1. 当前用户 -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="&#x1F464;" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding CurrentUser}" Foreground="{StaticResource MesTextMutedBrush}" FontSize="12"
                       VerticalAlignment="Center"/>
            <TextBlock Text="(" Foreground="{StaticResource MesTextDimBrush}" FontSize="12" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding CurrentRole}" Foreground="{StaticResource MesTextSecondaryBrush}" FontSize="12"
                       VerticalAlignment="Center"/>
            <TextBlock Text=")" Foreground="{StaticResource MesTextDimBrush}" FontSize="12" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 分隔符 -->
        <TextBlock Grid.Column="1" Text="|" Foreground="{StaticResource MesDividerBrush}" VerticalAlignment="Center"/>

        <!-- 2. 连接状态 — 使用 Ellipse 指示灯 -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="8" Height="8" Margin="0,0,4,0" VerticalAlignment="Center">
                <Ellipse.Style>
                    <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="{StaticResource MesErrorBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                <Setter Property="Fill" Value="{StaticResource MesSuccessBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Ellipse.Style>
            </Ellipse>
            <TextBlock Foreground="{StaticResource MesTextMutedBrush}" FontSize="12" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="连接断开"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                <Setter Property="Text" Value="已连接"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <TextBlock Grid.Column="3" Text="|" Foreground="{StaticResource MesDividerBrush}" VerticalAlignment="Center"/>

        <!-- 3. 告警数 -->
        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="&#x26A0;" FontSize="14" Margin="0,0,4,0" VerticalAlignment="Center"
                       Foreground="{StaticResource MesCriticalBrush}"/>
            <TextBlock Text="{Binding ActiveAlarmCount}" Foreground="{StaticResource MesCriticalBrush}" FontSize="12"
                       FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Grid.Column="5" Text="|" Foreground="{StaticResource MesDividerBrush}" VerticalAlignment="Center"/>

        <!-- 4. 占位 -->
        <TextBlock Grid.Column="6" Text="" />

        <!-- 5. 系统时间 -->
        <TextBlock Grid.Column="7"
                   Text="{Binding SystemTime, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                   Foreground="{StaticResource MesTextDimBrush}" FontSize="12"
                   FontFamily="Consolas"
                   VerticalAlignment="Center"/>
    </Grid>
</UserControl>
