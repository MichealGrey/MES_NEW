<UserControl x:Class="MES.Modules.Alarm.Views.AlarmHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="告警历史" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,16"/>

        <!-- 统计卡片 -->
        <UniformGrid Grid.Row="1" Rows="1" Margin="0,0,0,16">
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="告警总数" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesInfoBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="已关闭" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding ClosedCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesSuccessBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- 搜索栏 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="开始日期:" VerticalAlignment="Center" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,8,0"/>
                <DatePicker Width="150" SelectedDate="{Binding StartDate}" Margin="0,0,16,0" ToolTip="选择开始日期"/>
                <TextBlock Text="结束日期:" VerticalAlignment="Center" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,8,0"/>
                <DatePicker Width="150" SelectedDate="{Binding EndDate}" Margin="0,0,16,0" ToolTip="选择结束日期"/>
                <Button Content="搜索" Command="{Binding SearchCommand}" Margin="0,0,8,0" Style="{DynamicResource MesPrimaryButton}"/>
                <Button Content="刷新" Command="{Binding RefreshCommand}" Style="{DynamicResource MesSecondaryButton}"/>
            </StackPanel>
        </Border>

        <!-- 错误提示 -->
        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesDangerBrush}" FontSize="13" Margin="0,0,0,16" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- 数据表格 -->
        <Border Grid.Row="4" Style="{DynamicResource MesCard}" Padding="0">
            <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" AutoGenerateColumns="False" IsReadOnly="True" Style="{DynamicResource MesDataGrid}" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="告警ID" Binding="{Binding AlarmId}" Width="100"/>
                    <DataGridTextColumn Header="告警码" Binding="{Binding AlarmCode}" Width="80"/>
                    <DataGridTextColumn Header="设备" Binding="{Binding EquipmentId}" Width="100"/>
                    <DataGridTemplateColumn Header="级别" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="6,2" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource MesBadge}">
                                            <Setter Property="Background" Value="{DynamicResource MesInfoBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Severity}" Value="Major">
                                                    <Setter Property="Background" Value="{DynamicResource MesWarningBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                    <Setter Property="Background" Value="{DynamicResource MesDangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Severity}" FontSize="10" FontWeight="Medium" Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="告警内容" Binding="{Binding Text}" Width="*"/>
                    <DataGridTextColumn Header="告警时间" Binding="{Binding AlarmTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="160"/>
                    <DataGridTextColumn Header="确认时间" Binding="{Binding AckTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="160"/>
                    <DataGridTextColumn Header="确认人" Binding="{Binding AckBy}" Width="100"/>
                    <DataGridTextColumn Header="关闭时间" Binding="{Binding CloseTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="160"/>
                    <DataGridTemplateColumn Header="状态" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="6,2" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource MesBadge}">
                                            <Setter Property="Background" Value="{DynamicResource MesSuccessBrush}"/>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Medium" Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
