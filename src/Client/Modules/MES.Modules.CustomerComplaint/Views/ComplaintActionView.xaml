<UserControl x:Class="MES.Modules.CustomerComplaint.Views.ComplaintActionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 客诉选择区域 -->
        <Border Grid.Row="0" Background="{DynamicResource MesCardBackgroundBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="选择客诉单据" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="客诉:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding PendingActions}" 
                              SelectedItem="{Binding SelectedComplaint}" 
                              VerticalContentAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ComplaintNo}" Width="120" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding CustomerName}" Width="100" Margin="8,0,0,0"/>
                                    <TextBlock Text="{Binding DefectType}" Width="80" Margin="8,0,0,0"/>
                                    <TextBlock Text="{Binding EightDStatus}" Width="40" Margin="8,0,0,0" Foreground="Orange"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="2" Content="刷新" Command="{Binding RefreshCommand}" Margin="16,0,8,0" Width="70" Height="28"/>
                    <TextBlock Grid.Column="3" Text="当前步骤:" VerticalAlignment="Center" Margin="16,0,8,0" FontSize="14"/>
                    <TextBlock Grid.Column="4" Text="{Binding SelectedEightDStep}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Foreground="Orange" Margin="0,0,8,0"/>
                    <Border Grid.Column="5" CornerRadius="4" Padding="8,4" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource MesBorderBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedComplaint.Status}" Value="Closed">
                                        <Setter Property="Background" Value="Gray"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Foreground="White" Text="{Binding SelectedComplaint.Status, StringFormat='状态: {0}'}"/>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 8D 步骤导航按钮 -->
        <Border Grid.Row="1" Background="{DynamicResource MesCardBackgroundBrush}" CornerRadius="8" Padding="8" Margin="0,0,0,12">
            <WrapPanel>
                <Button Content="&lt; 上一步" Command="{Binding GoToPreviousStepCommand}" Width="80" Height="28" Margin="0,0,8,0"/>
                <Button Content="下一步 &gt;" Command="{Binding GoToNextStepCommand}" Width="80" Height="28" Margin="0,0,8,0"/>
                <Button Content="推进到下一步" Command="{Binding AdvanceStepCommand}" Width="100" Height="28" Margin="0,0,8,0" Background="Orange" Foreground="White"/>
                <Button Content="保存" Command="{Binding SaveCommand}" Width="70" Height="28" Margin="0,0,8,0"/>
                <Button Content="提交审批" Command="{Binding SubmitForApprovalCommand}" Width="90" Height="28" Margin="0,0,8,0" Background="Green" Foreground="White"/>
            </WrapPanel>
        </Border>

        <!-- 8D步骤Tab内容区 -->
        <Border Grid.Row="2" Background="{DynamicResource MesCardBackgroundBrush}" CornerRadius="8" Padding="16">
            <TabControl SelectedValue="{Binding SelectedEightDStep}" SelectedValuePath="Content">
                <!-- D0: 准备评估 -->
                <TabItem Header="D0: 准备评估">
                    <ScrollViewer>
                        <StackPanel Margin="8">
                            <TextBlock Text="D0 - 准备评估" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <CheckBox Content="需要启动8D流程" IsChecked="{Binding D0AssessmentNeeded}" Margin="0,0,0,12" FontSize="14"/>
                            <TextBlock Text="评估说明:" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding D0AssessmentComment}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Margin="0,0,0,12" Padding="8"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- D1: 成立团队 -->
                <TabItem Header="D1: 成立团队">
                    <ScrollViewer>
                        <StackPanel Margin="8">
                            <TextBlock Text="D1 - 成立8D团队" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="添加成员" Command="{Binding AddTeamMemberCommand}" Width="80" Height="28"/>
                                <Button Content="删除成员" Command="{Binding DeleteTeamMemberCommand}" Margin="8,0,0,0" Width="80" Height="28"/>
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding TeamMembers}" AutoGenerateColumns="False" 
                                      CanUserAddRows="False" IsReadOnly="False" GridLinesVisibility="Horizontal" MaxHeight="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="姓名" Binding="{Binding MemberName}" Width="100"/>
                                    <DataGridTextColumn Header="部门" Binding="{Binding Department}" Width="100"/>
                                    <DataGridTextColumn Header="角色" Binding="{Binding Role}" Width="80"/>
                                    <DataGridTextColumn Header="联系方式" Binding="{Binding ContactInfo}" Width="120"/>
                                    <DataGridTextColumn Header="加入日期" Binding="{Binding JoinDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                                    <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="团队描述:" Margin="0,8,0,4"/>
                            <TextBox Text="{Binding SelectedComplaint.D1TeamDescription}" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,8" Padding="8"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- D2: 问题描述 (5W2H) -->
                <TabItem Header="D2: 问题描述">
                    <ScrollViewer>
                        <StackPanel Margin="8">
                            <TextBlock Text="D2 - 问题描述 (5W2H)" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="What - 什么缺陷:" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding D2WhatDescription}" Margin="0,0,0,12" Padding="8" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                                    <TextBlock Text="Who - 谁发现的:" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding D2WhoDescription}" Margin="0,0,0,12" Padding="8"/>
                                    <TextBlock Text="Where - 在哪里发现:" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding D2WhereDescription}" Margin="0,0,0,12" Padding="8"/>
                                    <TextBlock Text="When - 何时发现:" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding D2WhenDescription}" Margin="0,0,0,12" Padding="8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Why - 为什么是问题:" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding D2WhyDescription}" Margin="0,0,0,12" Padding="8" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                                    <TextBlock Text="How - 如何发现:" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding D2HowDescription}" Margin="0,0,0,12" Padding="8"/>
                                    <TextBlock Text="HowMany - 数量多少:" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding D2HowManyDescription}" Margin="0,0,0,12" Padding="8"/>
                                    <TextBlock Text="缺陷位置:" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding D2DefectLocation}" Margin="0,0,0,12" Padding="8"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- D3: 临时对策 -->
                <TabItem Header="D3: 临时对策">
                    <ScrollViewer>
                        <StackPanel Margin="8">
                            <TextBlock Text="D3 - 临时围堵措施" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="添加措施" Command="{Binding AddContainmentCommand}" Width="80" Height="28"/>
                                <Button Content="删除措施" Command="{Binding DeleteContainmentCommand}" Margin="8,0,0,0" Width="80" Height="28"/>
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding Containments}" AutoGenerateColumns="False" 
                                      CanUserAddRows="False" IsReadOnly="False" GridLinesVisibility="Horizontal" MaxHeight="250">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="措施描述" Binding="{Binding ActionDescription}" Width="*"/>
                                    <DataGridTextColumn Header="影响批次" Binding="{Binding AffectedLot}" Width="100"/>
                                    <DataGridTextColumn Header="影响数量" Binding="{Binding AffectedQty}" Width="80"/>
                                    <DataGridTextColumn Header="围堵数量" Binding="{Binding ContainedQty}" Width="80"/>
                                    <DataGridTextColumn Header="处置方式" Binding="{Binding Disposition}" Width="100"/>
                                    <DataGridTextColumn Header="结果" Binding="{Binding Result}" Width="100"/>
                                    <DataGridTextColumn Header="责任人" Binding="{Binding ResponsiblePerson}" Width="100"/>
                                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="围堵结果:" Margin="0,12,0,4"/>
                            <TextBox Text="{Binding D3ContainmentResult}" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,8" Padding="8" AcceptsReturn="True"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- D4: 根本原因分析 -->
                <TabItem Header="D4: 根因分析">
                    <ScrollViewer>
                        <StackPanel Margin="8">
                            <TextBlock Text="D4 - 根本原因分析" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="添加原因" Command="{Binding AddRootCauseCommand}" Width="80" Height="28"/>
                                <Button Content="删除原因" Command="{Binding DeleteRootCauseCommand}" Margin="8,0,0,0" Width="80" Height="28"/>
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding RootCauses}" AutoGenerateColumns="False" 
                                      CanUserAddRows="False" IsReadOnly="False" GridLinesVisibility="Horizontal" MaxHeight="200">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="原因类型" Binding="{Binding CauseType}" Width="80"/>
                                    <DataGridTextColumn Header="分析方法" Binding="{Binding AnalysisMethod}" Width="100"/>
                                    <DataGridTextColumn Header="原因描述" Binding="{Binding CauseDescription}" Width="*"/>
                                    <DataGridTextColumn Header="责任人" Binding="{Binding ResponsiblePerson}" Width="100"/>
                                    <DataGridTextColumn Header="分析日期" Binding="{Binding AnalysisDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="5Why 分析链:" Margin="0,12,0,4"/>
                            <StackPanel Orientation="Vertical" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Why 1:" Width="60" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding SelectedItem.Why1, ElementName=RootCauseGrid}" Width="500" Padding="4"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Why 2:" Width="60" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding SelectedItem.Why2, ElementName=RootCauseGrid}" Width="500" Padding="4"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Why 3:" Width="60" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding SelectedItem.Why3, ElementName=RootCauseGrid}" Width="500" Padding="4"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Why 4:" Width="60" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding SelectedItem.Why4, ElementName=RootCauseGrid}" Width="500" Padding="4"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Why 5:" Width="60" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding SelectedItem.Why5, ElementName=RootCauseGrid}" Width="500" Padding="4"/>
                                </StackPanel>
                                <TextBlock Text="根因结论:" Margin="0,8,0,4"/>
                                <TextBox Text="{Binding SelectedItem.RootCauseConclusion, ElementName=RootCauseGrid}" TextWrapping="Wrap" MinHeight="60" Padding="8" AcceptsReturn="True"/>
                            </StackPanel>
                            <TextBlock Text="根因总结:" Margin="0,8,0,4"/>
                            <TextBox Text="{Binding D4RootCause}" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,8" Padding="8" AcceptsReturn="True"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- D5: 纠正措施 -->
                <TabItem Header="D5: 纠正措施">
                    <ScrollViewer>
                        <StackPanel Margin="8">
                            <TextBlock Text="D5 - 制定纠正/预防措施" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="添加措施" Command="{Binding AddActionCommand}" Width="80" Height="28"/>
                                <Button Content="删除措施" Command="{Binding DeleteActionCommand}" Margin="8,0,0,0" Width="80" Height="28"/>
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding Actions}" AutoGenerateColumns="False" 
                                      CanUserAddRows="False" IsReadOnly="False" GridLinesVisibility="Horizontal" MaxHeight="250">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="类型" Binding="{Binding ActionType}" Width="80"/>
                                    <DataGridTextColumn Header="措施描述" Binding="{Binding ActionDescription}" Width="*"/>
                                    <DataGridTextColumn Header="责任人" Binding="{Binding ResponsiblePerson}" Width="100"/>
                                    <DataGridTextColumn Header="计划日期" Binding="{Binding PlanDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                                    <DataGridTextColumn Header="实际日期" Binding="{Binding ActualDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                                    <DataGridTextColumn Header="验证方法" Binding="{Binding VerificationMethod}" Width="120"/>
                                    <DataGridTextColumn Header="验证结果" Binding="{Binding VerificationResult}" Width="120"/>
                                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="纠正措施总结:" Margin="0,12,0,4"/>
                            <TextBox Text="{Binding D5CorrectiveAction}" TextWrapping="Wrap" MinHeight="80" Margin="0,0,0,8" Padding="8" AcceptsReturn="True"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- D6: 实施与验证 -->
                <TabItem Header="D6: 实施验证">
                    <ScrollViewer>
                        <StackPanel Margin="8">
                            <TextBlock Text="D6 - 实施纠正措施并验证" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <TextBlock Text="实施结果:" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding D6ImplementationResult}" TextWrapping="Wrap" MinHeight="100" Margin="0,0,0,12" Padding="8" AcceptsReturn="True"/>
                            <TextBlock Text="验证说明:" Margin="0,0,0,4"/>
                            <TextBlock Text="请在上方纠正/预防措施表格中为每条措施填写验证方法和验证结果。" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- D7: 预防措施 -->
                <TabItem Header="D7: 预防措施">
                    <ScrollViewer>
                        <StackPanel Margin="8">
                            <TextBlock Text="D7 - 预防措施与标准化" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <TextBlock Text="预防措施描述:" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding D7PreventionDescription}" TextWrapping="Wrap" MinHeight="80" Margin="0,0,0,12" Padding="8" AcceptsReturn="True"/>
                            <TextBlock Text="水平展开:" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding D7HorizontalExpansion}" TextWrapping="Wrap" MinHeight="80" Margin="0,0,0,12" Padding="8" AcceptsReturn="True"/>
                            <TextBlock Text="文件更新记录:" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="添加记录" Command="{Binding AddDocUpdateCommand}" Width="80" Height="28"/>
                                <Button Content="删除记录" Command="{Binding DeleteDocUpdateCommand}" Margin="8,0,0,0" Width="80" Height="28"/>
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding DocUpdates}" AutoGenerateColumns="False" 
                                      CanUserAddRows="False" IsReadOnly="False" GridLinesVisibility="Horizontal" MaxHeight="200">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="文档类型" Binding="{Binding DocType}" Width="80"/>
                                    <DataGridTextColumn Header="文档名称" Binding="{Binding DocName}" Width="120"/>
                                    <DataGridTextColumn Header="文档编号" Binding="{Binding DocNo}" Width="100"/>
                                    <DataGridTextColumn Header="更新描述" Binding="{Binding UpdateDescription}" Width="*"/>
                                    <DataGridTextColumn Header="责任人" Binding="{Binding ResponsiblePerson}" Width="100"/>
                                    <DataGridTextColumn Header="计划日期" Binding="{Binding PlanDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                                    <DataGridTextColumn Header="实际日期" Binding="{Binding ActualDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- D8: 团队祝贺 -->
                <TabItem Header="D8: 团队祝贺">
                    <ScrollViewer>
                        <StackPanel Margin="8">
                            <TextBlock Text="D8 - 团队祝贺与结案" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <TextBlock Text="结案说明:" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding D8ClosureComment}" TextWrapping="Wrap" MinHeight="80" Margin="0,0,0,12" Padding="8" AcceptsReturn="True"/>
                            <TextBlock Text="团队表彰:" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding D8TeamRecognition}" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,12" Padding="8" AcceptsReturn="True"/>
                            <CheckBox Content="效果确认 - 措施已验证有效" IsChecked="{Binding D8EffectivenessConfirmed}" Margin="0,0,0,12" FontSize="14"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>

        <!-- 错误提示 -->
        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="Red" 
                   HorizontalAlignment="Center" Margin="0,12" FontSize="14"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
    </Grid>
</UserControl>
