<UserControl x:Class="MES.Modules.CustomerComplaint.Views.ComplaintAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <UserControl.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MesCardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="StatNumberStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource MesPrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource MesTextSecondaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style x:Key="StatValueSmallStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource MesPrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatLabelSmallStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource MesTextSecondaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题和日期过滤 -->
            <Border Grid.Row="0" Background="{DynamicResource MesCardBackgroundBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="客诉分析" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="日期范围:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker SelectedDate="{Binding FilterDateFrom}" Width="120" Margin="0,0,8,0" ToolTip="起始日期"/>
                        <TextBlock Text="至" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <DatePicker SelectedDate="{Binding FilterDateTo}" Width="120" Margin="0,0,8,0" ToolTip="结束日期"/>
                        <Button Content="刷新" Command="{Binding RefreshCommand}" Width="70" Height="28"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 统计卡片 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatNumberStyle}" Text="{Binding TotalCount}"/>
                        <TextBlock Style="{StaticResource StatLabelStyle}" Text="总计"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatNumberStyle}" Text="{Binding OpenCount}" Foreground="Blue"/>
                        <TextBlock Style="{StaticResource StatLabelStyle}" Text="开放"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatNumberStyle}" Text="{Binding InProgressCount}" Foreground="Orange"/>
                        <TextBlock Style="{StaticResource StatLabelStyle}" Text="进行中"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatNumberStyle}" Text="{Binding ClosedCount}" Foreground="Green"/>
                        <TextBlock Style="{StaticResource StatLabelStyle}" Text="已关闭"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 第二行统计卡片 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatValueSmallStyle}" Text="{Binding CloseRate, StringFormat={}{0:F1}%}"/>
                        <TextBlock Style="{StaticResource StatLabelSmallStyle}" Text="结案率"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatValueSmallStyle}" Text="{Binding AvgOpenDays, StringFormat={}{0:F1}}"/>
                        <TextBlock Style="{StaticResource StatLabelSmallStyle}" Text="平均开放天数"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatValueSmallStyle}" Text="{Binding TotalDefectTypes}"/>
                        <TextBlock Style="{StaticResource StatLabelSmallStyle}" Text="缺陷类型数"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatValueSmallStyle}" Text="{Binding TopDefectType}"/>
                        <TextBlock Style="{StaticResource StatLabelSmallStyle}" Text="最高频缺陷"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 缺陷类型分布 -->
            <Border Grid.Row="3" Background="{DynamicResource MesCardBackgroundBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="缺陷类型分布" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding DefectTypeDistribution}" AutoGenerateColumns="False" 
                              CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="Horizontal" MaxHeight="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="缺陷类型" Binding="{Binding Label}" Width="*"/>
                            <DataGridTextColumn Header="数量" Binding="{Binding Count}" Width="80"/>
                            <DataGridTextColumn Header="占比" Binding="{Binding Percentage, StringFormat={}{0:F1}%}" Width="80"/>
                            <DataGridTemplateColumn Header="分布" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Rectangle Fill="{DynamicResource MesPrimaryBrush}" Opacity="0.3" Height="16" HorizontalAlignment="Left">
                                                <Rectangle.Width>
                                                    <MultiBinding Converter="{StaticResource PercentageToWidthConverter}">
                                                        <Binding Path="Percentage"/>
                                                        <Binding RelativeSource="{RelativeSource FindAncestor, AncestorType=DataGridCell}" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Rectangle.Width>
                                            </Rectangle>
                                            <TextBlock Text="{Binding Label}" Margin="4,0" VerticalAlignment="Center" FontSize="12"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- 8D步骤分布 -->
            <Border Grid.Row="4" Background="{DynamicResource MesCardBackgroundBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="8D步骤分布" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding EightDStepDistribution}" AutoGenerateColumns="False" 
                              CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="Horizontal" MaxHeight="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="步骤" Binding="{Binding Label}" Width="80"/>
                            <DataGridTextColumn Header="数量" Binding="{Binding Count}" Width="80"/>
                            <DataGridTextColumn Header="占比" Binding="{Binding Percentage, StringFormat={}{0:F1}%}" Width="80"/>
                            <DataGridTemplateColumn Header="分布" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Rectangle Fill="{DynamicResource MesPrimaryBrush}" Opacity="0.3" Height="16" HorizontalAlignment="Left">
                                                <Rectangle.Width>
                                                    <MultiBinding Converter="{StaticResource PercentageToWidthConverter}">
                                                        <Binding Path="Percentage"/>
                                                        <Binding RelativeSource="{RelativeSource FindAncestor, AncestorType=DataGridCell}" Path="ActualWidth"/>
                                                    </MultiBinding>
                                                </Rectangle.Width>
                                            </Rectangle>
                                            <TextBlock Text="{Binding Label}" Margin="4,0" VerticalAlignment="Center" FontSize="12"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- 客诉明细 -->
            <Border Grid.Row="5" Background="{DynamicResource MesCardBackgroundBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="客诉明细" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding Complaints}" AutoGenerateColumns="False" 
                              CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="Horizontal" MaxHeight="400">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="客诉单号" Binding="{Binding ComplaintNo}" Width="120"/>
                            <DataGridTextColumn Header="客户" Binding="{Binding CustomerName}" Width="100"/>
                            <DataGridTextColumn Header="产品" Binding="{Binding ProductName}" Width="100"/>
                            <DataGridTextColumn Header="缺陷类型" Binding="{Binding DefectType}" Width="100"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                            <DataGridTextColumn Header="8D进度" Binding="{Binding EightDStatus}" Width="70"/>
                            <DataGridTextColumn Header="开放天数" Binding="{Binding OpenDays}" Width="70"/>
                            <DataGridTextColumn Header="报告日期" Binding="{Binding ReportDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- 错误提示 -->
            <TextBlock Grid.Row="6" Text="{Binding ErrorMessage}" Foreground="Red" 
                       HorizontalAlignment="Center" Margin="0,8" FontSize="14"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
        </Grid>
    </ScrollViewer>
</UserControl>
