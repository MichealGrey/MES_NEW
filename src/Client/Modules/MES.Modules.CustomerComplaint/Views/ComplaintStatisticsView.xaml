<UserControl x:Class="MES.Modules.CustomerComplaint.Views.ComplaintStatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <ScrollViewer Margin="24" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">

            <!-- 标题栏 -->
            <Grid Margin="0,0,0,20">
                <TextBlock Text="客诉8D - 统计分析" FontSize="24" FontWeight="SemiBold"
                           Foreground="{DynamicResource MesTextPrimaryBrush}" VerticalAlignment="Center"/>
                <Button Content="刷新" Style="{DynamicResource MesPrimaryButton}" Command="{Binding RefreshCommand}"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Padding="20,8"/>
            </Grid>

            <!-- KPI概览 -->
            <TextBlock Text="整体概况" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}"
                       Margin="0,0,0,12"/>
            <WrapPanel Margin="0,0,0,20">
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="客诉总数" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding TotalCount}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="开放中" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding OpenCount}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesInfoBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="进行中" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding InProgressCount}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesWarningBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="已结案" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding ClosedCount}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesSuccessBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="逾期" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding OverdueCount}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDangerBrush}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- 关键指标 -->
            <TextBlock Text="关键指标" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}"
                       Margin="0,0,0,12"/>
            <WrapPanel Margin="0,0,0,20">
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="结案率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding CloseRate, StringFormat={}{0:F1}%}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesSuccessBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="平均开放天数" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding AvgOpenDays, StringFormat={}{0:F1}}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesWarningBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="高严重度" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding HighSeverityCount}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDangerBrush}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- 按状态分布 -->
            <TextBlock Text="按状态分布" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}"
                       Margin="0,20,0,12"/>
            <Border Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <!-- 开放 -->
                    <StackPanel Margin="0,0,0,8">
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="开放" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MesInfoBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding OpenPercent, StringFormat={}{0:F1}%}" FontSize="13"
                                       Foreground="{DynamicResource MesTextPrimaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Background="{DynamicResource MesInfoBrush}" CornerRadius="4" Height="16" HorizontalAlignment="Left"
                                Width="{Binding OpenBarWidth}" Margin="100,0,0,0"/>
                    </StackPanel>

                    <!-- 进行中 -->
                    <StackPanel Margin="0,0,0,8">
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="进行中" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MesWarningBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding InProgressPercent, StringFormat={}{0:F1}%}" FontSize="13"
                                       Foreground="{DynamicResource MesTextPrimaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Background="{DynamicResource MesWarningBrush}" CornerRadius="4" Height="16" HorizontalAlignment="Left"
                                Width="{Binding InProgressBarWidth}" Margin="100,0,0,0"/>
                    </StackPanel>

                    <!-- 已关闭 -->
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="已结案" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MesSuccessBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding ClosedPercent, StringFormat={}{0:F1}%}" FontSize="13"
                                       Foreground="{DynamicResource MesTextPrimaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <Border Background="{DynamicResource MesSuccessBrush}" CornerRadius="4" Height="16" HorizontalAlignment="Left"
                                Width="{Binding ClosedBarWidth}" Margin="100,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 按严重度统计 -->
            <TextBlock Text="按严重度统计" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}"
                       Margin="0,20,0,12"/>
            <WrapPanel Margin="0,0,0,16">
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="严重(Critical)" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding CriticalCount}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDangerBrush}"/>
                        <TextBlock Text="{Binding CriticalPercent, StringFormat={}{0:F1}%}" FontSize="12"
                                   Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="高(High)" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding HighCount}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesWarningBrush}"/>
                        <TextBlock Text="{Binding HighPercent, StringFormat={}{0:F1}%}" FontSize="12"
                                   Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="中(Medium)" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding MediumCount}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesInfoBrush}"/>
                        <TextBlock Text="{Binding MediumPercent, StringFormat={}{0:F1}%}" FontSize="12"
                                   Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="低(Low)" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding LowCount}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding LowPercent, StringFormat={}{0:F1}%}" FontSize="12"
                                   Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- 按缺陷类型统计 -->
            <TextBlock Text="按缺陷类型统计 TOP 10" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}"
                       Margin="0,20,0,12"/>
            <DataGrid Style="{DynamicResource MesDataGrid}"
                      ItemsSource="{Binding DefectTypeStats}"
                      AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="250"
                      CanUserAddRows="False" CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="缺陷类型" Binding="{Binding DefectType}" Width="200"/>
                    <DataGridTextColumn Header="数量" Binding="{Binding Count}" Width="100"/>
                    <DataGridTextColumn Header="占比" Binding="{Binding Percentage, StringFormat={}{0:F1}%}" Width="100"/>
                    <DataGridTextColumn Header="涉及客户" Binding="{Binding AffectedCustomers}" Width="150"/>
                    <DataGridTextColumn Header="涉及产品" Binding="{Binding AffectedProducts}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 客诉明细列表 -->
            <TextBlock Text="客诉明细" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}"
                       Margin="0,20,0,12"/>
            <DataGrid Style="{DynamicResource MesDataGrid}"
                      ItemsSource="{Binding Complaints}"
                      AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="400"
                      CanUserAddRows="False" CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="客诉单号" Binding="{Binding ComplaintNo}" Width="130"/>
                    <DataGridTextColumn Header="客户" Binding="{Binding CustomerName}" Width="120"/>
                    <DataGridTextColumn Header="产品" Binding="{Binding ProductName}" Width="120"/>
                    <DataGridTextColumn Header="缺陷类型" Binding="{Binding DefectType}" Width="100"/>
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                    <DataGridTextColumn Header="严重度" Binding="{Binding Severity}" Width="70"/>
                    <DataGridTextColumn Header="8D进度" Binding="{Binding EightDStatus}" Width="70"/>
                    <DataGridTextColumn Header="影响数量" Binding="{Binding AffectedQty}" Width="80"/>
                    <DataGridTextColumn Header="退货数" Binding="{Binding ReturnQty}" Width="70"/>
                    <DataGridTextColumn Header="开放天数" Binding="{Binding OpenDays}" Width="80"/>
                    <DataGridTextColumn Header="报告日期" Binding="{Binding ReportDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                    <DataGridTextColumn Header="责任人" Binding="{Binding AssignedTo}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
