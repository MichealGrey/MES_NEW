<UserControl x:Class="MES.Modules.EngineeringChange.Views.ECNListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <UserControl.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MesCardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="StatNumberStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource MesPrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource MesTextSecondaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style x:Key="StatValueSmallStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource MesPrimaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatLabelSmallStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource MesTextSecondaryBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 统计卡片 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource StatNumberStyle}" Text="{Binding TotalCount}"/>
                    <TextBlock Style="{StaticResource StatLabelStyle}" Text="总计"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource StatNumberStyle}" Text="{Binding DraftCount}" Foreground="Gray"/>
                    <TextBlock Style="{StaticResource StatLabelStyle}" Text="草稿"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource StatNumberStyle}" Text="{Binding InReviewCount}" Foreground="Blue"/>
                    <TextBlock Style="{StaticResource StatLabelStyle}" Text="评审中"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource StatNumberStyle}" Text="{Binding ApprovedCount}" Foreground="Green"/>
                    <TextBlock Style="{StaticResource StatLabelStyle}" Text="已批准"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource StatNumberStyle}" Text="{Binding RejectedCount}" Foreground="Red"/>
                    <TextBlock Style="{StaticResource StatLabelStyle}" Text="已拒绝"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 工具栏 -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <!-- 搜索框 -->
            <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Padding="8" VerticalContentAlignment="Center" ToolTip="搜索单号/标题/申请人/产品">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Background" Value="{DynamicResource MesCardBackgroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource MesBorderBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource MesTextPrimaryBrush}"/>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <!-- 状态过滤 -->
            <ComboBox Grid.Column="1" Text="{Binding FilterStatus, UpdateSourceTrigger=PropertyChanged}" Margin="8,0,0,0" VerticalContentAlignment="Center" ToolTip="状态过滤">
                <ComboBox.ItemsSource>
                    <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                        <sys:String>Draft</sys:String>
                        <sys:String>Review</sys:String>
                        <sys:String>Approval</sys:String>
                        <sys:String>Implement</sys:String>
                        <sys:String>Verify</sys:String>
                        <sys:String>Close</sys:String>
                        <sys:String>Rejected</sys:String>
                    </x:Array>
                </ComboBox.ItemsSource>
            </ComboBox>
            <!-- 类型过滤 -->
            <ComboBox Grid.Column="2" Text="{Binding FilterType, UpdateSourceTrigger=PropertyChanged}" Margin="8,0,0,0" VerticalContentAlignment="Center" ToolTip="变更类型过滤">
                <ComboBox.ItemsSource>
                    <x:Array Type="sys:String" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                        <sys:String>设计变更</sys:String>
                        <sys:String>工艺变更</sys:String>
                        <sys:String>材料变更</sys:String>
                        <sys:String>规格变更</sys:String>
                        <sys:String>BOM变更</sys:String>
                    </x:Array>
                </ComboBox.ItemsSource>
            </ComboBox>
            <!-- 操作按钮 -->
            <Button Grid.Column="5" Content="新建" Command="{Binding AddCommand}" Margin="8,0,4,0" Width="70"/>
            <Button Grid.Column="6" Content="刷新" Command="{Binding RefreshCommand}" Margin="0,0,4,0" Width="70"/>
            <Button Grid.Column="7" Content="清除" Command="{Binding ClearFilterCommand}" Width="70"/>
        </Grid>

        <!-- 数据表格 -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding ECNs}" SelectedItem="{Binding SelectedECN}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True" GridLinesVisibility="Horizontal" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ECN单号" Binding="{Binding EcnNo}" Width="130"/>
                <DataGridTextColumn Header="标题" Binding="{Binding EcnTitle}" Width="180"/>
                <DataGridTextColumn Header="类型" Binding="{Binding EcnType}" Width="90"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                <DataGridTextColumn Header="紧急度" Binding="{Binding Urgency}" Width="70"/>
                <DataGridTextColumn Header="风险等级" Binding="{Binding RiskLevel}" Width="80"/>
                <DataGridTextColumn Header="申请人" Binding="{Binding RequestedBy}" Width="80"/>
                <DataGridTextColumn Header="申请日期" Binding="{Binding RequestedAt, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="生效日期" Binding="{Binding EffectiveDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTemplateColumn Header="操作" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="详情" Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}" Margin="2" Padding="6,2"/>
                                <Button Content="提交" Command="{Binding DataContext.SubmitCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}" Margin="2" Padding="6,2"/>
                                <Button Content="批准" Command="{Binding DataContext.ApproveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}" Margin="2" Padding="6,2"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 错误提示 -->
        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="Red" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                   FontSize="16" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                   TextWrapping="Wrap"/>
    </Grid>
</UserControl>
