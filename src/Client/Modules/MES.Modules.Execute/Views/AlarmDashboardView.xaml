<UserControl x:Class="MES.Modules.Execute.Views.AlarmDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 统计卡片 -->
            <RowDefinition Height="Auto"/>   <!-- 过滤栏 -->
            <RowDefinition Height="Auto"/>   <!-- 错误提示 -->
            <RowDefinition Height="Auto"/>   <!-- 操作按钮 -->
            <RowDefinition Height="*"/>      <!-- 报警列表 -->
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="报警看板"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource MesTextPrimaryBrush}"
                   Margin="0,0,0,16"/>

        <!-- 统计卡片 -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="活跃" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding ActiveCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesDangerBrush}"/>
                    <TextBlock Text="条报警" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="已确认" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding AcknowledgedCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesWarningBrush}"/>
                    <TextBlock Text="条报警" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="已清除" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding ClearedCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesSuccessBrush}"/>
                    <TextBlock Text="条报警" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="严重" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CriticalCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesDangerBrush}"/>
                    <TextBlock Text="Critical" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="警告" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding WarningCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesWarningBrush}"/>
                    <TextBlock Text="Warning" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- 过滤栏 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="级别过滤:"
                           FontSize="13"
                           Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1"
                          Width="140"
                          Style="{DynamicResource MesComboBox}"
                          SelectedValue="{Binding FilterSeverity}"
                          SelectedValuePath="Content">
                    <ComboBoxItem Content="" ContentStringFormat="全部级别"/>
                    <ComboBoxItem Content="Critical"/>
                    <ComboBoxItem Content="Warning"/>
                </ComboBox>

                <Button Grid.Column="3"
                        Content="刷新"
                        Command="{Binding RefreshCommand}"
                        Style="{DynamicResource MesPrimaryButton}"/>
            </Grid>
        </Border>

        <!-- 错误提示 -->
        <TextBlock Grid.Row="3"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource MesDangerBrush}"
                   FontSize="13"
                   Margin="0,0,0,16"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- 操作按钮 -->
        <Border Grid.Row="4" Background="Transparent" Padding="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <Button Content="确认"
                        Command="{Binding AcknowledgeCommand}"
                        Style="{DynamicResource MesPrimaryButton}"
                        Margin="0,0,12,0"
                        ToolTip="选中报警并确认"/>
                <Button Content="清除"
                        Command="{Binding ClearCommand}"
                        Style="{DynamicResource MesPrimaryButton}"
                        ToolTip="选中报警并清除"/>
            </StackPanel>
        </Border>

        <!-- 报警列表 -->
        <Border Grid.Row="5" Style="{DynamicResource MesCard}" Padding="0">
            <DataGrid ItemsSource="{Binding Alarms}"
                      SelectedItem="{Binding SelectedAlarm}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Style="{DynamicResource MesDataGrid}"
                      FontSize="12"
                      SelectionMode="Single"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="报警ID" Binding="{Binding AlarmId}" Width="120"/>
                    <DataGridTemplateColumn Header="级别" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="6,2" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource MesBadge}">
                                            <Setter Property="Background" Value="{DynamicResource MesWarningBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource MesWarningBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                    <Setter Property="Background" Value="{DynamicResource MesDangerBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource MesDangerBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                    <Setter Property="Background" Value="{DynamicResource MesWarningBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource MesWarningBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Severity}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="报警类型" Binding="{Binding AlarmType}" Width="120"/>
                    <DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="*"/>
                    <DataGridTextColumn Header="设备号" Binding="{Binding EquipmentId}" Width="120"/>
                    <DataGridTextColumn Header="触发时间" Binding="{Binding RaisedAt}" Width="160"/>
                    <DataGridTextColumn Header="确认时间" Binding="{Binding AcknowledgedAt}" Width="160"/>
                    <DataGridTextColumn Header="清除时间" Binding="{Binding ClearedAt}" Width="160"/>
                    <DataGridTextColumn Header="确认人" Binding="{Binding AcknowledgedBy}" Width="100"/>
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                    <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="150"/>
                    <DataGridTemplateColumn Header="操作" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="确认"
                                            Command="{Binding DataContext.AcknowledgeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Padding="4,2"
                                            FontSize="11"
                                            Margin="0,0,4,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MesPrimaryButton}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Active">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Acknowledged">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cleared">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="清除"
                                            Command="{Binding DataContext.ClearCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Padding="4,2"
                                            FontSize="11">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MesPrimaryButton}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Active">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Acknowledged">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
