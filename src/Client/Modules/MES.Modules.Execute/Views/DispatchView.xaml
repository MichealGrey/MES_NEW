<UserControl x:Class="MES.Modules.Execute.Views.DispatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 统计卡片 -->
            <RowDefinition Height="Auto"/>   <!-- 过滤栏 -->
            <RowDefinition Height="Auto"/>   <!-- 错误提示 -->
            <RowDefinition Height="Auto"/>   <!-- 操作按钮 -->
            <RowDefinition Height="*"/>      <!-- 数据表格 -->
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="派工管理"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource MesTextPrimaryBrush}"
                   Margin="0,0,0,16"/>

        <!-- 统计卡片 -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="待处理" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding PendingCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesWarningBrush}"/>
                    <TextBlock Text="条派工" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="进行中" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding InProgressCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesInfoBrush}"/>
                    <TextBlock Text="条派工" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="已完成" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CompletedCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesSuccessBrush}"/>
                    <TextBlock Text="条派工" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- 过滤栏 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="状态过滤:"
                           FontSize="13"
                           Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1"
                          Width="140"
                          Style="{DynamicResource MesComboBox}"
                          SelectedValue="{Binding FilterStatus}"
                          SelectedValuePath="Content">
                    <ComboBoxItem Content="" ContentStringFormat="全部状态"/>
                    <ComboBoxItem Content="Pending" ContentStringFormat="待处理"/>
                    <ComboBoxItem Content="InProgress" ContentStringFormat="进行中"/>
                    <ComboBoxItem Content="Completed" ContentStringFormat="已完成"/>
                </ComboBox>

                <Button Grid.Column="3"
                        Content="刷新"
                        Command="{Binding RefreshCommand}"
                        Style="{DynamicResource MesPrimaryButton}"/>
            </Grid>
        </Border>

        <!-- 错误提示 -->
        <TextBlock Grid.Row="3"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource MesDangerBrush}"
                   FontSize="13"
                   Margin="0,0,0,16"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- 操作按钮 -->
        <Border Grid.Row="4" Background="Transparent" Padding="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <Button Content="开始"
                        Command="{Binding StartCommand}"
                        Style="{DynamicResource MesPrimaryButton}"
                        Margin="0,0,12,0"
                        ToolTip="选中待处理派工并启动"/>
                <Button Content="完成"
                        Command="{Binding CompleteCommand}"
                        Style="{DynamicResource MesPrimaryButton}"
                        ToolTip="选中进行中派工并标记完成"/>
            </StackPanel>
        </Border>

        <!-- 派工列表 -->
        <Border Grid.Row="5" Style="{DynamicResource MesCard}" Padding="0">
            <DataGrid ItemsSource="{Binding Dispatches}"
                      SelectedItem="{Binding SelectedDispatch}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Style="{DynamicResource MesDataGrid}"
                      FontSize="12"
                      SelectionMode="Single"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="派工ID" Binding="{Binding DispatchId}" Width="140"/>
                    <DataGridTextColumn Header="批次号" Binding="{Binding LotId}" Width="120"/>
                    <DataGridTextColumn Header="工序编码" Binding="{Binding StepCode}" Width="100"/>
                    <DataGridTextColumn Header="设备号" Binding="{Binding EquipmentId}" Width="120"/>
                    <DataGridTextColumn Header="数量" Binding="{Binding Qty}" Width="80"/>
                    <DataGridTextColumn Header="优先级" Binding="{Binding Priority}" Width="80"/>
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                    <DataGridTextColumn Header="操作人" Binding="{Binding Operator}" Width="100"/>
                    <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt}" Width="160"/>
                    <DataGridTextColumn Header="开始时间" Binding="{Binding StartedAt}" Width="160"/>
                    <DataGridTextColumn Header="完成时间" Binding="{Binding CompletedAt}" Width="160"/>
                    <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="*"/>
                    <DataGridTemplateColumn Header="操作" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="开始"
                                            Command="{Binding DataContext.StartCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Padding="4,2"
                                            FontSize="11"
                                            Margin="0,0,4,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MesPrimaryButton}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="完成"
                                            Command="{Binding DataContext.CompleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Padding="4,2"
                                            FontSize="11">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource MesPrimaryButton}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
