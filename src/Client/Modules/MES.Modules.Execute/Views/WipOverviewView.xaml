<UserControl x:Class="MES.Modules.Execute.Views.WipOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 统计卡片 -->
            <RowDefinition Height="Auto"/>   <!-- 工具栏 -->
            <RowDefinition Height="Auto"/>   <!-- 错误提示 -->
            <RowDefinition Height="*"/>      <!-- 数据表格 -->
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="WIP 在制品概览"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource MesTextPrimaryBrush}"
                   Margin="0,0,0,16"/>

        <!-- 统计卡片 -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="总在制品" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding TotalWip}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                    <TextBlock Text="批次" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Frontend" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding FrontendWip}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesInfoBrush}"/>
                    <TextBlock Text="批次" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Backend" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding BackendWip}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesSuccessBrush}"/>
                    <TextBlock Text="批次" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="平均耗时" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding AvgCycleTime, StringFormat={}{0:F1}}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesWarningBrush}"/>
                    <TextBlock Text="分钟" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- 工具栏 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding WipList.Count, StringFormat=共 {0} 条在制品记录}"
                           FontSize="13"
                           Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="2"
                        Content="刷新"
                        Command="{Binding RefreshCommand}"
                        Style="{DynamicResource MesPrimaryButton}"/>
            </Grid>
        </Border>

        <!-- 错误提示 -->
        <TextBlock Grid.Row="3"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource MesDangerBrush}"
                   FontSize="13"
                   Margin="0,0,0,16"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- 在制品列表 -->
        <Border Grid.Row="4" Style="{DynamicResource MesCard}" Padding="0">
            <DataGrid ItemsSource="{Binding WipList}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Style="{DynamicResource MesDataGrid}"
                      FontSize="12"
                      SelectionMode="Single"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="批次号" Binding="{Binding LotId}" Width="140"/>
                    <DataGridTextColumn Header="产品型号" Binding="{Binding ProductId}" Width="120"/>
                    <DataGridTextColumn Header="产品名称" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="当前工序" Binding="{Binding CurrentStep}" Width="120"/>
                    <DataGridTextColumn Header="当前设备" Binding="{Binding CurrentEquipment}" Width="120"/>
                    <DataGridTextColumn Header="工艺阶段" Binding="{Binding ProcessStage}" Width="100"/>
                    <DataGridTextColumn Header="数量" Binding="{Binding Qty}" Width="80"/>
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                    <DataGridTextColumn Header="进站时间" Binding="{Binding TrackInTime}" Width="160"/>
                    <DataGridTextColumn Header="已耗时(分)" Binding="{Binding ElapsedMinutes, StringFormat={}{0:F1}}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
