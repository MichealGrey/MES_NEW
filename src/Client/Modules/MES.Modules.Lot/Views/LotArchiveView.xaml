<UserControl x:Class="MES.Modules.Lot.Views.LotArchiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <UserControl.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MesCardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 统计卡片 -->
            <RowDefinition Height="Auto"/>   <!-- 搜索栏 -->
            <RowDefinition Height="*"/>      <!-- 数据表格 -->
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="批次归档" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource MesTextPrimaryBrush}"
                       DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <Button Content="刷新" Command="{Binding RefreshCommand}"
                    Style="{DynamicResource MesPrimaryButton}"
                    HorizontalAlignment="Right" Width="80"/>
        </DockPanel>

        <!-- 统计卡片 -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding ArchivedCount}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource MesSuccessBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="归档总数" FontSize="12"
                               Foreground="{DynamicResource MesTextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- 搜索栏 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="搜索:" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource MesTextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Width="300" FontSize="14" Padding="8,4" Margin="0,0,12,0"
                         Style="{DynamicResource MesTextBox}"
                         ToolTip="搜索批次号/产品/工单号"/>
            </StackPanel>
        </Border>

        <!-- 数据表格 -->
        <Border Grid.Row="3" Style="{DynamicResource MesCard}" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding ArchivedLots}" SelectedItem="{Binding SelectedLot}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Style="{DynamicResource MesDataGrid}"
                          FontSize="13"
                          SelectionMode="Single" SelectionUnit="FullRow">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding ViewDetailCommand}"
                                      CommandParameter="{Binding SelectedLot}"/>
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="批次号" Binding="{Binding LotId}" Width="140"/>
                        <DataGridTextColumn Header="工单号" Binding="{Binding OrderId}" Width="120"/>
                        <DataGridTextColumn Header="产品" Binding="{Binding ProductName}" Width="120"/>
                        <DataGridTextColumn Header="管芯" Binding="{Binding DieName}" Width="100"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90"/>
                        <DataGridTextColumn Header="工艺阶段" Binding="{Binding ProcessStage}" Width="80"/>
                        <DataGridTextColumn Header="颗数" Binding="{Binding UnitCount}" Width="70"/>
                        <DataGridTextColumn Header="Strip数" Binding="{Binding StripCount}" Width="70"/>
                        <DataGridTextColumn Header="当前工序" Binding="{Binding CurrentStep}" Width="110"/>
                        <DataGridTextColumn Header="合格数" Binding="{Binding QtyPass}" Width="70"/>
                        <DataGridTextColumn Header="不良数" Binding="{Binding QtyFail}" Width="70"/>
                        <DataGridTextColumn Header="测试结果" Binding="{Binding TestResult, TargetNullValue='—'}" Width="80"/>
                        <DataGridTextColumn Header="归档时间" Binding="{Binding UpdatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="130"/>
                        <DataGridTextColumn Header="备注" Binding="{Binding Remark, TargetNullValue='—'}" Width="*"/>

                        <!-- 查看详情按钮 -->
                        <DataGridTemplateColumn Header="操作" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="查看详情"
                                            Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{DynamicResource MesPrimaryButton}"
                                            Width="70" Height="24" FontSize="11"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 错误提示 -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource MesDangerBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
