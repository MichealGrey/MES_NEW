<UserControl x:Class="MES.Modules.Lot.Views.LotDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <UserControl.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MesCardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 搜索栏 -->
            <RowDefinition Height="Auto"/>   <!-- 详情面板 -->
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="批次详情" FontSize="24" FontWeight="SemiBold"
                   Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,16"/>

        <!-- 搜索栏 -->
        <Border Grid.Row="1" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="批次号:" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource MesTextPrimaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Text="{Binding LotId, UpdateSourceTrigger=PropertyChanged}"
                         Width="250" FontSize="14" Padding="8,4" Margin="0,0,12,0"
                         Style="{DynamicResource MesTextBox}"
                         ToolTip="输入批次号进行查询"/>
                <Button Content="搜索" Command="{Binding SearchCommand}"
                        Style="{DynamicResource MesPrimaryButton}"
                        Width="80" Height="32" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- 详情面板 -->
        <Border Grid.Row="2" Padding="24" Margin="0,0,0,16">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource MesCard}">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Lot}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel>
                <!-- 头部信息 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="{Binding Lot.LotId}" FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesPrimaryBrush}" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding Lot.Status}" FontSize="16" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource MesInfoBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Lot.Status}" Value="Hold">
                                        <Setter Property="Foreground" Value="{DynamicResource MesDangerBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Lot.Status}" Value="Completed">
                                        <Setter Property="Foreground" Value="{DynamicResource MesSuccessBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Lot.Status}" Value="InProgress">
                                        <Setter Property="Foreground" Value="{DynamicResource MesWarningBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding Lot.ProcessStage}" FontSize="14"
                               Foreground="{DynamicResource MesTextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 基本信息 -->
                <TextBlock Text="基本信息" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,16,12">
                        <TextBlock Text="工单号" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Lot.OrderId}" FontSize="13" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,16,12">
                        <TextBlock Text="产品" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Lot.ProductName}" FontSize="13" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,16,12">
                        <TextBlock Text="管芯" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Lot.DieName}" FontSize="13" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,16,12">
                        <TextBlock Text="当前工序" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Lot.CurrentStep}" FontSize="13" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="优先级" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Lot.Priority}" FontSize="13" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Text="创建时间" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Lot.CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" FontSize="13" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,16,0">
                        <TextBlock Text="更新时间" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Lot.UpdatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" FontSize="13" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,16,0">
                        <TextBlock Text="备注" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Lot.Remark, TargetNullValue='—'}" FontSize="13" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- 数量信息 -->
                <TextBlock Text="数量信息" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="颗数" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Lot.UnitCount}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="Strip数" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Lot.StripCount}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesInfoBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                        <TextBlock Text="合格数" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Lot.QtyPass}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesSuccessBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,8,0">
                        <TextBlock Text="不良数" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Lot.QtyFail}" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDangerBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Margin="0,0,8,0">
                        <TextBlock Text="测试结果" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Lot.TestResult, TargetNullValue='—'}" FontSize="14" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- 批次标识 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Padding="12,4" Margin="0,0,8,0" CornerRadius="4"
                            Background="{DynamicResource MesCardBackgroundBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="部分批" FontSize="12" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Lot.IsPartialLot, StringFormat={}{0}}" FontSize="12"
                                       FontWeight="SemiBold" Foreground="{DynamicResource MesInfoBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Padding="12,4" Margin="0,0,8,0" CornerRadius="4"
                            Background="{DynamicResource MesCardBackgroundBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="返工批" FontSize="12" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Lot.IsReworkLot, StringFormat={}{0}}" FontSize="12"
                                       FontWeight="SemiBold" Foreground="{DynamicResource MesWarningBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Padding="12,4" Margin="0,0,0,0" CornerRadius="4"
                            Background="{DynamicResource MesCardBackgroundBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="已归档" FontSize="12" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Lot.IsArchived, StringFormat={}{0}}" FontSize="12"
                                       FontWeight="SemiBold" Foreground="{DynamicResource MesSuccessBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Hold原因（当状态为Hold时显示） -->
                <StackPanel Margin="0,0,0,16">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Lot.Status}" Value="Hold">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Padding="16" CornerRadius="8" BorderBrush="{DynamicResource MesDangerBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Hold信息" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesDangerBrush}" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                    <TextBlock Text="Hold原因" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                                    <TextBlock Text="{Binding Lot.HoldReason, TargetNullValue='—'}" FontSize="13"
                                               Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,2,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Hold分类" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                                    <TextBlock Text="{Binding Lot.HoldCategory, TargetNullValue='—'}" FontSize="13"
                                               Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 操作按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hold" Command="{Binding HoldCommand}" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MesWarningButton}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Lot.Status}" Value="Hold">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Release" Command="{Binding ReleaseCommand}" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MesSuccessButton}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Lot.Status}" Value="Hold">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Archive" Command="{Binding ArchiveCommand}" Margin="0,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MesPrimaryButton}"/>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 错误提示 -->
        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource MesDangerBrush}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="16"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                   TextWrapping="Wrap"
                   TextAlignment="Center"/>
    </Grid>
</UserControl>
