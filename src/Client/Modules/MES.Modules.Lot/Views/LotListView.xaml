<UserControl x:Class="MES.Modules.Lot.Views.LotListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <UserControl.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MesCardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 统计卡片 -->
            <RowDefinition Height="Auto"/>   <!-- 工具栏 -->
            <RowDefinition Height="*"/>      <!-- 数据表格 -->
            <RowDefinition Height="Auto"/>   <!-- 分页栏 -->
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="批次列表" FontSize="24" FontWeight="SemiBold"
                   Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,16"/>

        <!-- 统计卡片 -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding TotalCount}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource MesPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="总批次" FontSize="12"
                               Foreground="{DynamicResource MesTextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding CreatedCount}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource MesInfoBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="已创建" FontSize="12"
                               Foreground="{DynamicResource MesTextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding InProgressCount}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource MesSuccessBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="进行中" FontSize="12"
                               Foreground="{DynamicResource MesTextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding CompletedCount}" FontSize="28" FontWeight="Bold"
                               Foreground="Blue" HorizontalAlignment="Center"/>
                    <TextBlock Text="已完成" FontSize="12"
                               Foreground="{DynamicResource MesTextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding HoldCount}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource MesDangerBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Hold" FontSize="12"
                               Foreground="{DynamicResource MesTextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- 工具栏 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 搜索框 -->
                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" Padding="8,4" Margin="0,0,16,0"
                         Style="{DynamicResource MesTextBox}"
                         ToolTip="搜索批次号/产品/工单号/管芯"/>

                <!-- 状态过滤 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="状态:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Width="120" FontSize="13" Style="{DynamicResource MesComboBox}"
                              SelectedValue="{Binding FilterStatus}" SelectedValuePath="Content">
                        <ComboBoxItem Content=""/>
                        <ComboBoxItem Content="Created"/>
                        <ComboBoxItem Content="InProgress"/>
                        <ComboBoxItem Content="Hold"/>
                        <ComboBoxItem Content="Completed"/>
                        <ComboBoxItem Content="Closed"/>
                    </ComboBox>
                </StackPanel>

                <!-- 工艺阶段过滤 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="阶段:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Width="120" FontSize="13" Style="{DynamicResource MesComboBox}"
                              SelectedValue="{Binding FilterStage}" SelectedValuePath="Content">
                        <ComboBoxItem Content=""/>
                        <ComboBoxItem Content="Frontend"/>
                        <ComboBoxItem Content="Backend"/>
                    </ComboBox>
                </StackPanel>

                <!-- 刷新按钮 -->
                <Button Grid.Column="3" Content="刷新" Command="{Binding RefreshCommand}"
                        Style="{DynamicResource MesPrimaryButton}" Margin="0,0,8,0"/>

                <!-- 清除过滤 -->
                <Button Grid.Column="4" Content="清除" Command="{Binding ClearFilterCommand}"
                        Style="{DynamicResource MesSecondaryButton}"/>
            </Grid>
        </Border>

        <!-- 数据表格 -->
        <Border Grid.Row="3" Style="{DynamicResource MesCard}" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding PagedLots}" SelectedItem="{Binding SelectedLot}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Style="{DynamicResource MesDataGrid}"
                          FontSize="13"
                          SelectionMode="Single" SelectionUnit="FullRow">
                    <DataGrid.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding ViewDetailCommand}"
                                      CommandParameter="{Binding SelectedLot}"/>
                    </DataGrid.InputBindings>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="批次号" Binding="{Binding LotId}" Width="140"/>
                        <DataGridTextColumn Header="工单号" Binding="{Binding OrderId}" Width="120"/>
                        <DataGridTextColumn Header="产品" Binding="{Binding ProductName}" Width="120"/>
                        <DataGridTextColumn Header="管芯" Binding="{Binding DieName}" Width="100"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90"/>
                        <DataGridTextColumn Header="工艺阶段" Binding="{Binding ProcessStage}" Width="80"/>
                        <DataGridTextColumn Header="颗数" Binding="{Binding UnitCount}" Width="70"/>
                        <DataGridTextColumn Header="Strip数" Binding="{Binding StripCount}" Width="70"/>
                        <DataGridTextColumn Header="当前工序" Binding="{Binding CurrentStep}" Width="110"/>
                        <DataGridTextColumn Header="优先级" Binding="{Binding Priority}" Width="70"/>
                        <DataGridTextColumn Header="部分批" Binding="{Binding IsPartialLot}" Width="60"/>
                        <DataGridTextColumn Header="返工批" Binding="{Binding IsReworkLot}" Width="60"/>
                        <DataGridTextColumn Header="测试良率" Binding="{Binding QtyPass, StringFormat={}{0}}" Width="70"/>
                        <DataGridTextColumn Header="测试不良" Binding="{Binding QtyFail, StringFormat={}{0}}" Width="70"/>
                        <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="130"/>
                        <DataGridTextColumn Header="备注" Binding="{Binding Remark, TargetNullValue='—'}" Width="*"/>

                        <!-- 操作列 -->
                        <DataGridTemplateColumn Header="操作" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4,0">
                                        <Button Content="Hold"
                                                Command="{Binding DataContext.HoldCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{DynamicResource MesWarningButton}"
                                                Width="50" Height="24" Margin="0,0,4,0" FontSize="11"/>
                                        <Button Content="Release"
                                                Command="{Binding DataContext.ReleaseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{DynamicResource MesSuccessButton}"
                                                Width="55" Height="24" Margin="0,0,4,0" FontSize="11"/>
                                        <Button Content="Archive"
                                                Command="{Binding DataContext.ArchiveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{DynamicResource MesPrimaryButton}"
                                                Width="55" Height="24" Margin="0,0,4,0" FontSize="11"/>
                                        <Button Content="详情"
                                                Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{DynamicResource MesSecondaryButton}"
                                                Width="50" Height="24" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 错误提示 -->
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource MesDangerBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 分页栏 -->
        <Border Grid.Row="4" Style="{DynamicResource MesCard}" Padding="12,8" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 每页条数 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="每页" Foreground="{DynamicResource MesTextSecondaryBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="60" Height="26" SelectedItem="{Binding PageSize}">
                        <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">10</sys:Int32>
                        <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">20</sys:Int32>
                        <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">50</sys:Int32>
                        <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">100</sys:Int32>
                    </ComboBox>
                    <TextBlock Text="条" Foreground="{DynamicResource MesTextSecondaryBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- 分页信息 -->
                <TextBlock Grid.Column="1" Text="{Binding PageInfo}"
                           Foreground="{DynamicResource MesTextSecondaryBrush}" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- 分页按钮 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="首页" Command="{Binding FirstPageCommand}"
                            Style="{DynamicResource MesSecondaryButton}" Width="50" Height="26" Margin="0,0,4,0"/>
                    <Button Content="上一页" Command="{Binding PreviousPageCommand}"
                            Style="{DynamicResource MesSecondaryButton}" Width="55" Height="26" Margin="0,0,4,0"/>
                    <Button Content="下一页" Command="{Binding NextPageCommand}"
                            Style="{DynamicResource MesSecondaryButton}" Width="55" Height="26" Margin="0,0,4,0"/>
                    <Button Content="末页" Command="{Binding LastPageCommand}"
                            Style="{DynamicResource MesSecondaryButton}" Width="50" Height="26"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
