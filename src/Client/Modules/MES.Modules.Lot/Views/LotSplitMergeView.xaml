<UserControl x:Class="MES.Modules.Lot.Views.LotSplitMergeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <UserControl.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MesCardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 操作面板 -->
            <RowDefinition Height="*"/>      <!-- 可用批次列表 -->
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="批次拆分/合并" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource MesTextPrimaryBrush}"
                       DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <Button Content="刷新" Command="{Binding RefreshCommand}"
                    Style="{DynamicResource MesPrimaryButton}"
                    HorizontalAlignment="Right" Width="80"/>
        </DockPanel>

        <!-- 操作面板 -->
        <Border Grid.Row="1" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <!-- 操作类型选择 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="操作类型:" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesTextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Text="{Binding OperationType, UpdateSourceTrigger=PropertyChanged}"
                              Width="120" FontSize="14" Style="{DynamicResource MesComboBox}">
                        <ComboBoxItem Content="Split" IsSelected="True"/>
                        <ComboBoxItem Content="Merge"/>
                    </ComboBox>
                </StackPanel>

                <!-- 源批次和目标批次选择 -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="源批次:" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesTextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="1" ItemsSource="{Binding AllLots}"
                              SelectedItem="{Binding SourceLot}"
                              DisplayMemberPath="LotId"
                              FontSize="13" Style="{DynamicResource MesComboBox}"
                              ToolTip="选择源批次"/>

                    <TextBlock Grid.Column="2" Text="目标批次:" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesTextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="16,0,8,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OperationType}" Value="Split">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ComboBox Grid.Column="3" ItemsSource="{Binding AllLots}"
                              SelectedItem="{Binding TargetLot}"
                              DisplayMemberPath="LotId"
                              FontSize="13"
                              ToolTip="选择目标批次" Margin="0,0,0,0">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource MesComboBox}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OperationType}" Value="Split">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>
                </Grid>

                <!-- 拆分数量（仅在Split时显示） -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OperationType}" Value="Merge">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="拆分数量:" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesTextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding SplitQty, UpdateSourceTrigger=PropertyChanged}"
                             Width="100" FontSize="14" Padding="8,4" Margin="0,0,16,0"
                             Style="{DynamicResource MesTextBox}"/>
                </StackPanel>

                <!-- 拆分/合并原因 -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="操作原因:" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding SplitReason, UpdateSourceTrigger=PropertyChanged}"
                             Width="500" Height="60" FontSize="13" Padding="8,4"
                             Style="{DynamicResource MesTextBox}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             ToolTip="请输入拆分/合并原因"/>
                </StackPanel>

                <!-- 执行按钮 -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="执行拆分" Command="{Binding ExecuteSplitCommand}" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MesPrimaryButton}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OperationType}" Value="Merge">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="执行合并" Command="{Binding ExecuteMergeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MesWarningButton}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OperationType}" Value="Split">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 可用批次列表 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding AllLots}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Style="{DynamicResource MesDataGrid}"
                          FontSize="13"
                          SelectionMode="Single" SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="批次号" Binding="{Binding LotId}" Width="140"/>
                        <DataGridTextColumn Header="工单号" Binding="{Binding OrderId}" Width="120"/>
                        <DataGridTextColumn Header="产品" Binding="{Binding ProductName}" Width="120"/>
                        <DataGridTextColumn Header="管芯" Binding="{Binding DieName}" Width="100"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90"/>
                        <DataGridTextColumn Header="工艺阶段" Binding="{Binding ProcessStage}" Width="80"/>
                        <DataGridTextColumn Header="颗数" Binding="{Binding UnitCount}" Width="70"/>
                        <DataGridTextColumn Header="Strip数" Binding="{Binding StripCount}" Width="70"/>
                        <DataGridTextColumn Header="当前工序" Binding="{Binding CurrentStep}" Width="110"/>
                        <DataGridTextColumn Header="部分批" Binding="{Binding IsPartialLot}" Width="60"/>
                        <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
