<Window x:Class="MES.Modules.Order.Views.HoldReasonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hold原因" Height="280" Width="400"
        Background="{StaticResource MesBackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Hold原因:" Grid.Row="0" Foreground="{StaticResource MesTextSecondaryBrush}" Margin="0,0,0,4"/>
        <TextBox Name="txtReason" Grid.Row="1" Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                 Background="{StaticResource MesSurfaceBrush}" Foreground="{StaticResource MesTextPrimaryBrush}"
                 BorderBrush="{StaticResource MesBorderBrush}" Margin="0,0,0,16"/>

        <TextBlock Text="备注:" Grid.Row="2" Foreground="{StaticResource MesTextSecondaryBrush}" Margin="0,0,0,4"/>
        <TextBox Name="txtRemark" Grid.Row="2" Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalAlignment="Bottom"
                 Background="{StaticResource MesSurfaceBrush}" Foreground="{StaticResource MesTextPrimaryBrush}"
                 BorderBrush="{StaticResource MesBorderBrush}" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Width="80" Height="30" Click="btnOk_Click"
                    Background="{StaticResource MesAccentBrush}" Foreground="White" BorderThickness="0"/>
            <Button Content="取消" Width="80" Height="30" Margin="12,0,0,0" Click="btnCancel_Click"
                    Background="{StaticResource MesBorderBrush}" Foreground="{StaticResource MesTextPrimaryBrush}" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
