<UserControl x:Class="MES.Modules.Order.Views.WorkOrderCloseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="工单关闭"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource MesTextPrimaryBrush}"
                   Margin="0,0,0,16"/>

        <!-- 统计卡片 -->
        <UniformGrid Grid.Row="1" Rows="1" Margin="0,0,0,16">
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="可关闭工单" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesInfoBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="可正常关闭" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding ReadyToCloseCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesSuccessBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="部分完工" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding PartialCloseCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesWarningBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="未开工" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding PendingCloseCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- 筛选和搜索 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="搜索工单号/产品..."
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MesTextSecondaryBrush}"
                           Margin="0,0,8,0"/>

                <TextBox Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource MesTextBox}"
                         Margin="0,0,16,0"/>

                <Button Grid.Column="2"
                        Content="刷新"
                        Command="{Binding RefreshCommand}"
                        Style="{DynamicResource MesPrimaryButton}"/>
            </Grid>
        </Border>

        <!-- 错误提示 -->
        <TextBlock Grid.Row="3"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource MesDangerBrush}"
                   FontSize="13"
                   Margin="0,0,0,16"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- 工单列表 -->
        <Border Grid.Row="4" Style="{DynamicResource MesCard}" Padding="0">
            <DataGrid ItemsSource="{Binding ClosableOrders}"
                      SelectedItem="{Binding SelectedOrder}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Style="{DynamicResource MesDataGrid}"
                      FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="工单号" Binding="{Binding OrderId}" Width="120"/>
                    <DataGridTextColumn Header="产品" Binding="{Binding ProductName}" Width="120"/>
                    <DataGridTextColumn Header="计划量" Binding="{Binding PlannedQty}" Width="70"/>
                    <DataGridTextColumn Header="完成量" Binding="{Binding CompletedQty}" Width="70"/>
                    <DataGridTemplateColumn Header="进度" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="8"
                                                 Style="{DynamicResource MesProgressBar}"
                                                 Foreground="{DynamicResource MesSuccessBrush}"
                                                 Background="{DynamicResource MesBackgroundElevatedBrush}"/>
                                    <TextBlock Text="{Binding ProgressPercent, StringFormat='{}{0}%'}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="11" Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                    <DataGridTextColumn Header="客户" Binding="{Binding CustomerName}" Width="100"/>
                    <DataGridTextColumn Header="计划交期" Binding="{Binding PlannedEndDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="100"/>
                    <DataGridTemplateColumn Header="操作" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="关闭"
                                            Command="{Binding DataContext.CloseOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="2" Width="55"
                                            ToolTip="正常关闭工单"/>
                                    <Button Content="强制关闭"
                                            Command="{Binding DataContext.ForceCloseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="2" Width="65"
                                            Style="{DynamicResource MesWarningButton}"
                                            ToolTip="强制关闭未完成工单"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- 关闭原因输入 -->
        <Border Grid.Row="5" Style="{DynamicResource MesCard}" Padding="16" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="关闭原因" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,8"/>
                <TextBox Text="{Binding CloseReason}"
                         Style="{DynamicResource MesTextBox}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         Height="60"
                         Margin="0,0,0,8"/>
                <TextBlock Text="选择工单后输入关闭原因，然后点击操作列的关闭按钮"
                           FontSize="12"
                           Foreground="{DynamicResource MesTextTertiaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
