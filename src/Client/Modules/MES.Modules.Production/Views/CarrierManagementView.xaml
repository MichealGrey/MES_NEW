<UserControl x:Class="MES.Modules.Production.Views.CarrierManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 + 操作按钮 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="载具管理" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,24,0"
                       VerticalAlignment="Center"/>
            <Button Content="新增" Command="{Binding AddCommand}"
                    Style="{DynamicResource MesPrimaryButton}" Margin="0,0,8,0"/>
            <Button Content="编辑" Command="{Binding EditCommand}"
                    Style="{DynamicResource MesSecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="切换状态" Command="{Binding ToggleStatusCommand}"
                    Style="{DynamicResource MesSecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="刷新" Command="{Binding RefreshCommand}"
                    Style="{DynamicResource MesSecondaryButton}"/>
        </StackPanel>

        <!-- 数据表格 -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Carriers}" SelectedItem="{Binding SelectedCarrier}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Style="{DynamicResource MesDataGrid}"
                  SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="载具ID" Binding="{Binding CarrierId}" Width="140"/>
                <DataGridTextColumn Header="载具类型" Binding="{Binding CarrierType}" Width="120"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90"/>
                <DataGridTextColumn Header="容量" Binding="{Binding Capacity}" Width="60"/>
                <DataGridTextColumn Header="使用次数" Binding="{Binding UseCount}" Width="80"/>
                <DataGridTextColumn Header="最大使用次数" Binding="{Binding MaxUseCount}" Width="100"/>
                <DataGridTextColumn Header="位置" Binding="{Binding Location}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
