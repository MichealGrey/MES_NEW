<UserControl x:Class="MES.Modules.Production.Views.DefectCodeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="缺陷代码管理" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="缺陷分类:" Foreground="{DynamicResource MesTextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox x:Name="cmbFilterCategory" Width="120" Height="28"
                      SelectionChanged="cmbFilterCategory_SelectionChanged">
                <ComboBoxItem Content="全部" IsSelected="True"/>
                <ComboBoxItem Content="Cosmetic"/>
                <ComboBoxItem Content="Dimensional"/>
                <ComboBoxItem Content="Electrical"/>
                <ComboBoxItem Content="Functional"/>
            </ComboBox>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="新增" Command="{Binding AddCommand}"
                    Style="{DynamicResource MesPrimaryButton}"/>
            <Button Content="编辑" Command="{Binding EditCommand}"
                    Style="{DynamicResource MesSecondaryButton}" Margin="8,0,0,0"/>
            <Button Content="启用/停用" Command="{Binding ToggleEnabledCommand}"
                    Style="{DynamicResource MesSecondaryButton}" Margin="8,0,0,0"/>
            <Button Content="刷新" Command="{Binding RefreshCommand}"
                    Style="{DynamicResource MesSecondaryButton}" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding DefectCodes}" SelectedItem="{Binding SelectedDefectCode}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Style="{DynamicResource MesDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="缺陷代码" Binding="{Binding DefectCodeId}" Width="140"/>
                <DataGridTextColumn Header="缺陷分类" Binding="{Binding DefectCategory}" Width="120"/>
                <DataGridTextColumn Header="严重等级" Binding="{Binding Severity}" Width="100"/>
                <DataGridTextColumn Header="缺陷描述" Binding="{Binding DefectText}" Width="*"/>
                <DataGridTemplateColumn Header="启用" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsEnabled}" HorizontalAlignment="Center" IsHitTestVisible="False"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
