<UserControl x:Class="MES.Modules.Production.Views.GenealogyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{StaticResource MesBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 搜索区 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="批次号:" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{StaticResource MesTextPrimaryBrush}"/>
            <TextBox Text="{Binding SearchLotId}" Width="200" Margin="0,0,12,0"/>
            <Button Content="查询谱系" Command="{Binding SearchCommand}" Width="100" Margin="0,0,12,0"/>
            <Button Content="载具历史" Command="{Binding LoadCarrierHistoryCommand}" Width="100"/>
        </StackPanel>

        <!-- 谱系记录 -->
        <GroupBox Grid.Row="1" Header="谱系追溯记录" Margin="0,0,0,12"
                  Foreground="{StaticResource MesTextPrimaryBrush}">
            <DataGrid ItemsSource="{Binding GenealogyRecords}" AutoGenerateColumns="False"
                      IsReadOnly="True" MaxHeight="250"
                      Background="{StaticResource MesSurfaceBrush}" Foreground="{StaticResource MesTextPrimaryBrush}"
                      BorderBrush="{StaticResource MesBorderBrush}" RowBackground="{StaticResource MesCardBrush}"
                      AlternatingRowBackground="{StaticResource MesSurfaceBrush}" GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="父批次" Binding="{Binding ParentLotId}" Width="140"/>
                    <DataGridTextColumn Header="子批次" Binding="{Binding ChildLotId}" Width="140"/>
                    <DataGridTextColumn Header="关系类型" Binding="{Binding RelationType}" Width="100"/>
                    <DataGridTextColumn Header="工序" Binding="{Binding StepCode}" Width="100"/>
                    <DataGridTextColumn Header="数量" Binding="{Binding Qty}" Width="80"/>
                    <DataGridTextColumn Header="操作人" Binding="{Binding OperatorId}" Width="100"/>
                    <DataGridTextColumn Header="时间" Binding="{Binding CreatedAt}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- 关联批次和载具历史 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 关联批次 -->
            <GroupBox Grid.Column="0" Header="关联批次" Margin="0,0,8,0"
                      Foreground="{StaticResource MesTextPrimaryBrush}">
                <DataGrid ItemsSource="{Binding RelatedLots}" AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="{StaticResource MesSurfaceBrush}" Foreground="{StaticResource MesTextPrimaryBrush}"
                          BorderBrush="{StaticResource MesBorderBrush}" RowBackground="{StaticResource MesCardBrush}"
                          AlternatingRowBackground="{StaticResource MesSurfaceBrush}" GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column" FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="批次号" Binding="{Binding LotId}" Width="140"/>
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                        <DataGridTextColumn Header="数量" Binding="{Binding UnitCount}" Width="80"/>
                        <DataGridTextColumn Header="拆分原因" Binding="{Binding SplitReason}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <!-- 载具历史 -->
            <GroupBox Grid.Column="1" Header="载具绑定历史" Margin="8,0,0,0"
                      Foreground="{StaticResource MesTextPrimaryBrush}">
                <DataGrid ItemsSource="{Binding CarrierHistory}" AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="{StaticResource MesSurfaceBrush}" Foreground="{StaticResource MesTextPrimaryBrush}"
                          BorderBrush="{StaticResource MesBorderBrush}" RowBackground="{StaticResource MesCardBrush}"
                          AlternatingRowBackground="{StaticResource MesSurfaceBrush}" GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column" FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="载具ID" Binding="{Binding CarrierId}" Width="120"/>
                        <DataGridTextColumn Header="载具类型" Binding="{Binding CarrierType}" Width="100"/>
                        <DataGridTextColumn Header="工序" Binding="{Binding StepCode}" Width="100"/>
                        <DataGridTextColumn Header="绑定时间" Binding="{Binding BindTime}" Width="160"/>
                        <DataGridTextColumn Header="操作人" Binding="{Binding OperatorId}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
