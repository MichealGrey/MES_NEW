<UserControl x:Class="MES.Modules.Production.Views.GradeSortView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="等级分选" FontSize="24" FontWeight="SemiBold"
                   Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,16"/>

        <!-- 主内容区：左侧待分选列表 + 右侧 BIN 结果 + 分选规则 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：待分选批次列表 -->
            <Border Grid.Column="0" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 刷新按钮 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="刷新" Command="{Binding RefreshCommand}"
                                Style="{DynamicResource MesPrimaryButton}"/>
                        <TextBlock Text="{Binding Message}" FontSize="12"
                                   Foreground="{DynamicResource MesTextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding PendingLots}"
                              SelectedItem="{Binding SelectedLot}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Style="{DynamicResource MesDataGrid}"
                              SelectionMode="Single" SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="批次号" Binding="{Binding LotId}" Width="140"/>
                            <DataGridTextColumn Header="工单号" Binding="{Binding OrderId}" Width="120"/>
                            <DataGridTextColumn Header="产品" Binding="{Binding ProductName}" Width="120"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                            <DataGridTextColumn Header="Bin结果" Binding="{Binding BinResult}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 右侧：BIN 结果 + 分选规则 -->
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <!-- BIN 结果展示 -->
                <Border Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="BIN 结果详情" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,12"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding BinResults}" FontSize="12"
                                       Foreground="{DynamicResource MesTextPrimaryBrush}"
                                       FontFamily="Consolas" TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- 分选规则 -->
                <Border Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="分选规则配置" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Grade A:" Width="70" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                            <TextBox Text="{Binding GradeABin}" Width="200"
                                     Style="{DynamicResource MesTextBox}"/>
                            <TextBlock Text="(如: Bin1)" FontSize="11"
                                       Foreground="{DynamicResource MesTextTertiaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Grade B:" Width="70" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                            <TextBox Text="{Binding GradeBBin}" Width="200"
                                     Style="{DynamicResource MesTextBox}"/>
                            <TextBlock Text="(如: Bin2,Bin3)" FontSize="11"
                                       Foreground="{DynamicResource MesTextTertiaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Grade C:" Width="70" VerticalAlignment="Center"
                                       Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                            <TextBox Text="{Binding GradeCBin}" Width="200"
                                     Style="{DynamicResource MesTextBox}"/>
                            <TextBlock Text="(如: Bin4,Bin5,Bin6)" FontSize="11"
                                       Foreground="{DynamicResource MesTextTertiaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 执行按钮 -->
                <Button Content="执行分选" Command="{Binding ExecuteSortCommand}"
                        FontWeight="SemiBold">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MesPrimaryButton}">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 底部消息 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="8" Margin="0,12,0,0">
            <TextBlock Text="{Binding Message}" FontSize="13"
                       Foreground="{DynamicResource MesTextPrimaryBrush}" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
