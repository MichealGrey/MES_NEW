<Window x:Class="MES.Modules.Production.Views.HoldReasonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hold 工单" Height="250" Width="380"
        Background="{StaticResource MesBackgroundBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="请输入 Hold 原因：" Foreground="{StaticResource MesTextPrimaryBrush}" FontSize="14" Margin="0,0,0,8"/>

        <ComboBox Name="cmbReason" Height="30" Margin="0,0,0,8"
                  Background="{StaticResource MesSurfaceBrush}" Foreground="{StaticResource MesComboxTextBrush}"
                  BorderBrush="{StaticResource MesBorderBrush}" IsEditable="True">
            <ComboBoxItem Content="品质异常待检"/>
            <ComboBoxItem Content="等物料"/>
            <ComboBoxItem Content="工程指示"/>
            <ComboBoxItem Content="设备维护"/>
            <ComboBoxItem Content="工艺变更待确认"/>
            <ComboBoxItem Content="客户要求暂停"/>
        </ComboBox>

        <TextBlock Text="备注（可选）：" Foreground="{StaticResource MesTextSecondaryBrush}" FontSize="12" Margin="0,8,0,4"/>
        <TextBox Name="txtRemark" Height="50" AcceptsReturn="True" TextWrapping="Wrap"
                 Background="{StaticResource MesSurfaceBrush}" Foreground="{StaticResource MesComboxTextBrush}"
                 BorderBrush="{StaticResource MesBorderBrush}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button Content="确定 Hold" Width="100" Height="32"
                    Background="{StaticResource MesWarningBrush}" Foreground="White"
                    BorderThickness="0" Click="btnConfirm_Click"/>
            <Button Content="取消" Width="100" Height="32" Margin="16,0,0,0"
                    Background="{StaticResource MesBorderBrush}" Foreground="{StaticResource MesTextPrimaryBrush}"
                    BorderThickness="0" Click="btnCancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
