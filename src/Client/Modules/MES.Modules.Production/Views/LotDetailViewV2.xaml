<UserControl x:Class="MES.Modules.Production.Views.LotDetailViewV2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <UserControl.Resources>
        <converters:LotLevelToBrushConverter x:Key="LotLevelToBrush"/>
        <converters:LotLevelToTextConverter x:Key="LotLevelToText"/>
        <converters:LotLevelToForegroundConverter x:Key="LotLevelToForeground"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- 标题栏 -->
                <RowDefinition Height="Auto"/>   <!-- 层级关系图 -->
                <RowDefinition Height="Auto"/>   <!-- 批次基本信息 -->
                <RowDefinition Height="Auto"/>   <!-- 流程进度 -->
                <RowDefinition Height="Auto"/>   <!-- 操作记录 -->
            </Grid.RowDefinitions>

            <!-- ==========================================
                 标题栏
            ========================================== -->
            <Border Grid.Row="0"
                    Style="{DynamicResource MesCard}"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 左侧：批次信息 -->
                    <StackPanel Grid.Column="0"
                              Orientation="Horizontal">
                        <!-- 层级标识 -->
                        <Border Background="{Binding LotInfo.LotLevel, Converter={StaticResource LotLevelToBrush}}"
                                CornerRadius="{DynamicResource MesRadiusMd}"
                                Padding="12,8"
                                Margin="0,0,12,0">
                            <TextBlock Text="{Binding LotInfo.LotLevel, Converter={StaticResource LotLevelToText}}"
                                      FontSize="14"
                                      FontWeight="Bold"
                                      Foreground="{Binding LotInfo.LotLevel, Converter={StaticResource LotLevelToForeground}}"/>
                        </Border>
                        
                        <!-- 批次号和信息 -->
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding LotInfo.LotId}"
                                      FontFamily="{DynamicResource MesFontDisplay}"
                                      FontSize="24"
                                      FontWeight="Bold"
                                      Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                            <TextBlock Text="{Binding LotInfo.OrderId, StringFormat='工单号: {0}'}"
                                      FontSize="13"
                                      Foreground="{DynamicResource MesTextSecondaryBrush}"
                                      Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- 中间：状态 -->
                    <StackPanel Grid.Column="1"
                              Orientation="Horizontal"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                        <Border Width="12"
                                Height="12"
                                CornerRadius="6"
                                Background="{Binding LotInfo.Status, Converter={StaticResource LotStatusToColor}}"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding LotInfo.Status}"
                                  FontSize="16"
                                  FontWeight="Medium"
                                  Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                    </StackPanel>
                    
                    <!-- 右侧：操作按钮 -->
                    <StackPanel Grid.Column="2"
                              Orientation="Horizontal">
                        <Button Content="Hold"
                               Style="{DynamicResource MesSecondaryButton}"
                               Margin="0,0,8,0"/>
                        <Button Content="拆分"
                               Style="{DynamicResource MesSecondaryButton}"
                               Margin="0,0,8,0"/>
                        <Button Content="进站"
                               Style="{DynamicResource MesPrimaryButton}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==========================================
                 层级关系图
            ========================================== -->
            <Border Grid.Row="1"
                    Style="{DynamicResource MesCard}"
                    Margin="0,0,0,16"
                    Padding="20">
                <StackPanel>
                    <!-- 标题 -->
                    <TextBlock Text="批次层级关系"
                              FontFamily="{DynamicResource MesFontDisplay}"
                              FontSize="18"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource MesTextPrimaryBrush}"
                              Margin="0,0,0,16"/>
                    
                    <!-- 层级关系图 -->
                    <ItemsControl ItemsSource="{Binding HierarchyNodes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- 层级标签 -->
                                    <Border Grid.Column="0"
                                            Background="{Binding LevelBrush}"
                                            CornerRadius="3"
                                            Padding="6,3"
                                            HorizontalAlignment="Left"
                                            Margin="0,8,12,8">
                                        <TextBlock Text="{Binding LevelLabel}"
                                                  FontSize="11"
                                                  FontWeight="Bold"
                                                  Foreground="{Binding LevelForeground}"/>
                                    </Border>
                                    
                                    <!-- 连接线 -->
                                    <Line Grid.Column="1"
                                          X1="0"
                                          Y1="0"
                                          X2="0"
                                          Y2="40"
                                          Stroke="{DynamicResource MesBorderDefaultBrush}"
                                          StrokeThickness="2"
                                          StrokeDashArray="4,2"
                                          Visibility="{Binding HasChild, Converter={StaticResource BoolToVis}}"
                                          VerticalAlignment="Top"/>
                                    
                                    <!-- 批次节点 -->
                                    <Border Grid.Column="2"
                                            Background="{DynamicResource MesBackgroundElevatedBrush}"
                                            BorderBrush="{Binding IsCurrent, Converter={StaticResource BoolToThickness}}"
                                            BorderThickness="2"
                                            CornerRadius="{DynamicResource MesRadiusMd}"
                                            Padding="12"
                                            Margin="0,8,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- 批次信息 -->
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding LotId}"
                                                          FontSize="14"
                                                          FontWeight="Medium"
                                                          Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Summary}"
                                                          FontSize="12"
                                                          Foreground="{DynamicResource MesTextSecondaryBrush}"
                                                          Margin="0,4,0,0"/>
                                            </StackPanel>
                                            
                                            <!-- 当前标记 -->
                                            <Border Grid.Column="1"
                                                    Background="{DynamicResource MesInfoBrush}"
                                                    CornerRadius="3"
                                                    Padding="6,3"
                                                    Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="当前"
                                                          FontSize="11"
                                                          FontWeight="Medium"
                                                          Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ==========================================
                 批次基本信息
            ========================================== -->
            <Border Grid.Row="2"
                    Style="{DynamicResource MesCard}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <!-- 标题 -->
                    <TextBlock Text="批次信息"
                              FontFamily="{DynamicResource MesFontDisplay}"
                              FontSize="18"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource MesTextPrimaryBrush}"
                              Margin="16,16,16,0"/>
                    
                    <!-- 信息网格 -->
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- 左侧列 -->
                        <StackPanel Grid.Column="0">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                          Text="产品:"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                          Text="{Binding LotInfo.ProductName}"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                          Text="封装:"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                          Text="{Binding LotInfo.PackageTypeDisplay}"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                          Text="数量:"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                          Text="{Binding LotInfo.UnitCount}"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                          Text="载具:"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                          Text="{Binding LotInfo.CarrierId}"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                            </Grid>
                        </StackPanel>
                        
                        <!-- 右侧列 -->
                        <StackPanel Grid.Column="2">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                          Text="当前工序:"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                          Text="{Binding LotInfo.CurrentStep}"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                          Text="优先级:"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                          Text="{Binding LotInfo.Priority}"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                          Text="良率:"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                          Text="{Binding LotInfo.CurrentYield, StringFormat='{}{0:F1}%'}"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                          Text="路径:"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                          Text="{Binding LotInfo.RouteId}"
                                          FontSize="13"
                                          Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ==========================================
                 流程进度
            ========================================== -->
            <Border Grid.Row="3"
                    Style="{DynamicResource MesCard}"
                    Margin="0,0,0,16">
                <StackPanel>
                    <!-- 标题 -->
                    <TextBlock Text="工序流程"
                              FontFamily="{DynamicResource MesFontDisplay}"
                              FontSize="18"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource MesTextPrimaryBrush}"
                              Margin="16,16,16,0"/>
                    
                    <!-- 流程进度条 -->
                    <ItemsControl ItemsSource="{Binding ProcessSteps}"
                                  Margin="16">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- 步骤节点 -->
                                    <Border Grid.Row="0"
                                            Width="40"
                                            Height="40"
                                            CornerRadius="20"
                                            Background="{Binding StatusBrush}"
                                            BorderBrush="{DynamicResource MesBorderDefaultBrush}"
                                            BorderThickness="2"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Icon}"
                                                  FontSize="16"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Foreground="White"/>
                                    </Border>
                                    
                                    <!-- 连接线 -->
                                    <Line Grid.Row="0"
                                          X1="40"
                                          Y1="20"
                                          X2="60"
                                          Y2="20"
                                          Stroke="{DynamicResource MesBorderDefaultBrush}"
                                          StrokeThickness="2"
                                          Visibility="{Binding HasNext, Converter={StaticResource BoolToVis}}"
                                          HorizontalAlignment="Left"/>
                                    
                                    <!-- 步骤名称 -->
                                    <TextBlock Grid.Row="1"
                                              Text="{Binding StepName}"
                                              FontSize="11"
                                              Foreground="{DynamicResource MesTextSecondaryBrush}"
                                              TextAlignment="Center"
                                              MaxWidth="80"
                                              TextWrapping="Wrap"
                                              Margin="4,8,4,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ==========================================
                 操作记录
            ========================================== -->
            <Border Grid.Row="4"
                    Style="{DynamicResource MesCard}">
                <StackPanel>
                    <!-- 标题 -->
                    <TextBlock Text="操作记录"
                              FontFamily="{DynamicResource MesFontDisplay}"
                              FontSize="18"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource MesTextPrimaryBrush}"
                              Margin="16,16,16,0"/>
                    
                    <!-- 记录列表 -->
                    <DataGrid ItemsSource="{Binding OperationRecords}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Style="{DynamicResource MesDataGrid}"
                              RowStyle="{DynamicResource MesDataGridRow}"
                              ColumnHeaderStyle="{DynamicResource MesDataGridColumnHeader}"
                              Margin="16">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" 
                                               Binding="{Binding Time, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" 
                                               Width="180"/>
                            <DataGridTextColumn Header="操作" 
                                               Binding="{Binding Action}" 
                                               Width="120"/>
                            <DataGridTextColumn Header="操作者" 
                                               Binding="{Binding Operator}" 
                                               Width="120"/>
                            <DataGridTextColumn Header="详情" 
                                               Binding="{Binding Details}" 
                                               Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
