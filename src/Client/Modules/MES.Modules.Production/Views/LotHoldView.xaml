<UserControl x:Class="MES.Modules.Production.Views.LotHoldView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <UserControl.Resources>
        <converters:HoldTypeToBrushConverter x:Key="HoldTypeBrush"/>
        <converters:OverdueToBrushConverter x:Key="OverdueBrush"/>
        <converters:StatusToBrushConverter x:Key="StatusBrush"/>
        <converters:PriorityToBrushConverter x:Key="PriorityBrush"/>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 标题 + 工具栏 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="批次Hold管理" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource MesTextPrimaryBrush}" VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="&#xE710; Hold" Command="{Binding HoldLotCommand}" Margin="0,0,6,0"
                        Style="{DynamicResource MesWarningButton}"
                        ToolTip="Hold一个批次"/>
                <Button Content="&#xE768; Release" Command="{Binding ReleaseLotCommand}" CommandParameter="{Binding SelectedHoldLot}" Margin="0,0,6,0"
                        Style="{DynamicResource MesSuccessButton}"
                        ToolTip="释放选中的Hold批次"/>
                <Button Content="&#xE768; 批量释放" Command="{Binding BatchReleaseCommand}" Margin="0,0,6,0"
                        Style="{DynamicResource MesPrimaryButton}"
                        ToolTip="批量释放所有Hold批次"/>
                <Button Content="↻ 刷新" Command="{Binding RefreshCommand}"
                        Style="{DynamicResource MesSecondaryButton}"
                        ToolTip="刷新Hold批次列表"/>
            </StackPanel>
        </DockPanel>

        <!-- Row 1: 统计摘要栏 -->
        <UniformGrid Grid.Row="1" Rows="1" Margin="0,0,0,16">
            <!-- Hold总数 -->
            <Border Style="{DynamicResource MesKpiCard}" Padding="12,8" Margin="0,0,4,0">
                <StackPanel>
                    <TextBlock Text="Hold总数" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                    <TextBlock Text="{Binding TotalHoldCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesWarningBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <!-- ENG -->
            <Border Style="{DynamicResource MesKpiCard}" Padding="12,8" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="工程Hold" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                    <TextBlock Text="{Binding EngineeringHoldCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesInfoBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <!-- QA -->
            <Border Style="{DynamicResource MesKpiCard}" Padding="12,8" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="品质Hold" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                    <TextBlock Text="{Binding QualityHoldCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDangerBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <!-- CUST -->
            <Border Style="{DynamicResource MesKpiCard}" Padding="12,8" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="客户Hold" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                    <TextBlock Text="{Binding CustomerHoldCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesInfoBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <!-- MAT -->
            <Border Style="{DynamicResource MesKpiCard}" Padding="12,8" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="物料Hold" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                    <TextBlock Text="{Binding MaterialHoldCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesWarningBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <!-- 超时预警 -->
            <Border Style="{DynamicResource MesKpiCard}" Padding="12,8" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="超时预警(&gt;24h)" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                    <TextBlock Text="{Binding OverdueCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDangerBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <!-- 良率Hold -->
            <Border Style="{DynamicResource MesKpiCard}" Padding="12,8" Margin="4,0,4,0">
                <StackPanel>
                    <TextBlock Text="良率Hold" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                    <TextBlock Text="{Binding YieldHoldCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesWarningBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <!-- 数据Hold -->
            <Border Style="{DynamicResource MesKpiCard}" Padding="12,8" Margin="4,0,0,0">
                <StackPanel>
                    <TextBlock Text="数据Hold" FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                    <TextBlock Text="{Binding DataHoldCount}" FontSize="22" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesSuccessBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Row 2: 筛选面板 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="12,8" Margin="0,0,0,16">
            <WrapPanel>
                <TextBlock Text="筛选:" VerticalAlignment="Center" FontSize="13"
                           Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,8,0"/>

                <TextBlock Text="Hold类型" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,4,0"/>
                <ComboBox Width="100" Margin="0,0,8,0"
                          ItemsSource="{Binding HoldTypeOptions}"
                          SelectedItem="{Binding FilterHoldType}"/>

                <TextBlock Text="原因" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,4,0"/>
                <ComboBox Width="130" Margin="0,0,8,0"
                          ItemsSource="{Binding HoldReasonOptions}"
                          SelectedItem="{Binding FilterHoldReason}"/>

                <TextBlock Text="从" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,4,0"/>
                <DatePicker Width="120" Margin="0,0,4,0"
                            SelectedDate="{Binding FilterDateFrom}"/>
                <TextBlock Text="至" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,4,0"/>
                <DatePicker Width="120" Margin="0,0,12,0"
                            SelectedDate="{Binding FilterDateTo}"/>

                <Grid Width="200" Margin="0,0,8,0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource MesTextBox}"/>
                    <TextBlock Text="批次号/工单号/产品..." IsHitTestVisible="False"
                               Foreground="{DynamicResource MesTextTertiaryBrush}" VerticalAlignment="Center" Margin="6,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Content="清除筛选" Command="{Binding ClearFilterCommand}"
                        Style="{DynamicResource MesSecondaryButton}"
                        ToolTip="清除所有筛选条件"/>
            </WrapPanel>
        </Border>

        <!-- Row 3: DataGrid -->
        <DataGrid x:Name="dgHoldLots" Grid.Row="3"
                  ItemsSource="{Binding PagedHoldLots}" SelectedItem="{Binding SelectedHoldLot}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Style="{DynamicResource MesDataGrid}">
            <!-- 超时行高亮 -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{Binding IsHoldOverdue, Converter={StaticResource OverdueBrush}}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource MesInfoBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="批次号" Binding="{Binding LotId}" Width="130"/>
                <DataGridTextColumn Header="工单号" Binding="{Binding OrderId}" Width="110"/>
                <DataGridTextColumn Header="产品" Binding="{Binding ProductName}" Width="100"/>
                <DataGridTextColumn Header="管芯" Binding="{Binding DieName}" Width="100"/>
                <DataGridTextColumn Header="封装类型" Binding="{Binding PackageTypeDisplay}" Width="65"/>
                <DataGridTextColumn Header="当前工序" Binding="{Binding CurrentStep}" Width="70"/>
                <DataGridTextColumn Header="所在设备" Binding="{Binding CurrentEquipment}" Width="80"/>

                <!-- Hold类型（带颜色） -->
                <DataGridTemplateColumn Header="Hold类型" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding HoldTypeDisplay}" FontWeight="SemiBold" Margin="4,0"
                                       Foreground="{Binding HoldCategory, Converter={StaticResource HoldTypeBrush}}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Hold原因 -->
                <DataGridTemplateColumn Header="Hold原因" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding HoldReason, TargetNullValue='—'}"
                                       VerticalAlignment="Center" Margin="4,0"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding HoldReason}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Hold时间 -->
                <DataGridTextColumn Header="Hold时间" Binding="{Binding HoldTime, StringFormat='{}{0:MM-dd HH:mm}'}" Width="100"/>

                <!-- Hold时长 -->
                <DataGridTemplateColumn Header="Hold时长" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding HoldDuration}"
                                       VerticalAlignment="Center" Margin="4,0"
                                       FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource MesTextPrimaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHoldOverdue}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource MesDangerBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Hold操作人 -->
                <DataGridTextColumn Header="Hold人" Binding="{Binding HoldOperator, TargetNullValue='—'}" Width="80"/>

                <!-- 优先级（带颜色） -->
                <DataGridTemplateColumn Header="优先级" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Priority}" FontWeight="SemiBold" Margin="4,0"
                                       Foreground="{Binding Priority, Converter={StaticResource PriorityBrush}}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="颗数" Binding="{Binding UnitCount}" Width="55"/>
                <DataGridTextColumn Header="Strip数" Binding="{Binding StripCount}" Width="55"/>
                <DataGridTextColumn Header="载具" Binding="{Binding CarrierTypeDisplay}" Width="50"/>
                <DataGridTextColumn Header="载具号" Binding="{Binding CarrierId}" Width="75"/>

                <!-- 释放条件 -->
                <DataGridTemplateColumn Header="释放条件" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ReleaseCondition, TargetNullValue='—'}"
                                       VerticalAlignment="Center" Margin="4,0"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding ReleaseCondition}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Row 4: 分页控件栏 -->
        <Border Grid.Row="4" Style="{DynamicResource MesCard}" Padding="12,6" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 每页条数选择 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                    <TextBlock Text="每页" Foreground="{DynamicResource MesTextSecondaryBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="60" Height="26"
                              SelectedItem="{Binding PageSize}">
                        <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">10</sys:Int32>
                        <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">20</sys:Int32>
                        <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">50</sys:Int32>
                        <sys:Int32 xmlns:sys="clr-namespace:System;assembly=mscorlib">100</sys:Int32>
                    </ComboBox>
                    <TextBlock Text="条" Foreground="{DynamicResource MesTextSecondaryBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- 分页信息 -->
                <TextBlock Grid.Column="1" Text="{Binding PageInfo}"
                           Foreground="{DynamicResource MesTextSecondaryBrush}" FontSize="12"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- 分页导航按钮 -->
                <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center">
                    <Button Content="&#xE74A;" Command="{Binding FirstPageCommand}"
                            Style="{DynamicResource MesSecondaryButton}" Width="28" Height="26" Margin="0,0,2,0"
                            ToolTip="首页" FontFamily="Segoe MDL2 Assets"/>
                    <Button Content="&#xE74B;" Command="{Binding PreviousPageCommand}"
                            Style="{DynamicResource MesSecondaryButton}" Width="28" Height="26" Margin="0,0,2,0"
                            ToolTip="上一页" FontFamily="Segoe MDL2 Assets"/>
                    <Button Content="&#xE74C;" Command="{Binding NextPageCommand}"
                            Style="{DynamicResource MesSecondaryButton}" Width="28" Height="26" Margin="0,0,2,0"
                            ToolTip="下一页" FontFamily="Segoe MDL2 Assets"/>
                    <Button Content="&#xE74D;" Command="{Binding LastPageCommand}"
                            Style="{DynamicResource MesSecondaryButton}" Width="28" Height="26"
                            ToolTip="末页" FontFamily="Segoe MDL2 Assets"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
