<UserControl x:Class="MES.Modules.Production.Views.LotListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{StaticResource MesBackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 统计卡片 -->
            <RowDefinition Height="Auto"/>   <!-- 过滤栏 -->
            <RowDefinition Height="*"/>      <!-- 数据表格 -->
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="批次管理" FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource MesTextPrimaryBrush}" Margin="0,0,0,12"/>

        <!-- 统计卡片行 -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,12">
            <Border Background="{StaticResource MesCardBrush}" BorderBrush="{StaticResource MesBorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="总批次" FontSize="11" Foreground="{StaticResource MesTextMutedBrush}"/>
                    <TextBlock Text="{Binding TotalCount}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource MesTextPrimaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource MesCardBrush}" BorderBrush="{StaticResource MesBorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Assemble" FontSize="11" Foreground="{StaticResource MesTextMutedBrush}"/>
                    <TextBlock Text="{Binding AssembleCount}" FontSize="18" FontWeight="Bold"
                               Foreground="#00D2FF"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource MesCardBrush}" BorderBrush="{StaticResource MesBorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Test" FontSize="11" Foreground="{StaticResource MesTextMutedBrush}"/>
                    <TextBlock Text="{Binding TestCount}" FontSize="18" FontWeight="Bold"
                               Foreground="#4CC56C"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource MesCardBrush}" BorderBrush="{StaticResource MesCriticalBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Hold" FontSize="11" Foreground="{StaticResource MesTextMutedBrush}"/>
                    <TextBlock Text="{Binding HoldCount}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource MesCriticalBrush}"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource MesCardBrush}" BorderBrush="{StaticResource MesBorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="等待中" FontSize="11" Foreground="{StaticResource MesTextMutedBrush}"/>
                    <TextBlock Text="{Binding WaitingCount}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource MesWarningBrush}"/>
                </StackPanel>
            </Border>
            <Border Background="{StaticResource MesCardBrush}" BorderBrush="{StaticResource MesBorderBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="生产中" FontSize="11" Foreground="{StaticResource MesTextMutedBrush}"/>
                    <TextBlock Text="{Binding ProcessingCount}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource MesAccentBrush}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- 过滤栏 -->
        <Border Grid.Row="2" Background="{StaticResource MesCardBrush}" BorderBrush="{StaticResource MesBorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 工艺阶段 Tab -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="阶段:" FontSize="13" Foreground="{StaticResource MesTextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <RadioButton Content="全部"
                                 IsChecked="{Binding SelectedStage, Converter={StaticResource EnumMatch}, ConverterParameter=All}"
                                 FontSize="13" Foreground="{StaticResource MesTextPrimaryBrush}" Margin="0,0,12,0"/>
                    <RadioButton Content="Assemble"
                                 IsChecked="{Binding SelectedStage, Converter={StaticResource EnumMatch}, ConverterParameter=Assemble}"
                                 FontSize="13" Foreground="#00D2FF" Margin="0,0,12,0"/>
                    <RadioButton Content="Test"
                                 IsChecked="{Binding SelectedStage, Converter={StaticResource EnumMatch}, ConverterParameter=Test}"
                                 FontSize="13" Foreground="#4CC56C" Margin="0,0,12,0"/>
                </StackPanel>

                <!-- 状态过滤 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="状态:" FontSize="13" Foreground="{StaticResource MesTextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Width="100" FontSize="13"
                              SelectedValue="{Binding FilterStatus}"
                              SelectedValuePath="Content">
                        <ComboBoxItem Content=""/>
                        <ComboBoxItem Content="Waiting"/>
                        <ComboBoxItem Content="Processing"/>
                        <ComboBoxItem Content="Hold"/>
                        <ComboBoxItem Content="Completed"/>
                    </ComboBox>
                </StackPanel>

                <!-- 搜索框 -->
                <TextBox Grid.Column="2" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13" Padding="8,4" Margin="0,0,16,0"
                         Background="{StaticResource MesSurfaceBrush}"
                         Foreground="{StaticResource MesTextPrimaryBrush}"
                         BorderBrush="{StaticResource MesBorderBrush}"
                         ToolTip="搜索批次号/工单号/产品/工序">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <TextBlock Text="搜索批次号/工单号/产品/工序..."
                                                           Foreground="{StaticResource MesTextMutedBrush}"
                                                           FontSize="13" Margin="8,0"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding Text, RelativeSource={RelativeSource TemplatedParent},
                                                                       Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="8,0" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- 刷新按钮 -->
                <Button Grid.Column="3" Content="刷新" Command="{Binding RefreshCommand}"
                        FontSize="13" Padding="16,6" Margin="0,0,8,0"
                        Background="{StaticResource MesAccentBrush}" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>

                <!-- 清除过滤 -->
                <Button Grid.Column="4" Content="清除" Command="{Binding ClearFilterCommand}"
                        FontSize="13" Padding="16,6"
                        Background="{StaticResource MesSurfaceBrush}" Foreground="{StaticResource MesTextPrimaryBrush}"
                        BorderBrush="{StaticResource MesBorderBrush}" BorderThickness="1" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- 数据表格 -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding FilteredLots}" SelectedItem="{Binding SelectedLot}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="{StaticResource MesSurfaceBrush}" Foreground="{StaticResource MesTextPrimaryBrush}"
                  BorderBrush="{StaticResource MesBorderBrush}" RowBackground="{StaticResource MesCardBrush}"
                  AlternatingRowBackground="{StaticResource MesSurfaceBrush}" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" FontSize="13"
                  SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding ViewDetailCommand}"
                              CommandParameter="{Binding SelectedLot}"/>
            </DataGrid.InputBindings>
            <DataGrid.Columns>
                <DataGridTextColumn Header="批次号" Binding="{Binding LotId}" Width="140"/>
                <DataGridTextColumn Header="工单号" Binding="{Binding OrderId}" Width="120"/>
                <DataGridTextColumn Header="产品" Binding="{Binding ProductName}" Width="120"/>
                <DataGridTextColumn Header="封装" Binding="{Binding PackageTypeDisplay}" Width="80"/>
                <DataGridTextColumn Header="当前工序" Binding="{Binding CurrentStep}" Width="110"/>
                <DataGridTextColumn Header="工序序号" Binding="{Binding CurrentStepSeq}" Width="80"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90"/>
                <DataGridTextColumn Header="优先级" Binding="{Binding Priority}" Width="70"/>
                <DataGridTextColumn Header="数量" Binding="{Binding UnitCount}" Width="70"/>
                <DataGridTextColumn Header="载具" Binding="{Binding CarrierId}" Width="100"/>
                <DataGridTextColumn Header="良率" Binding="{Binding CurrentYield, StringFormat={}{0:F1}%}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
