<UserControl x:Class="MES.Modules.Production.Views.LotSplitMergeViewV2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <UserControl.Resources>
        <converters:LotLevelToBrushConverter x:Key="LotLevelToBrush"/>
        <converters:LotLevelToTextConverter x:Key="LotLevelToText"/>
        <converters:LotLevelToForegroundConverter x:Key="LotLevelToForeground"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题和模式选择 -->
            <RowDefinition Height="Auto"/>   <!-- 源批次选择 -->
            <RowDefinition Height="Auto"/>   <!-- 目标层级配置 -->
            <RowDefinition Height="Auto"/>   <!-- 可视化预览 -->
            <RowDefinition Height="*"/>      <!-- 详细配置和操作 -->
        </Grid.RowDefinitions>

        <!-- ==========================================
             标题和模式选择
        ========================================== -->
        <Border Grid.Row="0"
                Style="{DynamicResource MesCard}"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 标题 -->
                <StackPanel Grid.Column="0"
                          Orientation="Horizontal"
                          VerticalAlignment="Center">
                    <TextBlock Text="批次拆分/合并"
                              FontFamily="{DynamicResource MesFontDisplay}"
                              FontSize="24"
                              FontWeight="Bold"
                              Foreground="{DynamicResource MesTextPrimaryBrush}"
                              Margin="0,0,12,0"/>
                </StackPanel>
                
                <!-- 模式选择 -->
                <StackPanel Grid.Column="2"
                          Orientation="Horizontal"
                          VerticalAlignment="Center">
                    <RadioButton Content="拆分"
                                IsChecked="{Binding IsSplitMode}"
                                Style="{DynamicResource MesPrimaryButton}"
                                Padding="16,8"
                                Margin="0,0,8,0">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border Background="{Binding IsChecked, Converter={StaticResource BoolToBrush}, ConverterParameter={DynamicResource MesInfoBrush}, FallbackValue={DynamicResource MesBackgroundElevatedBrush}}"
                                        BorderBrush="{DynamicResource MesBorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource MesRadiusSm}"
                                        Padding="{TemplateBinding Padding}"
                                        Cursor="Hand">
                                    <TextBlock Text="拆分"
                                              FontSize="14"
                                              Foreground="{Binding IsChecked, Converter={StaticResource BoolToBrush}, ConverterParameter=White, FallbackValue={DynamicResource MesTextSecondaryBrush}}"
                                              HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                    <RadioButton Content="合并"
                                IsChecked="{Binding IsMergeMode}"
                                Style="{DynamicResource MesPrimaryButton}"
                                Padding="16,8"
                                Margin="0,0,8,0">
                        <RadioButton.Template>
                            <ControlTemplate TargetType="RadioButton">
                                <Border Background="{Binding IsChecked, Converter={StaticResource BoolToBrush}, ConverterParameter={DynamicResource MesSuccessBrush}, FallbackValue={DynamicResource MesBackgroundElevatedBrush}}"
                                        BorderBrush="{DynamicResource MesBorderDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource MesRadiusSm}"
                                        Padding="{TemplateBinding Padding}"
                                        Cursor="Hand">
                                    <TextBlock Text="合并"
                                              FontSize="14"
                                              Foreground="{Binding IsChecked, Converter={StaticResource BoolToBrush}, ConverterParameter=White, FallbackValue={DynamicResource MesTextSecondaryBrush}}"
                                              HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </RadioButton.Template>
                    </RadioButton>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==========================================
             源批次选择
        ========================================== -->
        <Border Grid.Row="1"
                Style="{DynamicResource MesCard}"
                Margin="0,0,0,16">
            <StackPanel>
                <!-- 标题 -->
                <TextBlock Text="源批次选择"
                          FontFamily="{DynamicResource MesFontDisplay}"
                          FontSize="18"
                          FontWeight="SemiBold"
                          Foreground="{DynamicResource MesTextPrimaryBrush}"
                          Margin="16,16,16,8"/>
                
                <!-- 选择区 -->
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 批次号 -->
                    <TextBlock Grid.Column="0"
                              Text="批次号:"
                              FontSize="13"
                              Foreground="{DynamicResource MesTextSecondaryBrush}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"/>
                    
                    <ComboBox Grid.Column="1"
                              Style="{DynamicResource MesComboBox}"
                              IsEditable="True"
                              SelectedValue="{Binding SourceLotId}"
                              Margin="0,0,16,0"/>
                    
                    <!-- 层级标识 -->
                    <Border Grid.Column="2"
                            Background="{Binding SourceLotLevel, Converter={StaticResource LotLevelToBrush}}"
                            CornerRadius="3"
                            Padding="8,4"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                        <TextBlock Text="{Binding SourceLotLevel, Converter={StaticResource LotLevelToText}}"
                                  FontSize="12"
                                  FontWeight="Medium"
                                  Foreground="{Binding SourceLotLevel, Converter={StaticResource LotLevelToForeground}}"/>
                    </Border>
                    
                    <!-- 信息 -->
                    <StackPanel Grid.Column="3"
                              Orientation="Horizontal"
                              VerticalAlignment="Center"
                              Margin="0,0,16,0">
                        <TextBlock Text="数量:"
                                  FontSize="13"
                                  Foreground="{DynamicResource MesTextSecondaryBrush}"
                                  Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding SourceLotQty}"
                                  FontSize="14"
                                  FontWeight="Medium"
                                  Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                    </StackPanel>
                    
                    <!-- 加载按钮 -->
                    <Button Grid.Column="6"
                            Content="加载"
                            Command="{Binding LoadSourceLotCommand}"
                            Style="{DynamicResource MesPrimaryButton}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ==========================================
             目标层级配置
        ========================================== -->
        <Border Grid.Row="2"
                Style="{DynamicResource MesCard}"
                Margin="0,0,0,16">
            <StackPanel>
                <!-- 标题 -->
                <TextBlock Text="目标层级配置"
                          FontFamily="{DynamicResource MesFontDisplay}"
                          FontSize="18"
                          FontWeight="SemiBold"
                          Foreground="{DynamicResource MesTextPrimaryBrush}"
                          Margin="16,16,16,8"/>
                
                <!-- 层级选择 -->
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 目标层级 -->
                    <TextBlock Grid.Column="0"
                              Text="目标层级:"
                              FontSize="13"
                              Foreground="{DynamicResource MesTextSecondaryBrush}"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>
                    
                    <StackPanel Grid.Column="1"
                              Orientation="Horizontal">
                        <RadioButton Content="L1 Wafer"
                                    IsChecked="{Binding TargetLevelWafer}"
                                    Style="{DynamicResource MesGhostButton}"
                                    Padding="12,6"
                                    Margin="0,0,8,0">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border Background="{Binding IsChecked, Converter={StaticResource BoolToBrush}, ConverterParameter={DynamicResource MesWaferLotLevelBrush}, FallbackValue={DynamicResource MesBackgroundElevatedBrush}}"
                                            BorderBrush="{Binding IsChecked, Converter={StaticResource BoolToThickness}, ConverterParameter={DynamicResource MesWaferLotLevelBrush}, FallbackValue={DynamicResource MesBorderDefaultBrush}}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource MesRadiusSm}"
                                            Padding="{TemplateBinding Padding}"
                                            Cursor="Hand">
                                        <TextBlock Text="L1 Wafer"
                                                  FontSize="12"
                                                  FontWeight="Medium"
                                                  Foreground="{Binding IsChecked, Converter={StaticResource BoolToBrush}, ConverterParameter=White, FallbackValue={DynamicResource MesTextSecondaryBrush}}"/>
                                    </Border>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                        <RadioButton Content="L2 Mother"
                                    IsChecked="{Binding TargetLevelMother}"
                                    Style="{DynamicResource MesGhostButton}"
                                    Padding="12,6"
                                    Margin="0,0,8,0">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border Background="{Binding IsChecked, Converter={StaticResource BoolToBrush}, ConverterParameter={DynamicResource MesMotherLotLevelBrush}, FallbackValue={DynamicResource MesBackgroundElevatedBrush}}"
                                            BorderBrush="{Binding IsChecked, Converter={StaticResource BoolToThickness}, ConverterParameter={DynamicResource MesMotherLotLevelBrush}, FallbackValue={DynamicResource MesBorderDefaultBrush}}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource MesRadiusSm}"
                                            Padding="{TemplateBinding Padding}"
                                            Cursor="Hand">
                                        <TextBlock Text="L2 Mother"
                                                  FontSize="12"
                                                  FontWeight="Medium"
                                                  Foreground="{Binding IsChecked, Converter={StaticResource BoolToBrush}, ConverterParameter=White, FallbackValue={DynamicResource MesTextSecondaryBrush}}"/>
                                    </Border>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                        <RadioButton Content="L3 Sub"
                                    IsChecked="{Binding TargetLevelSub}"
                                    Style="{DynamicResource MesGhostButton}"
                                    Padding="12,6"
                                    Margin="0,0,8,0">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border Background="{Binding IsChecked, Converter={StaticResource BoolToBrush}, ConverterParameter={DynamicResource MesSubLotLevelBrush}, FallbackValue={DynamicResource MesBackgroundElevatedBrush}}"
                                            BorderBrush="{Binding IsChecked, Converter={StaticResource BoolToThickness}, ConverterParameter={DynamicResource MesSubLotLevelBrush}, FallbackValue={DynamicResource MesBorderDefaultBrush}}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource MesRadiusSm}"
                                            Padding="{TemplateBinding Padding}"
                                            Cursor="Hand">
                                        <TextBlock Text="L3 Sub"
                                                  FontSize="12"
                                                  FontWeight="Medium"
                                                  Foreground="{Binding IsChecked, Converter={StaticResource BoolToBrush}, ConverterParameter=White, FallbackValue={DynamicResource MesTextSecondaryBrush}}"/>
                                    </Border>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                        <RadioButton Content="L4 Grade"
                                    IsChecked="{Binding TargetLevelGrade}"
                                    Style="{DynamicResource MesGhostButton}"
                                    Padding="12,6"
                                    Margin="0,0,8,0">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border Background="{Binding IsChecked, Converter={StaticResource BoolToBrush}, ConverterParameter={DynamicResource MesGradeLotLevelBrush}, FallbackValue={DynamicResource MesBackgroundElevatedBrush}}"
                                            BorderBrush="{Binding IsChecked, Converter={StaticResource BoolToThickness}, ConverterParameter={DynamicResource MesGradeLotLevelBrush}, FallbackValue={DynamicResource MesBorderDefaultBrush}}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource MesRadiusSm}"
                                            Padding="{TemplateBinding Padding}"
                                            Cursor="Hand">
                                        <TextBlock Text="L4 Grade"
                                                  FontSize="12"
                                                  FontWeight="Medium"
                                                  Foreground="{Binding IsChecked, Converter={StaticResource BoolToBrush}, ConverterParameter=#0F1521, FallbackValue={DynamicResource MesTextSecondaryBrush}}"/>
                                    </Border>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                        <RadioButton Content="L5 Mfg"
                                    IsChecked="{Binding TargetLevelMfg}"
                                    Style="{DynamicResource MesGhostButton}"
                                    Padding="12,6"
                                    Margin="0,0,8,0">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border Background="{Binding IsChecked, Converter={StaticResource BoolToBrush}, ConverterParameter={DynamicResource MesMfgIdLevelBrush}, FallbackValue={DynamicResource MesBackgroundElevatedBrush}}"
                                            BorderBrush="{Binding IsChecked, Converter={StaticResource BoolToThickness}, ConverterParameter={DynamicResource MesMfgIdLevelBrush}, FallbackValue={DynamicResource MesBorderDefaultBrush}}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource MesRadiusSm}"
                                            Padding="{TemplateBinding Padding}"
                                            Cursor="Hand">
                                        <TextBlock Text="L5 Mfg"
                                                  FontSize="12"
                                                  FontWeight="Medium"
                                                  Foreground="{Binding IsChecked, Converter={StaticResource BoolToBrush}, ConverterParameter=#0F1521, FallbackValue={DynamicResource MesTextSecondaryBrush}}"/>
                                    </Border>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                    </StackPanel>
                    
                    <!-- 拆分原因 -->
                    <StackPanel Grid.Column="2"
                              Orientation="Horizontal"
                              VerticalAlignment="Center">
                        <TextBlock Text="原因:"
                                  FontSize="13"
                                  Foreground="{DynamicResource MesTextSecondaryBrush}"
                                  Margin="0,0,8,0"/>
                        <TextBox Style="{DynamicResource MesTextBox}"
                                Width="200"
                                Text="{Binding SplitReason}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ==========================================
             可视化预览
        ========================================== -->
        <Border Grid.Row="3"
                Style="{DynamicResource MesCard}"
                Margin="0,0,0,16">
            <StackPanel>
                <!-- 标题 -->
                <TextBlock Text="转换预览"
                          FontFamily="{DynamicResource MesFontDisplay}"
                          FontSize="18"
                          FontWeight="SemiBold"
                          Foreground="{DynamicResource MesTextPrimaryBrush}"
                          Margin="16,16,16,8"/>
                
                <!-- 转换图 -->
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 源批次 -->
                    <Border Grid.Column="0"
                            Background="{Binding SourceLotLevel, Converter={StaticResource LotLevelToBrush}}"
                            CornerRadius="{DynamicResource MesRadiusMd}"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="源批次"
                                      FontSize="12"
                                      FontWeight="Medium"
                                      Foreground="White"
                                      Opacity="0.8"/>
                            <TextBlock Text="{Binding SourceLotId}"
                                      FontFamily="{DynamicResource MesFontDisplay}"
                                      FontSize="20"
                                      FontWeight="Bold"
                                      Foreground="White"
                                      Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding SourceLotLevel, Converter={StaticResource LotLevelToText}}"
                                      FontSize="14"
                                      Foreground="White"
                                      Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding SourceLotQty, StringFormat='数量: {0} pcs'}"
                                      FontSize="13"
                                      Foreground="White"
                                      Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- 箭头 -->
                    <Border Grid.Column="1"
                            Width="60"
                            Height="60"
                            CornerRadius="30"
                            Background="{DynamicResource MesInfoBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="16,0">
                        <TextBlock Text="→"
                                  FontSize="24"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- 目标批次 -->
                    <Border Grid.Column="2"
                            Background="{Binding TargetLevelBrush}"
                            CornerRadius="{DynamicResource MesRadiusMd}"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="目标批次"
                                      FontSize="12"
                                      FontWeight="Medium"
                                      Foreground="{Binding TargetLevelForeground}"
                                      Opacity="0.8"/>
                            <TextBlock Text="{Binding TargetLotIdPreview}"
                                      FontFamily="{DynamicResource MesFontDisplay}"
                                      FontSize="20"
                                      FontWeight="Bold"
                                      Foreground="{Binding TargetLevelForeground}"
                                      Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding TargetLevelLabel}"
                                      FontSize="14"
                                      Foreground="{Binding TargetLevelForeground}"
                                      Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding TargetLotQtyPreview, StringFormat='数量: {0} pcs'}"
                                      FontSize="13"
                                      Foreground="{Binding TargetLevelForeground}"
                                      Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ==========================================
             详细配置和操作
        ========================================== -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：批次配置 -->
            <Border Grid.Column="0"
                    Style="{DynamicResource MesCard}">
                <StackPanel>
                    <!-- 标题 -->
                    <TextBlock Text="拆分配置"
                              FontFamily="{DynamicResource MesFontDisplay}"
                              FontSize="18"
                              FontWeight="SemiBold"
                              Foreground="{DynamicResource MesTextPrimaryBrush}"
                              Margin="16,16,16,8"/>
                    
                    <!-- 配置表格 -->
                    <DataGrid ItemsSource="{Binding SplitTargets}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True"
                              CanUserDeleteRows="True"
                              Margin="16"
                              Height="240">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="目标批次号" Binding="{Binding TargetLotId}" Width="*"/>
                            <DataGridTextColumn Header="数量" Binding="{Binding Qty}" Width="100"/>
                            <DataGridTextColumn Header="备注" Binding="{Binding Remarks}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- 快捷按钮 -->
                    <StackPanel Orientation="Horizontal"
                                Margin="16,0,16,16">
                        <Button Content="平均拆分"
                               Command="{Binding SplitEvenlyCommand}"
                               Style="{DynamicResource MesSecondaryButton}"
                               Margin="0,0,8,0"/>
                        <Button Content="按比例拆分"
                               Command="{Binding SplitByRatioCommand}"
                               Style="{DynamicResource MesSecondaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- 右侧：操作和记录 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 操作按钮区 -->
                <Border Grid.Row="0"
                        Style="{DynamicResource MesCard}"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <!-- 标题 -->
                        <TextBlock Text="执行操作"
                                  FontFamily="{DynamicResource MesFontDisplay}"
                                  FontSize="18"
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource MesTextPrimaryBrush}"
                                  Margin="16,16,16,8"/>
                        
                        <!-- 按钮 -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="16">
                            <Button Content="执行拆分"
                                    Command="{Binding ExecuteSplitCommand}"
                                    Style="{DynamicResource MesPrimaryButton}"
                                    Margin="0,0,8,0"
                                    Height="48"
                                    Padding="32,0"/>
                            <Button Content="重置"
                                    Command="{Binding ResetCommand}"
                                    Style="{DynamicResource MesSecondaryButton}"
                                    Height="48"
                                    Padding="24,0"/>
                        </StackPanel>
                        
                        <!-- 验证信息 -->
                        <Border Background="{DynamicResource MesBackgroundElevatedBrush}"
                                CornerRadius="{DynamicResource MesRadiusSm}"
                                Padding="12"
                                Margin="16,0,16,16">
                            <TextBlock Text="{Binding ValidationMessage}"
                                      FontSize="13"
                                      Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- 历史记录 -->
                <Border Grid.Row="1"
                        Style="{DynamicResource MesCard}">
                    <StackPanel>
                        <!-- 标题 -->
                        <TextBlock Text="历史记录"
                                  FontFamily="{DynamicResource MesFontDisplay}"
                                  FontSize="18"
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource MesTextPrimaryBrush}"
                                  Margin="16,16,16,8"/>
                        
                        <!-- 记录表格 -->
                        <DataGrid ItemsSource="{Binding HistoryRecords}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Style="{DynamicResource MesDataGrid}"
                                  RowStyle="{DynamicResource MesDataGridRow}"
                                  ColumnHeaderStyle="{DynamicResource MesDataGridColumnHeader}"
                                  Margin="16">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding Time, StringFormat='{}{0:HH:mm:ss}'}" Width="100"/>
                                <DataGridTextColumn Header="操作" Binding="{Binding Action}" Width="80"/>
                                <DataGridTextColumn Header="源批次" Binding="{Binding SourceLot}" Width="120"/>
                                <DataGridTextColumn Header="目标批次" Binding="{Binding TargetLot}" Width="120"/>
                                <DataGridTextColumn Header="数量" Binding="{Binding Qty}" Width="80"/>
                                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
