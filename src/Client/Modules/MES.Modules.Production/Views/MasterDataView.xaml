<UserControl x:Class="MES.Modules.Production.Views.MasterDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Navigation Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="主数据管理" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,16"/>
            <WrapPanel>
                <Button Content="产品管理" Command="{Binding NavigateCommand}" CommandParameter="Product"
                        Style="{DynamicResource NavButtonStyle}" Margin="0,0,8,4"/>
                <Button Content="工艺路线" Command="{Binding NavigateCommand}" CommandParameter="Route"
                        Style="{DynamicResource NavButtonStyle}" Margin="0,0,8,4"/>
                <Button Content="设备管理" Command="{Binding NavigateCommand}" CommandParameter="Equipment"
                        Style="{DynamicResource NavButtonStyle}" Margin="0,0,8,4"/>
                <Button Content="载具管理" Command="{Binding NavigateCommand}" CommandParameter="Carrier"
                        Style="{DynamicResource NavButtonStyle}" Margin="0,0,8,4"/>
                <Button Content="Recipe" Command="{Binding NavigateCommand}" CommandParameter="Recipe"
                        Style="{DynamicResource NavButtonStyle}" Margin="0,0,8,4"/>
                <Button Content="物料管理" Command="{Binding NavigateCommand}" CommandParameter="Material"
                        Style="{DynamicResource NavButtonStyle}" Margin="0,0,8,4"/>
                <Button Content="客户管理" Command="{Binding NavigateCommand}" CommandParameter="Customer"
                        Style="{DynamicResource NavButtonStyle}" Margin="0,0,8,4"/>
                <Button Content="原因代码" Command="{Binding NavigateCommand}" CommandParameter="ReasonCode"
                        Style="{DynamicResource NavButtonStyle}" Margin="0,0,8,4"/>
                <Button Content="缺陷代码" Command="{Binding NavigateCommand}" CommandParameter="DefectCode"
                        Style="{DynamicResource NavButtonStyle}" Margin="0,0,8,4"/>
                <Button Content="良率规则" Command="{Binding NavigateCommand}" CommandParameter="YieldRule"
                        Style="{DynamicResource NavButtonStyle}" Margin="0,0,8,4"/>
                <Button Content="报警规则" Command="{Binding NavigateCommand}" CommandParameter="AlarmRule"
                        Style="{DynamicResource NavButtonStyle}" Margin="0,0,8,4"/>
                <Button Content="报废规则" Command="{Binding NavigateCommand}" CommandParameter="ScrapRule"
                        Style="{DynamicResource NavButtonStyle}" Margin="0,0,8,4"/>
            </WrapPanel>
        </StackPanel>

        <!-- Content Area -->
        <Border Grid.Row="1" Background="{DynamicResource MesCardBrush}" CornerRadius="8" Padding="16">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>
    </Grid>
</UserControl>
