<UserControl x:Class="MES.Modules.Production.Views.MaterialManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 + 操作按钮 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="物料管理" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,24,0"
                       VerticalAlignment="Center"/>
            <Button Content="新增" Command="{Binding AddCommand}"
                    Style="{DynamicResource MesPrimaryButton}" Margin="0,0,8,0"/>
            <Button Content="编辑" Command="{Binding EditCommand}"
                    Style="{DynamicResource MesSecondaryButton}" Margin="0,0,8,0"/>
            <Button Content="删除" Command="{Binding DeleteCommand}"
                    Style="{DynamicResource MesDangerButton}" Margin="0,0,8,0"/>
            <Button Content="刷新" Command="{Binding RefreshCommand}"
                    Style="{DynamicResource MesSecondaryButton}"/>
        </StackPanel>

        <!-- 数据表格 -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Materials}" SelectedItem="{Binding SelectedMaterial}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Style="{DynamicResource MesDataGrid}"
                  SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="物料ID" Binding="{Binding MaterialId}" Width="120"/>
                <DataGridTextColumn Header="物料名称" Binding="{Binding MaterialName}" Width="*"/>
                <DataGridTextColumn Header="物料编码" Binding="{Binding MaterialCode}" Width="120"/>
                <DataGridTextColumn Header="类型" Binding="{Binding MaterialType}" Width="100"/>
                <DataGridTextColumn Header="供应商" Binding="{Binding Supplier}" Width="120"/>
                <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="60"/>
                <DataGridTextColumn Header="最小库存" Binding="{Binding MinStock}" Width="80"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
