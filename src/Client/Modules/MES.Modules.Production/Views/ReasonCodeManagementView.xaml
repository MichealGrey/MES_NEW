<UserControl x:Class="MES.Modules.Production.Views.ReasonCodeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="原因代码管理" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock Text="分类:" Foreground="{DynamicResource MesTextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <ComboBox x:Name="cmbFilterCategory" Width="120" Height="28"
                      SelectionChanged="cmbFilterCategory_SelectionChanged">
                <ComboBoxItem Content="全部" IsSelected="True"/>
                <ComboBoxItem Content="Material"/>
                <ComboBoxItem Content="Equipment"/>
                <ComboBoxItem Content="Process"/>
                <ComboBoxItem Content="Quality"/>
                <ComboBoxItem Content="Personnel"/>
                <ComboBoxItem Content="Other"/>
            </ComboBox>
            <TextBlock Text="适用操作:" Foreground="{DynamicResource MesTextSecondaryBrush}" VerticalAlignment="Center" Margin="16,0,4,0"/>
            <ComboBox x:Name="cmbFilterApplicableTo" Width="100" Height="28"
                      SelectionChanged="cmbFilterApplicableTo_SelectionChanged">
                <ComboBoxItem Content="全部" IsSelected="True"/>
                <ComboBoxItem Content="Hold"/>
                <ComboBoxItem Content="Scrap"/>
                <ComboBoxItem Content="Rework"/>
                <ComboBoxItem Content="Alarm"/>
            </ComboBox>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="新增" Command="{Binding AddCommand}"
                    Style="{DynamicResource MesPrimaryButton}"/>
            <Button Content="编辑" Command="{Binding EditCommand}"
                    Style="{DynamicResource MesSecondaryButton}" Margin="8,0,0,0"/>
            <Button Content="启用/停用" Command="{Binding ToggleEnabledCommand}"
                    Style="{DynamicResource MesSecondaryButton}" Margin="8,0,0,0"/>
            <Button Content="刷新" Command="{Binding RefreshCommand}"
                    Style="{DynamicResource MesSecondaryButton}" Margin="8,0,0,0"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding ReasonCodes}" SelectedItem="{Binding SelectedReasonCode}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Style="{DynamicResource MesDataGrid}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="原因代码" Binding="{Binding ReasonCodeId}" Width="140"/>
                <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="100"/>
                <DataGridTextColumn Header="子分类" Binding="{Binding SubCategory}" Width="100"/>
                <DataGridTextColumn Header="适用操作" Binding="{Binding ApplicableTo}" Width="100"/>
                <DataGridTextColumn Header="原因描述" Binding="{Binding ReasonText}" Width="*"/>
                <DataGridTemplateColumn Header="启用" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsEnabled}" HorizontalAlignment="Center" IsHitTestVisible="False"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
