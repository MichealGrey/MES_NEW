<UserControl x:Class="MES.Modules.Production.Views.RecipeManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{StaticResource MesBackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 + 操作按钮 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="配方管理" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource MesTextPrimaryBrush}" Margin="0,0,24,0"
                       VerticalAlignment="Center"/>
            <Button Content="新增" Command="{Binding AddCommand}"
                    FontSize="13" Padding="16,6" Margin="0,0,8,0"
                    Background="{StaticResource MesAccentBrush}" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Content="编辑" Command="{Binding EditCommand}"
                    FontSize="13" Padding="16,6" Margin="0,0,8,0"
                    Background="{StaticResource MesSurfaceBrush}" Foreground="{StaticResource MesTextPrimaryBrush}"
                    BorderBrush="{StaticResource MesBorderBrush}" BorderThickness="1" Cursor="Hand"/>
            <Button Content="切换状态" Command="{Binding ToggleStatusCommand}"
                    FontSize="13" Padding="16,6" Margin="0,0,8,0"
                    Background="#A6E3A1" Foreground="#1E1E2E"
                    BorderThickness="0" Cursor="Hand"/>
            <Button Content="刷新" Command="{Binding RefreshCommand}"
                    FontSize="13" Padding="16,6"
                    Background="{StaticResource MesSurfaceBrush}" Foreground="{StaticResource MesTextPrimaryBrush}"
                    BorderBrush="{StaticResource MesBorderBrush}" BorderThickness="1" Cursor="Hand"/>
        </StackPanel>

        <!-- 数据表格 -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Recipes}" SelectedItem="{Binding SelectedRecipe}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="{StaticResource MesSurfaceBrush}" Foreground="{StaticResource MesTextPrimaryBrush}"
                  BorderBrush="{StaticResource MesBorderBrush}" RowBackground="{StaticResource MesCardBrush}"
                  AlternatingRowBackground="{StaticResource MesSurfaceBrush}" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" FontSize="13"
                  SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="配方ID" Binding="{Binding RecipeId}" Width="120"/>
                <DataGridTextColumn Header="配方名称" Binding="{Binding RecipeName}" Width="*"/>
                <DataGridTextColumn Header="设备组" Binding="{Binding EquipmentGroup}" Width="100"/>
                <DataGridTextColumn Header="工艺步骤" Binding="{Binding StepCode}" Width="80"/>
                <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="60"/>
                <DataGridCheckBoxColumn Header="是否激活" Binding="{Binding IsActive}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
