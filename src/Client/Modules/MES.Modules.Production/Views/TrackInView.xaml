<UserControl x:Class="MES.Modules.Production.Views.TrackInView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             xmlns:local="clr-namespace:MES.Modules.Production.ViewModels"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource MesTextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource MesTextSecondaryBrush}"/>
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource MesTextPrimaryBrush}"/>
        </Style>

        <Style x:Key="InfoValueHighlight" TargetType="TextBlock" BasedOn="{StaticResource InfoValueStyle}">
            <Setter Property="Foreground" Value="{DynamicResource MesInfoBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <!-- 全局加载遮罩层 -->
    <Grid>
        <!-- 主内容 -->
        <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- 标题栏 -->
                    <RowDefinition Height="Auto"/>   <!-- 快速扫描区 -->
                    <RowDefinition Height="Auto"/>   <!-- Hold 告警横幅 -->
                    <RowDefinition Height="Auto"/>   <!-- 批次信息卡片 -->
                    <RowDefinition Height="Auto"/>   <!-- 校验结果 -->
                    <RowDefinition Height="Auto"/>   <!-- 操作按钮 -->
                    <RowDefinition Height="Auto"/>   <!-- 最近操作记录 -->
                    <RowDefinition Height="Auto"/>   <!-- 操作员信息栏 -->
                </Grid.RowDefinitions>

                <!-- Row 0: 标题与模式切换 -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding PageTitle}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource MesTextPrimaryBrush}"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <RadioButton Content="进站"
                                     IsChecked="{Binding IsTrackInMode}"
                                     FontSize="14"
                                     Foreground="{DynamicResource MesTextPrimaryBrush}"
                                     Margin="0,0,16,0"/>
                        <RadioButton Content="出站"
                                     IsChecked="{Binding IsTrackOutMode}"
                                     FontSize="14"
                                     Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                    </StackPanel>
                </Grid>

                <!-- Row 1: 快速扫描区 -->
                <Border Grid.Row="1"
                        Style="{DynamicResource MesCard}"
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="快速扫描区（条码枪扫描后自动查询）"
                                   Style="{StaticResource SectionTitleStyle}"/>

                        <!-- 扫描输入行 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 批次号 -->
                            <TextBlock Grid.Column="0"
                                       Text="批次号:"
                                       Style="{StaticResource InfoLabelStyle}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <TextBox Grid.Column="1"
                                     x:Name="LotIdTextBox"
                                     Text="{Binding LotId, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource MesTextBox}"
                                     ToolTip="扫描批次号条码，按 Enter 查询">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding ScanLotCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>

                            <!-- 设备号 -->
                            <TextBlock Grid.Column="2"
                                       Text="设备号:"
                                       Style="{StaticResource InfoLabelStyle}"
                                       VerticalAlignment="Center"
                                       Margin="16,0,8,0"/>
                            <TextBox Grid.Column="3"
                                     Text="{Binding EquipmentId, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource MesTextBox}"
                                     ToolTip="扫描设备条码或手动输入">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding ScanLotCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>

                            <!-- 载具号 -->
                            <TextBlock Grid.Column="4"
                                       Text="载具号:"
                                       Style="{StaticResource InfoLabelStyle}"
                                       VerticalAlignment="Center"
                                       Margin="16,0,8,0"/>
                            <TextBox Grid.Column="5"
                                     Text="{Binding CarrierId, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource MesTextBox}"
                                     ToolTip="扫描载具(FOUP/Cassette/Frame)条码">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding ScanLotCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>

                            <!-- 手动查询按钮 -->
                            <Button Grid.Column="6"
                                    Content="查询"
                                    Command="{Binding ScanLotCommand}"
                                    Style="{DynamicResource MesPrimaryButton}"
                                    Margin="16,0,0,0"
                                    ToolTip="或直接按 Enter 查询"/>
                        </Grid>

                        <!-- 快捷键提示 -->
                        <TextBlock Text="Enter=查询  |  Ctrl+Enter=确认  |  Esc=取消  |  F8=强制操作"
                                   FontSize="11"
                                   Foreground="{DynamicResource MesTextTertiaryBrush}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Row 2: Hold 告警横幅 -->
                <Border Grid.Row="2"
                        Background="{DynamicResource MesDangerBrush}"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,16"
                        Visibility="{Binding IsHoldBannerVisible, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="HOLD"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesTextInverseBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding HoldBannerText}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource MesTextInverseBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding HoldDetailText}"
                                       FontSize="12"
                                       Foreground="{DynamicResource MesTextInverseBrush}"
                                       Opacity="0.8"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding HoldDurationText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource MesTextInverseBrush}"
                                   Opacity="0.8"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Row 3: 批次信息卡片 -->
                <Border Grid.Row="3"
                        Style="{DynamicResource MesCard}"
                        Padding="16"
                        Margin="0,0,0,16"
                        Visibility="{Binding IsLotInfoVisible, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <!-- 标题行 -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="批次信息"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <!-- 设备状态指示 -->
                            <Border Grid.Column="2"
                                    CornerRadius="12"
                                    Padding="10,4"
                                    Background="{DynamicResource MesSurfaceBrush}"
                                    BorderBrush="{DynamicResource MesBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="10" Height="10"
                                             Fill="{Binding EquipmentStatusBrush}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding EquipmentStatusDisplay}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding EquipmentStatusBrush}"/>
                                    <TextBlock Text=" | "
                                               FontSize="12"
                                               Foreground="{DynamicResource MesTextTertiaryBrush}"
                                               Margin="4,0"/>
                                    <TextBlock Text="{Binding EquipmentId}"
                                               FontSize="12"
                                               Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 批次信息网格 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 第一行 -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="工单号:" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding CurrentLotInfo.OrderId}"
                                           Style="{StaticResource InfoValueHighlight}"
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="产品型号:" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding CurrentLotInfo.ProductId}"
                                           Style="{StaticResource InfoValueStyle}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                                <TextBlock Text="客户:" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding CustomerName}"
                                           Style="{StaticResource InfoValueStyle}" Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- 第二行 -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="数量:" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding CurrentLotInfo.UnitCount}"
                                           Style="{StaticResource InfoValueStyle}" Margin="8,0,0,0"/>
                                <TextBlock Text="{Binding UnitLabel}"
                                           Style="{StaticResource InfoLabelStyle}" Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="当前工序:" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding CurrentLotInfo.CurrentStep}"
                                           Style="{StaticResource InfoValueStyle}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="批次状态:" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding CurrentLotInfo.Status}"
                                           Style="{StaticResource InfoValueStyle}" Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- 第三行 -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="优先级:" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding CurrentLotInfo.Priority}"
                                           Style="{StaticResource InfoValueStyle}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="管芯:" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding CurrentLotInfo.DieName}"
                                           Style="{StaticResource InfoValueStyle}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="封装形式:" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding CurrentLotInfo.PackageTypeDisplay}"
                                           Style="{StaticResource InfoValueStyle}" Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- 第四行 -->
                            <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="测试程式:" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding RecipeName}"
                                           Style="{StaticResource InfoValueStyle}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="目标良率:" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding TargetYieldDisplay}"
                                           Style="{StaticResource InfoValueStyle}" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="条带数:" Style="{StaticResource InfoLabelStyle}"/>
                                <TextBlock Text="{Binding CurrentLotInfo.StripCount}"
                                           Style="{StaticResource InfoValueStyle}" Margin="8,0,0,0"/>
                                <TextBlock Text=" strips"
                                           Style="{StaticResource InfoLabelStyle}" Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- 分隔线 -->
                        <Rectangle Height="1" Fill="{DynamicResource MesDividerBrush}" Margin="0,12"/>

                        <!-- 载具信息行 -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="载具:"
                                       Style="{StaticResource InfoLabelStyle}"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1"
                                    CornerRadius="4"
                                    Padding="8,2"
                                    Background="{DynamicResource MesSurfaceBrush}"
                                    BorderBrush="{DynamicResource MesBorderBrush}"
                                    BorderThickness="1"
                                    Margin="8,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding CurrentLotInfo.CarrierTypeDisplay}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource MesInfoBrush}"/>
                                    <TextBlock Text=" / "
                                               FontSize="12"
                                               Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                                    <TextBlock Text="{Binding CurrentLotInfo.CarrierId}"
                                               FontSize="12"
                                               Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- 晶圆来源 -->
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <TextBlock Text="晶圆来源:" Style="{StaticResource InfoLabelStyle}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding WaferSourceDisplay}"
                                           Style="{StaticResource InfoValueStyle}"
                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Row 4: 校验结果 -->
                <Border Grid.Row="4"
                        Style="{DynamicResource MesCard}"
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="校验结果" Style="{StaticResource SectionTitleStyle}"/>

                        <!-- 失败汇总横幅 -->
                        <Border Background="{DynamicResource MesDangerBrush}"
                                CornerRadius="8"
                                Padding="12,8"
                                Margin="0,0,0,12"
                                Visibility="{Binding HasCriticalFailures, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="X"
                                           FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesTextInverseBrush}" VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding FailureSummaryText}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource MesTextInverseBrush}" VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- 校验列表 -->
                        <DataGrid ItemsSource="{Binding ValidationResults}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Style="{DynamicResource MesDataGrid}"
                                  GridLinesVisibility="Horizontal"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  Height="200"
                                  RowHeight="32">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="校验项" Binding="{Binding CheckItem}" Width="150"/>
                                <DataGridTemplateColumn Header="结果" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding StatusIcon}"
                                                           FontSize="16"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding StatusDisplay}"
                                                           Margin="4,0,0,0"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource MesTextPrimaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Pass">
                                                                    <Setter Property="Foreground" Value="{DynamicResource MesSuccessBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Warning">
                                                                    <Setter Property="Foreground" Value="{DynamicResource MesWarningBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Fail">
                                                                    <Setter Property="Foreground" Value="{DynamicResource MesDangerBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="说明" Binding="{Binding Message}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Row 5: 操作按钮区 -->
                <Border Grid.Row="5"
                        Background="Transparent"
                        Padding="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="确认进站"
                                Command="{Binding ConfirmCommand}"
                                Style="{DynamicResource MesPrimaryButton}"
                                Margin="0,0,12,0"
                                ToolTip="Ctrl+Enter"/>
                        <Button Content="取消"
                                Command="{Binding CancelCommand}"
                                Style="{DynamicResource MesSecondaryButton}"
                                Margin="0,0,12,0"
                                ToolTip="Esc"/>
                        <Button Content="强制操作"
                                Command="{Binding ForceConfirmCommand}"
                                Style="{DynamicResource MesDangerButton}"
                                Visibility="{Binding CanForceConfirm, Converter={StaticResource BoolToVis}}"
                                ToolTip="F8"/>
                    </StackPanel>
                </Border>

                <!-- Row 6: 最近操作记录 -->
                <Border Grid.Row="6"
                        Style="{DynamicResource MesCard}"
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="最近操作记录" Style="{StaticResource SectionTitleStyle}"/>
                        <DataGrid ItemsSource="{Binding OperationHistory}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Style="{DynamicResource MesDataGrid}"
                                  GridLinesVisibility="Horizontal"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  Height="160">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding TimeDisplay}" Width="100"/>
                                <DataGridTextColumn Header="批次号" Binding="{Binding LotId}" Width="120"/>
                                <DataGridTextColumn Header="操作人" Binding="{Binding Operator}" Width="100"/>
                                <DataGridTextColumn Header="类型" Binding="{Binding OperationType}" Width="80"/>
                                <DataGridTextColumn Header="设备" Binding="{Binding EquipmentId}" Width="100"/>
                                <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Row 7: 操作员信息栏 -->
                <Border Grid.Row="7"
                        Style="{DynamicResource MesCard}"
                        Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="操作员:"
                                   Style="{StaticResource InfoLabelStyle}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CurrentOperator}"
                                   Style="{StaticResource InfoValueStyle}"
                                   Margin="8,0,20,0"
                                   VerticalAlignment="Center"/>

                        <!-- Redis 数据源状态 -->
                        <Border Grid.Column="3"
                                CornerRadius="10"
                                Padding="8,2"
                                Background="{DynamicResource MesSurfaceBrush}"
                                BorderBrush="{DynamicResource MesBorderBrush}"
                                BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8"
                                         Fill="{DynamicResource MesSuccessBrush}"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Redis"
                                           FontSize="11"
                                           Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- 记录数 -->
                        <TextBlock Grid.Column="4"
                                   Text="{Binding HistoryCountDisplay}"
                                   FontSize="11"
                                   Foreground="{DynamicResource MesTextTertiaryBrush}"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- 加载遮罩层 -->
        <Border Background="{DynamicResource MesOverlayBrush}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Width="200" Height="4"
                             Foreground="{DynamicResource MesInfoBrush}"
                             Background="{DynamicResource MesSurfaceBrush}"/>
                <TextBlock Text="正在查询，请稍候..."
                           FontSize="14"
                           Foreground="{DynamicResource MesTextPrimaryBrush}"
                           Margin="0,12,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
