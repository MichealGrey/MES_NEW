<UserControl x:Class="MES.Modules.Production.Views.WipOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 标题 -->
            <RowDefinition Height="Auto"/>   <!-- 汇总统计 -->
            <RowDefinition Height="Auto"/>   <!-- 过滤栏 -->
            <RowDefinition Height="*"/>      <!-- 工序卡片 -->
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="WIP总览" FontSize="24" FontWeight="SemiBold"
                   Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,16"/>

        <!-- 汇总统计行 -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="总批次" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Summary.TotalLots}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="总数量" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Summary.TotalQty}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Urgent" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Summary.UrgentLots}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDangerBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Hold" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Summary.HoldLots}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDangerBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="等待中" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Summary.WaitingLots}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesWarningBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="生产中" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Summary.ProcessingLots}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesInfoBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="平均良率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Summary.AvgYield, StringFormat={}{0:F1}%}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesSuccessBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Assemble" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Summary.AssembleLots}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesInfoBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="Test" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding Summary.TestLots}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesSuccessBrush}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- 过滤栏 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 工艺阶段 Tab -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="阶段:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <RadioButton Content="全部"
                                 IsChecked="{Binding SelectedStage, Converter={StaticResource EnumMatch}, ConverterParameter=ALL}"
                                 FontSize="13" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,12,0"/>
                    <RadioButton Content="Assemble"
                                 IsChecked="{Binding SelectedStage, Converter={StaticResource EnumMatch}, ConverterParameter=Assemble}"
                                 FontSize="13" Foreground="{DynamicResource MesInfoBrush}" Margin="0,0,12,0"/>
                    <RadioButton Content="Test"
                                 IsChecked="{Binding SelectedStage, Converter={StaticResource EnumMatch}, ConverterParameter=Test}"
                                 FontSize="13" Foreground="{DynamicResource MesSuccessBrush}" Margin="0,0,12,0"/>
                </StackPanel>

                <!-- 刷新按钮 -->
                <Button Grid.Column="2" Content="刷新" Command="{Binding RefreshCommand}"
                        Style="{DynamicResource MesPrimaryButton}"/>
            </Grid>
        </Border>

        <!-- 工序卡片 -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding WipByStep}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{DynamicResource MesCard}" Padding="16"
                                Margin="6" MinWidth="180" MaxWidth="220">
                            <StackPanel>
                                <!-- 工序名称 -->
                                <TextBlock Text="{Binding StepName}" Foreground="{DynamicResource MesTextPrimaryBrush}"
                                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                                <!-- WIP 数量 -->
                                <TextBlock FontSize="28" FontWeight="SemiBold" Margin="0,0,0,4"
                                           Foreground="{DynamicResource MesInfoBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} 批次">
                                            <Binding Path="WipCount"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>

                                <!-- 状态分布 -->
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                                    <TextBlock Text="等待: " FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                                    <TextBlock Text="{Binding WaitingCount}" FontSize="11"
                                               Foreground="{DynamicResource MesWarningBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="  生产: " FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}" Margin="8,0,0,0"/>
                                    <TextBlock Text="{Binding ProcessingCount}" FontSize="11"
                                               Foreground="{DynamicResource MesInfoBrush}" FontWeight="SemiBold"/>
                                </StackPanel>

                                <!-- Urgent / Hold -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                    <TextBlock Text="Urgent: " FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}"/>
                                    <TextBlock Text="{Binding UrgentCount}" FontSize="11"
                                               Foreground="{DynamicResource MesDangerBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="  Hold: " FontSize="11" Foreground="{DynamicResource MesTextTertiaryBrush}" Margin="8,0,0,0"/>
                                    <TextBlock Text="{Binding HoldCount}" FontSize="11"
                                               Foreground="{DynamicResource MesDangerBrush}" FontWeight="SemiBold"/>
                                </StackPanel>

                                <!-- 良率 -->
                                <TextBlock FontSize="11" Foreground="{DynamicResource MesSuccessBrush}" Margin="0,4,0,0">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="平均良率: {0:F1}%">
                                            <Binding Path="AvgYield"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
