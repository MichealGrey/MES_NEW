<UserControl x:Class="MES.Modules.ReportCenter.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
    xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
    prism:ViewModelLocator.AutoWireViewModel="True"
    Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibility"/>
    </UserControl.Resources>

    <ScrollViewer Margin="24" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">
            <!-- 标题栏 -->
            <Grid Margin="0,0,0,20">
                <TextBlock Text="报表中心 - 综合看板" FontSize="24" FontWeight="SemiBold"
                           Foreground="{DynamicResource MesTextPrimaryBrush}" VerticalAlignment="Center"/>
                <Button Content="刷新" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{DynamicResource MesPrimaryButton}" Command="{Binding RefreshCommand}" Padding="20,8"/>
            </Grid>

            <!-- 加载中提示 -->
            <TextBlock Text="数据加载中..." Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                       Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,0,16" FontSize="13"/>
            <TextBlock Text="{Binding ErrorMessage}" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"
                       Foreground="{DynamicResource MesDangerBrush}" Margin="0,0,0,16" FontSize="13"/>

            <!-- KPI卡片：工单 -->
            <TextBlock Text="工单概览" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}"
                       Margin="0,0,0,12"/>
            <WrapPanel Margin="0,0,0,20">
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="总工单" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Summary.TotalProductionOrders}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="已完成" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Summary.CompletedOrders}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesSuccessBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="进行中" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Summary.InProgressOrders}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesInfoBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="待排产" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Summary.PendingOrders}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesWarningBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="逾期" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Summary.OverdueOrders}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDangerBrush}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- KPI卡片：批次与良率 -->
            <TextBlock Text="批次与良率" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}"
                       Margin="0,0,0,12"/>
            <WrapPanel Margin="0,0,0,20">
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="总批次" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Summary.TotalLots}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="活跃批次" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Summary.ActiveLots}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesInfoBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="综合良率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Summary.OverallYield, StringFormat={}{0:P2}}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesSuccessBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="目标良率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Summary.TargetYield, StringFormat={}{0:P2}}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesWarningBrush}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <!-- KPI卡片：设备与质量 -->
            <TextBlock Text="设备与质量" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}"
                       Margin="0,0,0,12"/>
            <WrapPanel>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="运行中设备" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesSuccessBrush}">
                            <Run Text="{Binding Summary.EquipmentRunning}"/><Run Text="/"/><Run Text="{Binding Summary.EquipmentTotal}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="设备运行率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding EquipmentRunRate, StringFormat={}{0:P1}}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesInfoBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="质量告警" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Summary.QualityAlerts}" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MesDangerBrush}"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
