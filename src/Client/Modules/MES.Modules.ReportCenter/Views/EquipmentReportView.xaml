<UserControl x:Class="MES.Modules.ReportCenter.Views.EquipmentReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="设备报表" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource MesTextPrimaryBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OEE趋势" Style="{DynamicResource MesPrimaryButton}" Command="{Binding LoadTrendCommand}"
                        Margin="0,0,8,0" Padding="16,6"/>
                <Button Content="清除筛选" Style="{DynamicResource MesSecondaryButton}" Command="{Binding ClearFilterCommand}"
                        Margin="0,0,8,0" Padding="16,6"/>
                <Button Content="刷新" Style="{DynamicResource MesPrimaryButton}" Command="{Binding RefreshCommand}"
                        Padding="16,6"/>
            </StackPanel>
        </Grid>

        <!-- 统计卡片 -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="设备总数" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalEquipment}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="运行中" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding RunningCount}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesSuccessBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="空闲" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding IdleCount}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesInfoBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="平均OEE" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding AvgOEE, StringFormat={}{0:P2}}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesSuccessBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="平均稼动率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding AvgAvailability, StringFormat={}{0:P2}}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesInfoBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="告警总数" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalAlarmCount}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDangerBrush}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- 过滤栏 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 日期范围 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="日期:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                    <DatePicker Width="120" SelectedDate="{Binding StartDate}" FontSize="13" Style="{DynamicResource MesDatePicker}"/>
                    <TextBlock Text="至" VerticalAlignment="Center" Margin="4,0"/>
                    <DatePicker Width="120" SelectedDate="{Binding EndDate}" FontSize="13" Style="{DynamicResource MesDatePicker}"/>
                </StackPanel>

                <!-- 设备编号 -->
                <TextBlock Grid.Row="0" Grid.Column="2" Text="设备:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding FilterEquipmentNo, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource MesTextBox}" Margin="0,0,16,0" FontSize="13"/>

                <!-- 状态 -->
                <TextBlock Grid.Row="0" Grid.Column="4" Text="状态:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="0" Grid.Column="5" Width="100" SelectedValue="{Binding FilterStatus}"
                          Style="{DynamicResource MesComboBox}" FontSize="13">
                    <ComboBoxItem Content="全部"/>
                    <ComboBoxItem Content="Running"/>
                    <ComboBoxItem Content="Idle"/>
                    <ComboBoxItem Content="Down"/>
                    <ComboBoxItem Content="Maintenance"/>
                </ComboBox>

                <!-- 搜索 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="搜索:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource MesTextBox}" FontSize="13" Grid.ColumnSpan="5"
                         ToolTip="搜索设备名称或编号"/>
            </Grid>
        </Border>

        <!-- 设备报表表格 -->
        <DataGrid Grid.Row="3" Style="{DynamicResource MesDataGrid}"
                  ItemsSource="{Binding EquipmentReports}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="300"
                  CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="日期" Binding="{Binding ReportDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="设备编号" Binding="{Binding EquipmentNo}" Width="100"/>
                <DataGridTextColumn Header="设备名称" Binding="{Binding EquipmentName}" Width="140"/>
                <DataGridTextColumn Header="OEE" Binding="{Binding OEE, StringFormat={}{0:P2}}" Width="80"/>
                <DataGridTextColumn Header="稼动率" Binding="{Binding Availability, StringFormat={}{0:P2}}" Width="80"/>
                <DataGridTextColumn Header="性能率" Binding="{Binding Performance, StringFormat={}{0:P2}}" Width="80"/>
                <DataGridTextColumn Header="质量率" Binding="{Binding QualityRate, StringFormat={}{0:P2}}" Width="80"/>
                <DataGridTextColumn Header="运行时间(分)" Binding="{Binding TotalRunTime}" Width="100"/>
                <DataGridTextColumn Header="空闲时间(分)" Binding="{Binding TotalIdleTime}" Width="100"/>
                <DataGridTextColumn Header="停机时间(分)" Binding="{Binding TotalDownTime}" Width="100"/>
                <DataGridTextColumn Header="加工数" Binding="{Binding TotalProcessQty}" Width="80"/>
                <DataGridTextColumn Header="告警数" Binding="{Binding AlarmCount}" Width="80"/>
                <DataGridTextColumn Header="主要告警" Binding="{Binding TopAlarmType}" Width="120"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- OEE趋势数据 -->
        <TextBlock Grid.Row="4" Text="OEE趋势数据" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}"
                   Margin="0,20,0,12"/>
        <DataGrid Style="{DynamicResource MesDataGrid}"
                  ItemsSource="{Binding EquipmentTrend}"
                  AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="200"
                  CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="日期" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="120"/>
                <DataGridTextColumn Header="设备编号" Binding="{Binding EquipmentNo}" Width="120"/>
                <DataGridTextColumn Header="OEE" Binding="{Binding OEE, StringFormat={}{0:P2}}" Width="100"/>
                <DataGridTextColumn Header="稼动率" Binding="{Binding Availability, StringFormat={}{0:P2}}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
