<UserControl x:Class="MES.Modules.ReportCenter.Views.ProductionReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="生产报表" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource MesTextPrimaryBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="清除筛选" Style="{DynamicResource MesSecondaryButton}" Command="{Binding ClearFilterCommand}"
                        Margin="0,0,8,0" Padding="16,6"/>
                <Button Content="刷新" Style="{DynamicResource MesPrimaryButton}" Command="{Binding RefreshCommand}"
                        Padding="16,6"/>
            </StackPanel>
        </Grid>

        <!-- 统计卡片 -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="总记录数" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalReports}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="平均良率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding AvgYieldRate, StringFormat={}{0:P2}}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesSuccessBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="平均效率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding AvgEfficiency, StringFormat={}{0:P2}}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesInfoBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="总投入" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalInputQty}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="良品数" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalGoodQty}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesSuccessBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="报废数" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalScrapQty}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDangerBrush}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- 过滤栏 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 日期范围 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="日期:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                    <DatePicker Width="120" SelectedDate="{Binding StartDate}" FontSize="13" Style="{DynamicResource MesDatePicker}"/>
                    <TextBlock Text="至" VerticalAlignment="Center" Margin="4,0"/>
                    <DatePicker Width="120" SelectedDate="{Binding EndDate}" FontSize="13" Style="{DynamicResource MesDatePicker}"/>
                </StackPanel>

                <!-- 产品 -->
                <TextBlock Grid.Row="0" Grid.Column="2" Text="产品:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding FilterProduct, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource MesTextBox}" Margin="0,0,16,0" FontSize="13" ToolTip="产品名称或编号"/>

                <!-- 班次 -->
                <TextBlock Grid.Row="0" Grid.Column="4" Text="班次:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="0" Grid.Column="5" Width="100" SelectedValue="{Binding FilterShift}"
                          Style="{DynamicResource MesComboBox}" FontSize="13">
                    <ComboBoxItem Content="全部"/>
                    <ComboBoxItem Content="白班"/>
                    <ComboBoxItem Content="夜班"/>
                </ComboBox>

                <!-- 搜索 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="搜索:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource MesTextBox}" FontSize="13" ToolTip="搜索产品、批次、工单、操作员"/>
            </Grid>
        </Border>

        <!-- 数据表格 -->
        <DataGrid Grid.Row="3" Style="{DynamicResource MesDataGrid}"
                  ItemsSource="{Binding ProductionReports}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="日期" Binding="{Binding ReportDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="工单号" Binding="{Binding WorkOrderNo}" Width="120"/>
                <DataGridTextColumn Header="产品" Binding="{Binding ProductName}" Width="140"/>
                <DataGridTextColumn Header="批次号" Binding="{Binding LotNo}" Width="120"/>
                <DataGridTextColumn Header="工序" Binding="{Binding ProcessStep}" Width="100"/>
                <DataGridTextColumn Header="投入" Binding="{Binding InputQty}" Width="80"/>
                <DataGridTextColumn Header="产出" Binding="{Binding OutputQty}" Width="80"/>
                <DataGridTextColumn Header="良品" Binding="{Binding GoodQty}" Width="80"/>
                <DataGridTextColumn Header="报废" Binding="{Binding ScrapQty}" Width="80"/>
                <DataGridTextColumn Header="良率" Binding="{Binding YieldRate, StringFormat={}{0:P2}}" Width="80"/>
                <DataGridTextColumn Header="效率" Binding="{Binding Efficiency, StringFormat={}{0:P2}}" Width="80"/>
                <DataGridTextColumn Header="班次" Binding="{Binding Shift}" Width="80"/>
                <DataGridTextColumn Header="操作员" Binding="{Binding Operator}" Width="100"/>
                <DataGridTextColumn Header="设备" Binding="{Binding EquipmentNo}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
