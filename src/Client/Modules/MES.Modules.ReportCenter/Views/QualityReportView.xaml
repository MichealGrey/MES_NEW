<UserControl x:Class="MES.Modules.ReportCenter.Views.QualityReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
    xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
    prism:ViewModelLocator.AutoWireViewModel="True"
    Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="质量报表" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource MesTextPrimaryBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="统计汇总" Style="{DynamicResource MesPrimaryButton}" Command="{Binding LoadStatisticsCommand}"
                        Margin="0,0,8,0" Padding="16,6"/>
                <Button Content="清除筛选" Style="{DynamicResource MesSecondaryButton}" Command="{Binding ClearFilterCommand}"
                        Margin="0,0,8,0" Padding="16,6"/>
                <Button Content="刷新" Style="{DynamicResource MesPrimaryButton}" Command="{Binding RefreshCommand}"
                        Padding="16,6"/>
            </StackPanel>
        </Grid>

        <!-- 统计卡片 -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="总检验数" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalCount}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="严重缺陷" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding CriticalCount}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDangerBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="主要缺陷" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding MajorCount}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesWarningBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="次要缺陷" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding MinorCount}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesInfoBrush}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- 统计汇总信息 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16"
                Visibility="{Binding Statistics, Converter={StaticResource NullToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="统计汇总: " FontSize="14" FontWeight="SemiBold" Margin="0,0,12,0"
                           Foreground="{DynamicResource MesTextPrimaryBrush}"/>
                <TextBlock Text="{Binding Statistics.TotalInspections, StringFormat=总检验数: {0}}" FontSize="13" Margin="0,0,16,0"
                           Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                <TextBlock Text="{Binding Statistics.OverallPassRate, StringFormat=总通过率: {0:P2}}" FontSize="13" Margin="0,0,16,0"
                           Foreground="{DynamicResource MesSuccessBrush}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Statistics.CriticalDefects, StringFormat=严重缺陷: {0}}" FontSize="13" Margin="0,0,16,0"
                           Foreground="{DynamicResource MesDangerBrush}"/>
                <TextBlock Text="{Binding Statistics.TopDefectType, StringFormat=主要缺陷类型: {0}}" FontSize="13" Margin="0,0,16,0"
                           Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                <TextBlock Text="{Binding Statistics.TopDefectCount, StringFormat=缺陷数: {0}}" FontSize="13"
                           Foreground="{DynamicResource MesTextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <!-- 过滤栏 -->
        <Border Grid.Row="3" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 日期范围 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="日期:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                    <DatePicker Width="120" SelectedDate="{Binding StartDate}" FontSize="13" Style="{DynamicResource MesDatePicker}"/>
                    <TextBlock Text="至" VerticalAlignment="Center" Margin="4,0"/>
                    <DatePicker Width="120" SelectedDate="{Binding EndDate}" FontSize="13" Style="{DynamicResource MesDatePicker}"/>
                </StackPanel>

                <!-- 严重程度 -->
                <TextBlock Grid.Row="0" Grid.Column="2" Text="严重度:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="0" Grid.Column="3" Width="120" SelectedValue="{Binding FilterSeverity}"
                          Style="{DynamicResource MesComboBox}" FontSize="13" Margin="0,0,16,0">
                    <ComboBoxItem Content="全部"/>
                    <ComboBoxItem Content="Critical"/>
                    <ComboBoxItem Content="Major"/>
                    <ComboBoxItem Content="Minor"/>
                </ComboBox>

                <!-- 工序 -->
                <TextBlock Grid.Row="0" Grid.Column="4" Text="工序:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding FilterProcessStep, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource MesTextBox}" FontSize="13"/>

                <!-- 搜索 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="搜索:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource MesTextBox}" FontSize="13" Grid.ColumnSpan="5"
                         ToolTip="搜索产品、批次、缺陷描述、检验员"/>
            </Grid>
        </Border>

        <!-- 数据表格 -->
        <DataGrid Grid.Row="4" Style="{DynamicResource MesDataGrid}"
                  ItemsSource="{Binding QualityReports}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="日期" Binding="{Binding ReportDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="检验编号" Binding="{Binding InspectionNo}" Width="120"/>
                <DataGridTextColumn Header="批次号" Binding="{Binding LotNo}" Width="120"/>
                <DataGridTextColumn Header="产品" Binding="{Binding ProductName}" Width="140"/>
                <DataGridTextColumn Header="工序" Binding="{Binding ProcessStep}" Width="100"/>
                <DataGridTextColumn Header="检验数" Binding="{Binding InspectedQty}" Width="80"/>
                <DataGridTextColumn Header="合格数" Binding="{Binding PassQty}" Width="80"/>
                <DataGridTextColumn Header="不合格数" Binding="{Binding FailQty}" Width="80"/>
                <DataGridTextColumn Header="合格率" Binding="{Binding PassRate, StringFormat={}{0:P2}}" Width="80"/>
                <DataGridTextColumn Header="缺陷代码" Binding="{Binding DefectCode}" Width="100"/>
                <DataGridTextColumn Header="缺陷描述" Binding="{Binding DefectDescription}" Width="150"/>
                <DataGridTextColumn Header="严重度" Binding="{Binding Severity}" Width="80"/>
                <DataGridTextColumn Header="处置方式" Binding="{Binding Disposition}" Width="100"/>
                <DataGridTextColumn Header="检验员" Binding="{Binding Inspector}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
