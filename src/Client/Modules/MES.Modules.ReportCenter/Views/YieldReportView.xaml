<UserControl x:Class="MES.Modules.ReportCenter.Views.YieldReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="良率报表" FontSize="24" FontWeight="SemiBold"
                       Foreground="{DynamicResource MesTextPrimaryBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="趋势分析" Style="{DynamicResource MesPrimaryButton}" Command="{Binding LoadTrendCommand}"
                        Margin="0,0,8,0" Padding="16,6"/>
                <Button Content="清除筛选" Style="{DynamicResource MesSecondaryButton}" Command="{Binding ClearFilterCommand}"
                        Margin="0,0,8,0" Padding="16,6"/>
                <Button Content="刷新" Style="{DynamicResource MesPrimaryButton}" Command="{Binding RefreshCommand}"
                        Padding="16,6"/>
            </StackPanel>
        </Grid>

        <!-- 统计卡片 -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,16">
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="平均良率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding AvgYieldRate, StringFormat={}{0:P2}}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesSuccessBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="最低良率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding MinYieldRate, StringFormat={}{0:P2}}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDangerBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="最高良率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding MaxYieldRate, StringFormat={}{0:P2}}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesSuccessBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="低于目标" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding BelowTargetCount}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesWarningBrush}"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="总报废数" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalScrapQty}" FontSize="28" FontWeight="SemiBold"
                               Foreground="{DynamicResource MesDangerBrush}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- 过滤栏 -->
        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 日期范围 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="日期:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,16,0">
                    <DatePicker Width="120" SelectedDate="{Binding StartDate}" FontSize="13" Style="{DynamicResource MesDatePicker}"/>
                    <TextBlock Text="至" VerticalAlignment="Center" Margin="4,0"/>
                    <DatePicker Width="120" SelectedDate="{Binding EndDate}" FontSize="13" Style="{DynamicResource MesDatePicker}"/>
                </StackPanel>

                <!-- 产品 -->
                <TextBlock Grid.Row="0" Grid.Column="2" Text="产品:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding FilterProduct, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource MesTextBox}" Margin="0,0,16,0" FontSize="13"/>

                <!-- 工序 -->
                <TextBlock Grid.Row="0" Grid.Column="4" Text="工序:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding FilterProcessStep, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource MesTextBox}" FontSize="13"/>

                <!-- 搜索 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="搜索:" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource MesTextBox}" FontSize="13" Grid.ColumnSpan="5" ToolTip="搜索产品、批次、缺陷类型"/>
            </Grid>
        </Border>

        <!-- 良率报表表格 -->
        <DataGrid Grid.Row="3" Style="{DynamicResource MesDataGrid}"
                  ItemsSource="{Binding YieldReports}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="日期" Binding="{Binding ReportDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="产品编号" Binding="{Binding ProductId}" Width="120"/>
                <DataGridTextColumn Header="产品名称" Binding="{Binding ProductName}" Width="140"/>
                <DataGridTextColumn Header="批次号" Binding="{Binding LotNo}" Width="120"/>
                <DataGridTextColumn Header="工序" Binding="{Binding ProcessStep}" Width="100"/>
                <DataGridTextColumn Header="投入" Binding="{Binding TotalInput}" Width="80"/>
                <DataGridTextColumn Header="产出" Binding="{Binding TotalOutput}" Width="80"/>
                <DataGridTextColumn Header="良品" Binding="{Binding GoodQty}" Width="80"/>
                <DataGridTextColumn Header="报废" Binding="{Binding ScrapQty}" Width="80"/>
                <DataGridTextColumn Header="良率" Binding="{Binding YieldRate, StringFormat={}{0:P2}}" Width="80"/>
                <DataGridTextColumn Header="目标良率" Binding="{Binding TargetYield, StringFormat={}{0:P2}}" Width="100"/>
                <DataGridTextColumn Header="主要缺陷" Binding="{Binding TopDefectType}" Width="120"/>
                <DataGridTextColumn Header="缺陷数" Binding="{Binding TopDefectCount}" Width="80"/>
                <DataGridTextColumn Header="班次" Binding="{Binding Shift}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 缺陷分析 -->
        <TextBlock Grid.Row="4" Text="缺陷分析 TOP" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}"
                   Margin="0,20,0,12"/>
        <DataGrid Grid.Row="5" Style="{DynamicResource MesDataGrid}"
                  ItemsSource="{Binding DefectAnalysis}"
                  AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="250"
                  CanUserAddRows="False" CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="缺陷类型" Binding="{Binding DefectType}" Width="150"/>
                <DataGridTextColumn Header="缺陷数" Binding="{Binding DefectCount}" Width="100"/>
                <DataGridTextColumn Header="占比" Binding="{Binding Percentage, StringFormat={}{0:P2}}" Width="100"/>
                <DataGridTextColumn Header="影响产品" Binding="{Binding AffectedProduct}" Width="150"/>
                <DataGridTextColumn Header="首次发生" Binding="{Binding FirstOccurrence, StringFormat=yyyy-MM-dd HH:mm}" Width="150"/>
                <DataGridTextColumn Header="最近发生" Binding="{Binding LastOccurrence, StringFormat=yyyy-MM-dd HH:mm}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
