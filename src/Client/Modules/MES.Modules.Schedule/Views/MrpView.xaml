<UserControl x:Class="MES.Modules.Schedule.Views.MrpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="物料需求计划(MRP)" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,16"/>

        <UniformGrid Grid.Row="1" Rows="1" Margin="0,0,0,16">
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="物料总数" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalMaterials}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesInfoBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="短缺物料" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding ShortageCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesDangerBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="短缺总量" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalShortageQty}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesWarningBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="充足物料" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding AvailableProcessCount, FallbackValue=0}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesSuccessBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <CheckBox Content="仅显示短缺物料" IsChecked="{Binding ShowShortageOnly}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Content="刷新" Command="{Binding RefreshCommand}" Style="{DynamicResource MesPrimaryButton}"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesDangerBrush}" FontSize="13" Margin="0,0,0,16" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <Border Grid.Row="4" Style="{DynamicResource MesCard}" Padding="0">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True" Style="{DynamicResource MesDataGrid}" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="物料编码" Binding="{Binding MaterialNo}" Width="120"/>
                    <DataGridTextColumn Header="物料名称" Binding="{Binding MaterialName}" Width="*"/>
                    <DataGridTextColumn Header="需求数量" Binding="{Binding RequiredQty}" Width="80"/>
                    <DataGridTextColumn Header="可用数量" Binding="{Binding AvailableQty}" Width="80"/>
                    <DataGridTextColumn Header="短缺数量" Binding="{Binding ShortageQty}" Width="80"/>
                    <DataGridTextColumn Header="供应商" Binding="{Binding Supplier}" Width="120"/>
                    <DataGridTextColumn Header="交期(天)" Binding="{Binding LeadTime}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
