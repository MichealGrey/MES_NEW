<UserControl x:Class="MES.Modules.SystemSettings.Views.ExternalSystemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">
    <UserControl.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource MesCardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 统计卡片 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding TotalSystems}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource MesPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="系统总数" FontSize="12" Foreground="{DynamicResource MesTextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding EnabledSystems}" FontSize="28" FontWeight="Bold" Foreground="Green" HorizontalAlignment="Center"/>
                    <TextBlock Text="已启用" FontSize="12" Foreground="{DynamicResource MesTextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding DisabledSystems}" FontSize="28" FontWeight="Bold" Foreground="Gray" HorizontalAlignment="Center"/>
                    <TextBlock Text="已禁用" FontSize="12" Foreground="{DynamicResource MesTextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding TotalFailedSync}" FontSize="28" FontWeight="Bold" Foreground="Red" HorizontalAlignment="Center"/>
                    <TextBlock Text="同步失败" FontSize="12" Foreground="{DynamicResource MesTextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 工具栏 -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Padding="8" VerticalContentAlignment="Center" ToolTip="搜索系统名称/代码/类型"/>
            <Button Grid.Column="2" Content="刷新" Command="{Binding RefreshCommand}" Width="70"/>
        </Grid>

        <!-- 外部系统列表 -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Systems}" SelectedItem="{Binding SelectedSystem}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True" GridLinesVisibility="Horizontal" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="系统代码" Binding="{Binding SystemCode}" Width="120"/>
                <DataGridTextColumn Header="系统名称" Binding="{Binding SystemName}" Width="150"/>
                <DataGridTextColumn Header="类型" Binding="{Binding SystemType}" Width="100"/>
                <DataGridTextColumn Header="端点" Binding="{Binding Endpoint}" Width="200"/>
                <DataGridTextColumn Header="认证方式" Binding="{Binding AuthType}" Width="80"/>
                <DataGridTextColumn Header="已启用" Binding="{Binding IsEnabled}" Width="60"/>
                <DataGridTextColumn Header="超时(秒)" Binding="{Binding Timeout}" Width="70"/>
                <DataGridTextColumn Header="重试次数" Binding="{Binding RetryCount}" Width="70"/>
                <DataGridTextColumn Header="最后同步时间" Binding="{Binding LastSyncTime}" Width="130"/>
                <DataGridTextColumn Header="最后同步状态" Binding="{Binding LastSyncStatus}" Width="100"/>
                <DataGridTextColumn Header="总同步次数" Binding="{Binding TotalSyncCount}" Width="90"/>
                <DataGridTextColumn Header="失败次数" Binding="{Binding FailedSyncCount}" Width="80"/>
                <DataGridTemplateColumn Header="操作" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="详情" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}" Margin="2" Padding="6,2"/>
                                <Button Content="启用/禁用" Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}" Margin="2" Padding="6,2"/>
                                <Button Content="同步" Command="{Binding DataContext.TriggerSyncCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}" Margin="2" Padding="6,2"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 错误提示 -->
        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" TextWrapping="Wrap"/>
    </Grid>
</UserControl>
