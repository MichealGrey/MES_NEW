<UserControl x:Class="MES.Modules.Trace.Views.ForwardTraceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="正向追溯" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,16"/>

        <UniformGrid Grid.Row="1" Rows="1" Margin="0,0,0,16">
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="总工序数" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalSteps}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesInfoBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="合格数" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding PassCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesSuccessBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="不合格数" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding FailCount}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesDangerBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="合格率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding PassRate, StringFormat={}{0:F1}%}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="批次号:" VerticalAlignment="Center" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,8,0"/>
                <TextBox Width="200" Text="{Binding SearchLotId}" Style="{DynamicResource MesTextBox}" Margin="0,0,16,0" ToolTip="输入要追溯的批次号"/>
                <Button Content="追溯" Command="{Binding TraceCommand}" Style="{DynamicResource MesPrimaryButton}"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesDangerBrush}" FontSize="13" Margin="0,0,0,16" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <Border Grid.Row="4" Style="{DynamicResource MesCard}" Padding="0">
            <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" AutoGenerateColumns="False" IsReadOnly="True" Style="{DynamicResource MesDataGrid}" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="工序号" Binding="{Binding StepNo}" Width="80"/>
                    <DataGridTextColumn Header="操作" Binding="{Binding Operation}" Width="120"/>
                    <DataGridTextColumn Header="设备号" Binding="{Binding EquipmentId}" Width="100"/>
                    <DataGridTextColumn Header="操作员" Binding="{Binding Operator}" Width="100"/>
                    <DataGridTextColumn Header="配方" Binding="{Binding RecipeId}" Width="100"/>
                    <DataGridTextColumn Header="开始时间" Binding="{Binding StartTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="160"/>
                    <DataGridTextColumn Header="结束时间" Binding="{Binding EndTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="160"/>
                    <DataGridTemplateColumn Header="结果" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="6,2" HorizontalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource MesBadge}">
                                            <Setter Property="Background" Value="{DynamicResource MesSuccessBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource MesSuccessBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Result}" Value="Fail">
                                                    <Setter Property="Background" Value="{DynamicResource MesDangerBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource MesDangerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Result}" FontSize="10" FontWeight="Medium" Foreground="White"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
