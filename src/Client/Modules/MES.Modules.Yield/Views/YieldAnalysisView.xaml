<UserControl x:Class="MES.Modules.Yield.Views.YieldAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:MES.Shared.Converters;assembly=MES.Shared"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource MesBackgroundPrimaryBrush}">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="良率分析" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource MesTextPrimaryBrush}" Margin="0,0,0,16"/>

        <UniformGrid Grid.Row="1" Rows="1" Margin="0,0,0,16">
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="平均良率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding AvgYield, StringFormat={}{0:F1}%}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesInfoBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="最低良率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding MinYield, StringFormat={}{0:F1}%}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesDangerBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{DynamicResource MesKpiCard}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="最高良率" FontSize="13" Foreground="{DynamicResource MesTextSecondaryBrush}"/>
                    <TextBlock Text="{Binding MaxYield, StringFormat={}{0:F1}%}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource MesSuccessBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Style="{DynamicResource MesCard}" Padding="16" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="产品:" VerticalAlignment="Center" Foreground="{DynamicResource MesTextSecondaryBrush}" Margin="0,0,8,0"/>
                <ComboBox Width="200" SelectedItem="{Binding SelectedProduct}" ItemsSource="{Binding Products}" Style="{DynamicResource MesComboBox}" Margin="0,0,16,0"/>
                <Button Content="分析" Command="{Binding AnalyzeCommand}" Style="{DynamicResource MesPrimaryButton}"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" Foreground="{DynamicResource MesDangerBrush}" FontSize="13" Margin="0,0,0,16" Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <Border Grid.Row="4" Style="{DynamicResource MesCard}" Padding="0">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True" Style="{DynamicResource MesDataGrid}" FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="日期" Binding="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110"/>
                    <DataGridTextColumn Header="产品" Binding="{Binding Product}" Width="120"/>
                    <DataGridTextColumn Header="良率" Binding="{Binding Yield, StringFormat={}{0:F1}%}" Width="80"/>
                    <DataGridTextColumn Header="目标良率" Binding="{Binding TargetYield, StringFormat={}{0:F1}%}" Width="100"/>
                    <DataGridTextColumn Header="总数量" Binding="{Binding TotalQty}" Width="80"/>
                    <DataGridTextColumn Header="合格数量" Binding="{Binding GoodQty}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
