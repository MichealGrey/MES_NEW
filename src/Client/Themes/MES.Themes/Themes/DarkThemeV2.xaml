<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================
         OSAT MES DarkTheme V2.0
         "Industrial Precision, Humanized Intelligence"
         设计理念：工业精密感 + 人性化智能
         版本：V2.0
         日期：2026-05-30
    ============================================ -->

    <!-- ============================================
         第一部分：背景层级色彩
    ============================================ -->
    <Color x:Key="MesBackgroundPrimary">#0A0E17</Color>
    <Color x:Key="MesBackgroundSurface">#0F1521</Color>
    <Color x:Key="MesBackgroundElevated">#141C2B</Color>
    <Color x:Key="MesBackgroundOverlay">#1A2332</Color>

    <!-- ============================================
         第二部分：边框与分隔线
    ============================================ -->
    <Color x:Key="MesBorderDefault">#2A3545</Color>
    <Color x:Key="MesBorderHover">#3D4F66</Color>
    <Color x:Key="MesBorderLight">#4A5A72</Color>
    <Color x:Key="MesDivider">#1E2A3A</Color>

    <!-- ============================================
         第三部分：文字层级色彩
    ============================================ -->
    <Color x:Key="MesTextPrimary">#FFFFFF</Color>
    <Color x:Key="MesTextSecondary">#94A3B8</Color>
    <Color x:Key="MesTextTertiary">#64748B</Color>
    <Color x:Key="MesTextDisabled">#475569</Color>
    <Color x:Key="MesTextInverse">#0F1521</Color>

    <!-- ============================================
         第四部分：语义色彩（状态）
    ============================================ -->
    <Color x:Key="MesSuccess">#10B981</Color>
    <Color x:Key="MesWarning">#F59E0B</Color>
    <Color x:Key="MesDanger">#EF4444</Color>
    <Color x:Key="MesInfo">#3B82F6</Color>
    <Color x:Key="MesCritical">#FF2D55</Color>

    <!-- ============================================
         第五部分：批次层级专属色彩（核心创新）
    ============================================ -->
    <Color x:Key="MesWaferLotLevel">#8B5CF6</Color>
    <Color x:Key="MesMotherLotLevel">#06B6D4</Color>
    <Color x:Key="MesSubLotLevel">#10B981</Color>
    <Color x:Key="MesGradeLotLevel">#F59E0B</Color>
    <Color x:Key="MesMfgIdLevel">#EC4899</Color>

    <!-- ============================================
         第六部分：工艺段色彩
    ============================================ -->
    <Color x:Key="MesProcessThin">#FF6B6B</Color>
    <Color x:Key="MesProcessDieAttach">#4ECDC4</Color>
    <Color x:Key="MesProcessMold">#45B7D1</Color>
    <Color x:Key="MesProcessSingulate">#96CEB4</Color>
    <Color x:Key="MesProcessTest">#FFEAA7</Color>
    <Color x:Key="MesProcessTape">#DDA0DD</Color>

    <!-- ============================================
         第七部分：背景 Brushes
    ============================================ -->
    <SolidColorBrush x:Key="MesBackgroundPrimaryBrush" Color="{StaticResource MesBackgroundPrimary}"/>
    <SolidColorBrush x:Key="MesBackgroundSurfaceBrush" Color="{StaticResource MesBackgroundSurface}"/>
    <SolidColorBrush x:Key="MesBackgroundElevatedBrush" Color="{StaticResource MesBackgroundElevated}"/>
    <SolidColorBrush x:Key="MesBackgroundOverlayBrush" Color="{StaticResource MesBackgroundOverlay}"/>

    <!-- ============================================
         第八部分：边框 Brushes
    ============================================ -->
    <SolidColorBrush x:Key="MesBorderDefaultBrush" Color="{StaticResource MesBorderDefault}"/>
    <SolidColorBrush x:Key="MesBorderHoverBrush" Color="{StaticResource MesBorderHover}"/>
    <SolidColorBrush x:Key="MesBorderLightBrush" Color="{StaticResource MesBorderLight}"/>
    <SolidColorBrush x:Key="MesDividerBrush" Color="{StaticResource MesDivider}"/>

    <!-- ============================================
         第九部分：文字 Brushes
    ============================================ -->
    <SolidColorBrush x:Key="MesTextPrimaryBrush" Color="{StaticResource MesTextPrimary}"/>
    <SolidColorBrush x:Key="MesTextSecondaryBrush" Color="{StaticResource MesTextSecondary}"/>
    <SolidColorBrush x:Key="MesTextTertiaryBrush" Color="{StaticResource MesTextTertiary}"/>
    <SolidColorBrush x:Key="MesTextDisabledBrush" Color="{StaticResource MesTextDisabled}"/>

    <!-- ============================================
         第十部分：语义 Brushes
    ============================================ -->
    <SolidColorBrush x:Key="MesSuccessBrush" Color="{StaticResource MesSuccess}"/>
    <SolidColorBrush x:Key="MesWarningBrush" Color="{StaticResource MesWarning}"/>
    <SolidColorBrush x:Key="MesDangerBrush" Color="{StaticResource MesDanger}"/>
    <SolidColorBrush x:Key="MesInfoBrush" Color="{StaticResource MesInfo}"/>
    <SolidColorBrush x:Key="MesCriticalBrush" Color="{StaticResource MesCritical}"/>

    <!-- ============================================
         第十一部分：批次层级 Brushes
    ============================================ -->
    <SolidColorBrush x:Key="MesWaferLotLevelBrush" Color="{StaticResource MesWaferLotLevel}"/>
    <SolidColorBrush x:Key="MesMotherLotLevelBrush" Color="{StaticResource MesMotherLotLevel}"/>
    <SolidColorBrush x:Key="MesSubLotLevelBrush" Color="{StaticResource MesSubLotLevel}"/>
    <SolidColorBrush x:Key="MesGradeLotLevelBrush" Color="{StaticResource MesGradeLotLevel}"/>
    <SolidColorBrush x:Key="MesMfgIdLevelBrush" Color="{StaticResource MesMfgIdLevel}"/>

    <!-- ============================================
         第十二部分：工艺段 Brushes
    ============================================ -->
    <SolidColorBrush x:Key="MesProcessThinBrush" Color="{StaticResource MesProcessThin}"/>
    <SolidColorBrush x:Key="MesProcessDieAttachBrush" Color="{StaticResource MesProcessDieAttach}"/>
    <SolidColorBrush x:Key="MesProcessMoldBrush" Color="{StaticResource MesProcessMold}"/>
    <SolidColorBrush x:Key="MesProcessSingulateBrush" Color="{StaticResource MesProcessSingulate}"/>
    <SolidColorBrush x:Key="MesProcessTestBrush" Color="{StaticResource MesProcessTest}"/>
    <SolidColorBrush x:Key="MesProcessTapeBrush" Color="{StaticResource MesProcessTape}"/>

    <!-- ============================================
         第十三部分：字体系统
    ============================================ -->
    <FontFamily x:Key="MesFontDisplay">Segoe UI Semibold</FontFamily>
    <FontFamily x:Key="MesFontBody">Microsoft YaHei UI</FontFamily>
    <FontFamily x:Key="MesFontCode">Cascadia Code, Consolas</FontFamily>

    <!-- 字号定义 -->
    <sys:Double x:Key="MesFontSizeH1" xmlns:sys="clr-namespace:System;assembly=mscorlib">28</sys:Double>
    <sys:Double x:Key="MesFontSizeH2" xmlns:sys="clr-namespace:System;assembly=mscorlib">20</sys:Double>
    <sys:Double x:Key="MesFontSizeH3" xmlns:sys="clr-namespace:System;assembly=mscorlib">18</sys:Double>
    <sys:Double x:Key="MesFontSizeBody" xmlns:sys="clr-namespace:System;assembly=mscorlib">14</sys:Double>
    <sys:Double x:Key="MesFontSizeSmall" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <sys:Double x:Key="MesFontSizeTag" xmlns:sys="clr-namespace:System;assembly=mscorlib">11</sys:Double>

    <!-- ============================================
         第十四部分：间距系统（4px基准）
    ============================================ -->
    <Thickness x:Key="MesSpacingXs">4</Thickness>
    <Thickness x:Key="MesSpacingSm">8</Thickness>
    <Thickness x:Key="MesSpacingMd">12</Thickness>
    <Thickness x:Key="MesSpacingLg">16</Thickness>
    <Thickness x:Key="MesSpacingXl">24</Thickness>
    <Thickness x:Key="MesSpacing2xl">32</Thickness>

    <!-- ============================================
         第十五部分：圆角系统
    ============================================ -->
    <CornerRadius x:Key="MesRadiusSm">4</CornerRadius>
    <CornerRadius x:Key="MesRadiusMd">8</CornerRadius>
    <CornerRadius x:Key="MesRadiusLg">12</CornerRadius>
    <CornerRadius x:Key="MesRadiusXl">16</CornerRadius>
    <CornerRadius x:Key="MesRadiusFull">9999</CornerRadius>

    <!-- ============================================
         第十六部分：阴影效果
    ============================================ -->
    <DropShadowEffect x:Key="MesShadowSm" BlurRadius="4" ShadowDepth="1" Opacity="0.3" Color="Black"/>
    <DropShadowEffect x:Key="MesShadowMd" BlurRadius="8" ShadowDepth="4" Opacity="0.4" Color="Black"/>
    <DropShadowEffect x:Key="MesShadowLg" BlurRadius="16" ShadowDepth="8" Opacity="0.5" Color="Black"/>
    <DropShadowEffect x:Key="MesShadowGlow" BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#3B82F6"/>

</ResourceDictionary>
