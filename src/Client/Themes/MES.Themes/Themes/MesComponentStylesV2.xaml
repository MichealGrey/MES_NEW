<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================
         OSAT MES 组件样式库 V2.0
         包含：按钮、输入框、卡片、表格、标签等
         版本：V2.0
         日期：2026-05-30
    ============================================ -->

    <!-- 引用主题资源 -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="DarkThemeV2.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ============================================
         第一部分：按钮组件样式
    ============================================ -->

    <!-- 主要按钮（Primary Button） -->
    <Style x:Key="MesPrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource MesInfoBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource MesTextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="20, 12"/>
        <Setter Property="FontFamily" Value="{StaticResource MesFontBody}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource MesRadiusSm}"
                            Padding="{TemplateBinding Padding}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}">
                        <ContentPresenter HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#2563EB"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MesTextDisabledBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource MesTextDisabledBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
    </Style>

    <!-- 次要按钮（Secondary Button） -->
    <Style x:Key="MesSecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource MesBackgroundElevatedBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource MesTextSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesBorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="20, 12"/>
        <Setter Property="FontFamily" Value="{StaticResource MesFontBody}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource MesRadiusSm}"
                            Padding="{TemplateBinding Padding}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}">
                        <ContentPresenter HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MesBorderDefaultBrush}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource MesBorderHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MesBackgroundElevatedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 危险按钮（Danger Button） -->
    <Style x:Key="MesDangerButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource MesDangerBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource MesTextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="20, 12"/>
        <Setter Property="FontFamily" Value="{StaticResource MesFontBody}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource MesRadiusSm}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#B91C1C"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MesTextDisabledBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 幽灵按钮（Ghost Button） -->
    <Style x:Key="MesGhostButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource MesInfoBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12, 8"/>
        <Setter Property="FontFamily" Value="{StaticResource MesFontBody}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource MesRadiusSm}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MesBackgroundElevatedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MesBackgroundSurfaceBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 小按钮（Small Button） -->
    <Style x:Key="MesSmallButton" TargetType="Button" BasedOn="{StaticResource MesPrimaryButton}">
        <Setter Property="Padding" Value="16, 8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="32"/>
    </Style>

    <!-- 大按钮（Large Button） -->
    <Style x:Key="MesLargeButton" TargetType="Button" BasedOn="{StaticResource MesPrimaryButton}">
        <Setter Property="Padding" Value="24, 14"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Height" Value="48"/>
    </Style>

    <!-- 图标按钮（Icon Button） -->
    <Style x:Key="MesIconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource MesTextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource MesRadiusSm}">
                        <ContentPresenter HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MesBackgroundElevatedBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource MesTextPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================
         第二部分：文本输入框样式
    ============================================ -->

    <!-- 默认文本框 -->
    <Style x:Key="MesTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource MesBackgroundElevatedBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource MesTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesBorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12, 10"/>
        <Setter Property="FontFamily" Value="{StaticResource MesFontBody}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="CaretBrush" Value="{StaticResource MesTextPrimaryBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource MesInfoBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource MesRadiusSm}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                     Margin="{TemplateBinding Padding}"
                                     VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource MesInfoBrush}"/>
                            <Setter TargetName="border" Property="Effect" Value="{StaticResource MesShadowGlow}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource MesBorderHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource MesBackgroundSurfaceBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource MesTextDisabledBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 错误状态文本框 -->
    <Style x:Key="MesTextBoxError" TargetType="TextBox" BasedOn="{StaticResource MesTextBox}">
        <Setter Property="BorderBrush" Value="{StaticResource MesDangerBrush}"/>
    </Style>

    <!-- ============================================
         第三部分：卡片组件样式
    ============================================ -->

    <!-- 基础卡片 -->
    <Style x:Key="MesCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MesBackgroundSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesBorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource MesRadiusMd}"/>
        <Setter Property="Padding" Value="20"/>
    </Style>

    <!-- KPI 统计卡片 -->
    <Style x:Key="MesKpiCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MesBackgroundSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesBorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource MesRadiusMd}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform X="0" Y="0"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                           To="-4" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                           To="0" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 操作卡片 -->
    <Style x:Key="MesActionCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MesBackgroundSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesBorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource MesRadiusMd}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource MesInfoBrush}"/>
                <Setter Property="Background" Value="{StaticResource MesBackgroundElevatedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================
         第四部分：表格组件样式
    ============================================ -->

    <!-- 表格容器 -->
    <Style x:Key="MesDataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource MesBackgroundSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesBorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="RowBackground" Value="{StaticResource MesBackgroundSurfaceBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource MesBackgroundElevatedBrush}"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource MesDividerBrush}"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="FontFamily" Value="{StaticResource MesFontBody}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- 表格列头样式 -->
    <Style x:Key="MesDataGridColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource MesBackgroundSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource MesTextTertiaryBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="12, 0"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesDividerBrush}"/>
        <Setter Property="BorderThickness" Value="0, 0, 0, 1"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <!-- 表格行样式 -->
    <Style x:Key="MesDataGridRow" TargetType="DataGridRow">
        <Setter Property="Height" Value="48"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource MesTextPrimaryBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource MesBackgroundOverlayBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource MesBackgroundElevatedBrush}"/>
            </Trigger>
            <Trigger Property="AlternationIndex" Value="1">
                <Setter Property="Background" Value="{StaticResource MesBackgroundElevatedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 表格单元格样式 -->
    <Style x:Key="MesDataGridCell" TargetType="DataGridCell">
        <Setter Property="Padding" Value="12, 0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource MesTextPrimaryBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================
         第五部分：标签/徽章组件样式
    ============================================ -->

    <!-- 状态标签基类 -->
    <Style x:Key="MesStatusTag" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource MesRadiusSm}"/>
        <Setter Property="Padding" Value="8, 4"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- 批次层级标签样式（带色块） -->
    <Style x:Key="MesLotLevelTag" TargetType="Border">
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Padding" Value="4, 2"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- 批次层级文字样式 -->
    <Style x:Key="MesLotLevelText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MesFontBody}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="4, 0, 0, 0"/>
    </Style>

    <!-- ============================================
         第六部分：下拉框样式
    ============================================ -->

    <Style x:Key="MesComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource MesBackgroundElevatedBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource MesTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesBorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12, 10"/>
        <Setter Property="FontFamily" Value="{StaticResource MesFontBody}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- ============================================
         第七部分：滚动条样式
    ============================================ -->

    <Style x:Key="MesScrollBarThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="{StaticResource MesBorderDefaultBrush}"
                           CornerRadius="4"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================
         第八部分：TabControl 样式
    ============================================ -->

    <Style x:Key="MesTabControl" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="MesTabItem" TargetType="TabItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource MesTextSecondaryBrush}"/>
        <Setter Property="Padding" Value="16, 12"/>
        <Setter Property="FontFamily" Value="{StaticResource MesFontBody}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="border" Background="Transparent" Padding="{TemplateBinding Padding}">
                        <Grid>
                            <ContentPresenter x:Name="contentPresenter"
                                             ContentSource="Header"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                            <Border x:Name="indicator"
                                   Height="2"
                                   Background="{StaticResource MesInfoBrush}"
                                   VerticalAlignment="Bottom"
                                   Margin="0, 0, 0, -12"
                                   Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource MesTextPrimaryBrush}"/>
                            <Setter TargetName="indicator" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource MesTextPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================
         第九部分：模态框/弹窗样式
    ============================================ -->

    <Style x:Key="MesModalOverlay" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="Black" Opacity="0.7"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MesModalDialog" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MesBackgroundSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesBorderDefaultBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource MesRadiusLg}"/>
        <Setter Property="Effect" Value="{StaticResource MesShadowLg}"/>
    </Style>

    <!-- ============================================
         第十部分：进度条样式
    ============================================ -->

    <Style x:Key="MesProgressBar" TargetType="ProgressBar">
        <Setter Property="Background" Value="{StaticResource MesBackgroundElevatedBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource MesInfoBrush}"/>
        <Setter Property="Height" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}"
                           CornerRadius="{StaticResource MesRadiusSm}">
                        <Border x:Name="PART_Indicator"
                               HorizontalAlignment="Left"
                               Background="{TemplateBinding Foreground}"
                               CornerRadius="{StaticResource MesRadiusSm}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================
         第十一部分：状态标签/徽章组件样式
    ============================================ -->

    <!-- 基础标签样式 -->
    <Style x:Key="MesBadge" TargetType="Border">
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="CornerRadius" Value="{StaticResource MesRadiusSm}"/>
        <Setter Property="Background" Value="{StaticResource MesBackgroundElevatedBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesBorderDefaultBrush}"/>
    </Style>

    <!-- 成功状态标签 -->
    <Style x:Key="MesBadgeSuccess" TargetType="Border" BasedOn="{StaticResource MesBadge}">
        <Setter Property="Background" Value="{StaticResource MesSuccessBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesSuccessBrush}"/>
    </Style>

    <!-- 警告状态标签 -->
    <Style x:Key="MesBadgeWarning" TargetType="Border" BasedOn="{StaticResource MesBadge}">
        <Setter Property="Background" Value="{StaticResource MesWarningBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesWarningBrush}"/>
    </Style>

    <!-- 危险状态标签 -->
    <Style x:Key="MesBadgeDanger" TargetType="Border" BasedOn="{StaticResource MesBadge}">
        <Setter Property="Background" Value="{StaticResource MesDangerBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesDangerBrush}"/>
    </Style>

    <!-- 信息状态标签 -->
    <Style x:Key="MesBadgeInfo" TargetType="Border" BasedOn="{StaticResource MesBadge}">
        <Setter Property="Background" Value="{StaticResource MesInfoBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesInfoBrush}"/>
    </Style>

    <!-- 批次层级徽章 -->
    <Style x:Key="MesWaferLotBadge" TargetType="Border" BasedOn="{StaticResource MesBadge}">
        <Setter Property="Background" Value="{StaticResource MesWaferLotLevelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesWaferLotLevelBrush}"/>
    </Style>

    <Style x:Key="MesMotherLotBadge" TargetType="Border" BasedOn="{StaticResource MesBadge}">
        <Setter Property="Background" Value="{StaticResource MesMotherLotLevelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesMotherLotLevelBrush}"/>
    </Style>

    <Style x:Key="MesSubLotBadge" TargetType="Border" BasedOn="{StaticResource MesBadge}">
        <Setter Property="Background" Value="{StaticResource MesSubLotLevelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesSubLotLevelBrush}"/>
    </Style>

    <Style x:Key="MesGradeLotBadge" TargetType="Border" BasedOn="{StaticResource MesBadge}">
        <Setter Property="Background" Value="{StaticResource MesGradeLotLevelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesGradeLotLevelBrush}"/>
    </Style>

    <Style x:Key="MesMfgIdBadge" TargetType="Border" BasedOn="{StaticResource MesBadge}">
        <Setter Property="Background" Value="{StaticResource MesMfgIdLevelBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MesMfgIdLevelBrush}"/>
    </Style>

    <!-- ============================================
         第十二部分：模态框/弹窗样式增强
    ============================================ -->

    <!-- 模态框标题 -->
    <Style x:Key="MesModalTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource MesTextPrimaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <!-- 模态框内容区域 -->
    <Style x:Key="MesModalContent" TargetType="ContentControl">
        <Setter Property="Margin" Value="0,16"/>
    </Style>

    <!-- 模态框底部按钮区域 -->
    <Style x:Key="MesModalFooter" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Margin" Value="0,16,0,0"/>
    </Style>

</ResourceDictionary>
